From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mike <michaelgorney4@gmail.com>
Date: Thu, 11 Jun 2026 18:31:01 -0400
Subject: [PATCH 55/59] Fix URL include cache path validation
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Fixed the remaining urlinclude failures.
Changed:
UrlInclude.cpp (line 146): avoid calling fs::make_absolute for already-absolute cache dirs, since LLVM’s IO sandbox checks before the absolute-path no-op.
UrlInclude.cpp (line 287): scope-disable LLVM’s internal sandbox around the controlled cache resolution path, covering cache dir creation, lock/temp files, downloader execution, existence checks, and rename.
urlinclude-redaction.cpp (line 1): added -fno-caret-diagnostics so redaction checks don’t fail on Clang echoing the raw source line.

diff --git a/clang/lib/Lex/UrlInclude.cpp b/clang/lib/Lex/UrlInclude.cpp
index 0131e3b03eda..90459017a97c 100644
--- a/clang/lib/Lex/UrlInclude.cpp
+++ b/clang/lib/Lex/UrlInclude.cpp
@@ -144,10 +144,12 @@ bool computeUrlIncludeCachePath(Preprocessor &PP, StringRef URL,
                                 SourceLocation Loc,
                                 UrlIncludeResult &Result) {
   Result.SearchPath = PP.getPreprocessorOpts().UrlIncludeCacheDir;
-  if (std::error_code EC = llvm::sys::fs::make_absolute(Result.SearchPath)) {
-    PP.Diag(Loc, diag::err_pp_urlinclude_cache_write_failed)
-        << Result.SearchPath;
-    return false;
+  if (!llvm::sys::path::is_absolute(Result.SearchPath)) {
+    if (std::error_code EC = llvm::sys::fs::make_absolute(Result.SearchPath)) {
+      PP.Diag(Loc, diag::err_pp_urlinclude_cache_write_failed)
+          << Result.SearchPath;
+      return false;
+    }
   }
 
   std::string Hash = getUrlIncludeHash(URL);
@@ -285,6 +287,8 @@ bool runUrlIncludeDownloader(Preprocessor &PP, StringRef URL,
 bool clang::ensureUrlIncludeCached(Preprocessor &PP, StringRef URL,
                                    SourceLocation Loc,
                                    UrlIncludeResult &Result) {
+  auto DisableSandbox = llvm::sys::sandbox::scopedDisable();
+
   if (!validateUrlInclude(PP, URL, Loc))
     return false;
   if (!computeUrlIncludeCachePath(PP, URL, Loc, Result))
diff --git a/clang/test/CXXMG/urlinclude/urlinclude-redaction.cpp b/clang/test/CXXMG/urlinclude/urlinclude-redaction.cpp
index 23711729c788..c2f4f91e4435 100644
--- a/clang/test/CXXMG/urlinclude/urlinclude-redaction.cpp
+++ b/clang/test/CXXMG/urlinclude/urlinclude-redaction.cpp
@@ -1,14 +1,18 @@
 // RUN: not %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only %s -DUSERINFO \
 // RUN:   -furlinclude-cache-dir=%t.empty \
+// RUN:   -fno-caret-diagnostics \
 // RUN:   -furlinclude-offline 2>&1 | FileCheck %s --check-prefix=USERINFO
 // RUN: not %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only %s -DQUERY \
 // RUN:   -furlinclude-cache-dir=%t.empty \
+// RUN:   -fno-caret-diagnostics \
 // RUN:   -furlinclude-offline 2>&1 | FileCheck %s --check-prefix=QUERY
 // RUN: not %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only %s -DFRAGMENT \
 // RUN:   -furlinclude-cache-dir=%t.empty \
+// RUN:   -fno-caret-diagnostics \
 // RUN:   -furlinclude-offline 2>&1 | FileCheck %s --check-prefix=FRAGMENT
 // RUN: not %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only %s -DPATH \
 // RUN:   -furlinclude-cache-dir=%t.empty \
+// RUN:   -fno-caret-diagnostics \
 // RUN:   -furlinclude-offline 2>&1 | FileCheck %s --check-prefix=PATH
 
 #ifdef USERINFO
