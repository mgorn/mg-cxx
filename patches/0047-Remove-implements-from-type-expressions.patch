-
-ExprResult Parser::TryParseCXXMGTypePredicateExpression() {
-  if (!getLangOpts().CPlusPlusMG)
-    return ExprEmpty();
-
-  if (!mayStartCXXMGTypePredicateExpression(*this))
-    return ExprEmpty();
-
-  if (Tok.is(tok::l_paren)) {
-    TentativeParsingAction TPA(*this);
-    ConsumeParen();
-    ExprResult Inner = TryParseCXXMGTypePredicateExpression();
