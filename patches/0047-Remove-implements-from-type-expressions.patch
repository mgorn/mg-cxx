-    TPA.Revert();
-    return ExprEmpty();
-  }
-  if (!ParseCXXMGTypeExprRHS(LHS, prec::Unknown,
-                             /*AllowTypeNameFallback=*/false)) {
-    TPA.Revert();
-    return ExprEmpty();
-  }
-
-  if (!isCXXMGTypePredicateOperator(*this)) {
-    TPA.Revert();
-    return ExprEmpty();
-  }
-
-  SourceLocation OpLoc;
-  SourceLocation OpEndLoc;
-  bool UsesAngleSyntax = false;
-  if (Tok.is(tok::kw_implements)) {
-    OpLoc = ConsumeToken();
-    OpEndLoc = OpLoc;
-  } else {
-    OpLoc = ConsumeToken();
-    OpEndLoc = ConsumeToken();
-    UsesAngleSyntax = true;
-  }
-
-  if (Tok.isOneOf(tok::semi, tok::comma, tok::r_paren, tok::eof)) {
-    TPA.Commit();
-    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
-    return ExprError();
-  }
-
-  ParsedCXXMGTypeExpr RHS;
-  if (!ParseCXXMGTypeExprPrimary(RHS, /*AllowTypeNameFallback=*/true)) {
-    TPA.Commit();
-    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
-    return ExprError();
-  }
-  if (!ParseCXXMGTypeExprRHS(RHS, prec::Unknown,
-                             /*AllowTypeNameFallback=*/true)) {
-    TPA.Commit();
-    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
-    return ExprError();
-  }
-
-  auto Node = std::make_unique<ParsedCXXMGTypeExpr>();
-  Node->K = ParsedCXXMGTypeExpr::Binary;
-  Node->Op = ParsedCXXMGTypeExprOpcode::Implements;
-  Node->OpLoc = OpLoc;
-  Node->OpEndLoc = OpEndLoc;
-  Node->UsesAngleImplements = UsesAngleSyntax;
-  Node->BeginLoc = LHS.BeginLoc;
-  Node->EndLoc = RHS.EndLoc;
-  Node->SawTypeExprOperator = true;
-  Node->LHS = std::make_unique<ParsedCXXMGTypeExpr>(std::move(LHS));
-  Node->RHS = std::make_unique<ParsedCXXMGTypeExpr>(std::move(RHS));
-
-  TPA.Commit();
-  return Actions.ActOnCXXMGTypePredicateExpression(getCurScope(), *Node);
-}
