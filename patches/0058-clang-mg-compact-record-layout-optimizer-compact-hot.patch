index 000000000..5d5951e0e
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-already-optimal.cpp
@@ -0,0 +1,13 @@
+// When the fields are already in descending-alignment order, `compact` is a
+// no-op for size and correctness: the stable sort preserves the order.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct AlreadyOptimal {
+  double d;
+  int b;
+  char a;
+};
+
+static_assert(sizeof(AlreadyOptimal) == 16, "already-optimal layout is 16");
diff --git a/clang/test/CXXMG/compact/compact-array-of-structs.cpp b/clang/test/CXXMG/compact/compact-array-of-structs.cpp
