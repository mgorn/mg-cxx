diff --git a/clang/test/CXXMG/compact/compact-template-and-constexpr-local-class.cpp b/clang/test/CXXMG/compact/compact-template-and-constexpr-local-class.cpp
new file mode 100644
index 000000000..a869be4a2
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-template-and-constexpr-local-class.cpp
@@ -0,0 +1,55 @@
+// VERY hard combination: a `compact` struct declared local to a TEMPLATE
+// function and to a CONSTEXPR function. The template-local class is instantiated
+// (and reordered) per specialization, so its size tracks the template argument;
+// the constexpr-local class is reordered and its fields are read in a constant
+// expression. Both rely on the block-scope parse of `compact` and on the layout
+// optimizer running during instantiation / for the local class.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+// Template-function-local compact struct: TL = {char a; T b; int c;} reorders by
+// descending alignment per instantiation, so sizeof depends on T.
+template <class T> constexpr unsigned tlSize() {
+  compact struct TL {
+    char a;
+    T b;
+    int c;
+  };
+  return sizeof(TL);
+}
+static_assert(tlSize<double>() == 16, "{a,b=double,c} -> {b,c,a} = 16");
+static_assert(tlSize<int>() == 12, "{a,b=int,c} -> {b,c,a} = 12");
+static_assert(tlSize<char>() == 8, "{a,b=char,c} -> {c,a,b} = 8");
+
+// Constexpr-function-local compact struct: reordered, and every field reads back
+// correctly inside a constant expression.
+constexpr int clEval() {
+  compact struct CL {
+    char a;
+    double b;
+    int c;
+  };
+  CL x{};
+  x.a = 2;
+  x.b = 4.0;
+  x.c = 9;
+  return x.a + x.c + (int)x.b; // 2 + 9 + 4
+}
+static_assert(clEval() == 15, "constexpr reads through the reordered local layout");
+
+// And the same constexpr-local pattern exercised through a generic lambda.
+constexpr int viaGenericLambda() {
+  auto mk = [](auto seed) constexpr {
+    compact struct K {
+      char a;
+      decltype(seed) b;
+      int c;
+    };
+    K k{};
+    k.c = 6;
+    return k.c + (int)sizeof(K);
+  };
+  return mk(3.0); // c(6) + sizeof(K with b=double)=16 -> 22
+}
+static_assert(viaGenericLambda() == 22, "generic-lambda-local compact reorders and evaluates");
diff --git a/clang/test/CXXMG/compact/compact-template-hotcold-honored.cpp b/clang/test/CXXMG/compact/compact-template-hotcold-honored.cpp
new file mode 100644
index 000000000..015dd6b67
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-template-hotcold-honored.cpp
@@ -0,0 +1,26 @@
+// A compact CLASS TEMPLATE now HONORS hot/cold markers on its fields for every
+// instantiation: the pattern's markers are mapped positionally onto each
+// instantiation's (distinct) FieldDecls at Sema::ActOnFields. So Mega<int> pulls
+// the hot `value` to offset 0 (matching the non-template form in
+// compact-all-features-torture.cpp), keeps the cold `tag` last, and still
+// isolates the atomic `refs` onto its own cache line.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+template <class T> compact struct Mega {
+  cold char tag;
+  hot T value;
+  _Atomic int refs;
+  double d;
+};
+
+Mega<int> m;
+
+static_assert(sizeof(Mega<int>) == 192, "hot/cold + atomic isolation compose");
+
+// hot value is now FIRST (offset 0), not d -- the template honors hot/cold:
+// CHECK:      struct Mega<int>
+// CHECK:      0 |{{.*}}int value
+// CHECK:      8 |{{.*}}double d
+// CHECK:      64 |{{.*}}refs
+// CHECK:      128 |{{.*}}char tag
diff --git a/clang/test/CXXMG/compact/compact-template-instantiation.cpp b/clang/test/CXXMG/compact/compact-template-instantiation.cpp
new file mode 100644
index 000000000..e32af7cde
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-template-instantiation.cpp
@@ -0,0 +1,22 @@
+// A `compact` class template reorders each concrete instantiation by ITS field
+// alignments. The dependent pattern is skipped (its alignments are unknown), and
+// the reorder happens at instantiation completion (Sema::ActOnFields), so
+// Box<double> packs to {payload, id, tag} = 16 bytes instead of source-order 24.
+// Padding-min only here; hot/cold on template fields is a separate feature.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+template <class T> compact struct Box {
+  char tag;
+  T payload;
+  int id;
+};
+
+Box<double> bd; // force instantiation + layout
+
+static_assert(sizeof(Box<double>) == 16, "double payload(8)+int(4)+char, packed to 16");
+
+// CHECK:      struct Box<double>
+// CHECK-NEXT: double payload
+// CHECK-NEXT: int id
+// CHECK-NEXT: char tag
diff --git a/clang/test/CXXMG/compact/compact-template-optimal-packing.cpp b/clang/test/CXXMG/compact/compact-template-optimal-packing.cpp
new file mode 100644
index 000000000..f929b4444
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-template-optimal-packing.cpp
@@ -0,0 +1,40 @@
+// Hard combination: a compact CLASS TEMPLATE whose field carries a field-level
+// `alignas(16)` over a small type. Each instantiation is reordered at
+// Sema::ActOnFields, which runs the SAME packing search as the textual parser
+// path -- so the greedy/exhaustive optimizer applies to template instantiations
+// too. In Box<int>, `alignas(16) int b` (size 4, align 16) opens a hole that the
+// two chars fill before the double, packing the instantiation to 16 bytes
+// rather than the 32 a descending-alignment sort would give. Box<double> packs
+// to a different optimum, proving the search runs per-instantiation.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+template <class T> compact struct Box {
+  alignas(16) T b;
+  double d;
+  char e;
+  char f;
+};
+
+Box<int> bi;
+static_assert(sizeof(Box<int>) == 16, "greedy fills the alignas hole in the instantiation");
+
+// CHECK:      struct Box<int>
+// CHECK-NEXT: 0 |{{.*}}int b
+// CHECK-NEXT: 4 |{{.*}}char e
+// CHECK-NEXT: 5 |{{.*}}char f
+// CHECK-NEXT: 8 |{{.*}}double d
+// CHECK:      sizeof=16, align=16
+
+// Box<double>: b is alignas(16) double (size 8, align 16). The hole after it is
+// 8 bytes; the two chars cannot fill a full double slot, so d follows at 8 and
+// the chars tail it -> 24 rounded to 32.
+Box<double> bd;
+static_assert(sizeof(Box<double>) == 32, "different T -> different optimum, per instantiation");
+
+// CHECK:      struct Box<double>
+// CHECK-NEXT: 0 |{{.*}}double b
+// CHECK-NEXT: 8 |{{.*}}double d
+// CHECK-NEXT: 16 |{{.*}}char e
+// CHECK-NEXT: 17 |{{.*}}char f
+// CHECK:      sizeof=32, align=16
diff --git a/clang/test/CXXMG/compact/compact-trailing-array-stays-last.cpp b/clang/test/CXXMG/compact/compact-trailing-array-stays-last.cpp
new file mode 100644
index 000000000..1cb0afa22
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-trailing-array-stays-last.cpp
@@ -0,0 +1,22 @@
+// A trailing array of size <= 1 (a flexible-array-like member) must stay last;
+// only the other fields are reordered around it. The record layout is dumped to
+// confirm the field *order*, not just the size (`static_assert` below forces
+// the layout to be computed so -fdump-record-layouts emits it).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s
+
+compact struct WithTail {
+  char a;
+  double d;
+  char tail[1];
+};
+
+// Reorder {a, d} by descending alignment => {d, a}; `tail` stays last.
+static_assert(sizeof(WithTail) == 16, "d(8)+a(1)+tail(1) padded to 16");
+
+// CHECK:      *** Dumping AST Record Layout
+// CHECK:      0 | struct WithTail
+// CHECK-NEXT: 0 |   double d
+// CHECK-NEXT: 8 |   char a
+// CHECK-NEXT: 9 |   char[1] tail
diff --git a/clang/test/CXXMG/compact/compact-trailing-array-with-packer.cpp b/clang/test/CXXMG/compact/compact-trailing-array-with-packer.cpp
new file mode 100644
index 000000000..31e651db0
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-trailing-array-with-packer.cpp
@@ -0,0 +1,24 @@
+// The packing search excludes a trailing flexible-array-like member (it must
+// stay last) but still accounts for it when comparing candidate orderings of
+// the head fields (the size simulation appends the trailing array). Here the
+// head {a, b, c} is reordered around `tail`, packing V to 32 bytes versus 48 in
+// declaration order, where `alignas(16) int b` after `char a` wastes 15 bytes.
+// `tail` remains the final member.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct V {
+  char a;
+  alignas(16) int b;
+  double c;
+  int tail[1];
+};
+V v;
+static_assert(sizeof(V) == 32, "head packs optimally (decl order is 48), tail stays last");
+
+// CHECK:      struct V
+// CHECK-NEXT: 0 |{{.*}}int b
+// CHECK-NEXT: 8 |{{.*}}double c
+// CHECK-NEXT: 16 |{{.*}}char a
+// CHECK-NEXT: 20 |{{.*}}int[1] tail
+// CHECK:      sizeof=32, align=16
diff --git a/clang/test/CXXMG/compact/compact-transitive-atomic-isolation.cpp b/clang/test/CXXMG/compact/compact-transitive-atomic-isolation.cpp
new file mode 100644
index 000000000..15c1120f9
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-transitive-atomic-isolation.cpp
@@ -0,0 +1,33 @@
+// False-sharing safety, transitive case: a field whose TYPE embeds an atomic by
+// value (here a plain struct with an _Atomic member, or an array of atomics) is
+// itself concurrently written, so it is isolated onto its own cache line just
+// like a direct atomic field. Detection recurses through value members, bases,
+// and array elements -- but not through pointers (a pointer to an atomic does
+// not make the pointing field concurrently written).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+struct HasAtomic { _Atomic int counter; };
+
+// h embeds an atomic -> isolated to its own cache line; b is pushed to the next.
+compact struct Outer {
+  char a;
+  HasAtomic h;
+  int b;
+};
+Outer o;
+static_assert(sizeof(Outer) == 128, "nested-atomic field isolated like a direct atomic");
+
+// CHECK:      struct Outer
+// CHECK:      0 |{{.*}}struct HasAtomic h
+// CHECK:      64 |{{.*}}int b
+
+// A POINTER to an atomic-containing struct is NOT isolated (not concurrently
+// written through this field): P stays compact with no cache-line blowup.
+compact struct P {
+  char a;
+  HasAtomic *ptr;
+  int b;
+};
+P p;
+static_assert(sizeof(P) == 16, "pointer to atomic-containing type is not isolated");
diff --git a/clang/test/CXXMG/compact/compact-transitive-atomic-variants.cpp b/clang/test/CXXMG/compact/compact-transitive-atomic-variants.cpp
new file mode 100644
index 000000000..b376f0f2f
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-transitive-atomic-variants.cpp
@@ -0,0 +1,47 @@
+// Transitive atomic detection covers every embedding path: a std::atomic nested
+// in a member struct, a raw array of _Atomic, and multi-level nesting
+// (struct -> struct -> _Atomic) all isolate the containing field. A member
+// struct with NO atomic is left compact (no over-isolation).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+namespace std {
+template <class T> struct atomic { T v; };
+} // namespace std
+
+// std::atomic nested one level inside a member struct.
+struct WrapsStdAtomic { std::atomic<int> a; };
+compact struct A {
+  char x;
+  WrapsStdAtomic w;
+  int y;
+};
+static_assert(sizeof(A) == 128, "nested std::atomic member is isolated");
+
+// A raw array of _Atomic as a field is concurrently written -> isolated.
+compact struct B {
+  char x;
+  _Atomic int arr[2];
+  int y;
+};
+static_assert(sizeof(B) == 128, "array of atomics is isolated");
+
+// Two levels of value nesting: Top -> Mid -> Inner -> _Atomic.
+struct Inner { _Atomic int c; };
+struct Mid { Inner i; int pad; };
+compact struct Top {
+  char x;
+  Mid m;
+  int y;
+};
+static_assert(sizeof(Top) == 128, "multi-level nested atomic is isolated");
+
+// Negative: a member struct with no atomic anywhere must NOT be over-isolated.
+struct Plain { int a; double b; };
+compact struct N {
+  char x;
+  Plain p;
+  int y;
+};
+static_assert(sizeof(N) == 24, "non-atomic member is packed normally, not isolated");
diff --git a/clang/test/CXXMG/compact/compact-two-atomics-no-false-sharing.cpp b/clang/test/CXXMG/compact/compact-two-atomics-no-false-sharing.cpp
new file mode 100644
index 000000000..b7811deb0
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-two-atomics-no-false-sharing.cpp
@@ -0,0 +1,24 @@
+// The canonical false-sharing scenario: two atomic counters that, packed
+// adjacently, would share one 64-byte cache line and ping-pong between cores on
+// every write. Compact's atomic isolation forces each onto its OWN line --
+// a at offset 0, b at offset 64 -- so independent writes never contend. sizeof
+// grows to 192 (a + b + the trailing char each on a separate line): the
+// deliberate cost of correctness over density.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct Counters {
+  _Atomic long a;
+  _Atomic long b;
+  char pad;
+};
+Counters cc;
+
+static_assert(sizeof(Counters) == 192, "a, b and pad each on a separate line");
+static_assert(alignof(Counters) == 64, "record alignment raised to the line");
+
+// The two atomics are 64 bytes apart -> different cache lines -> no false sharing.
+// CHECK:      struct Counters
+// CHECK:      0 |{{.*}} a
+// CHECK:      64 |{{.*}} b
+// CHECK:      128 |{{.*}} pad
diff --git a/clang/test/CXXMG/compact/compact-type-expression-field.cpp b/clang/test/CXXMG/compact/compact-type-expression-field.cpp
new file mode 100644
index 000000000..92a958aa2
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-type-expression-field.cpp
@@ -0,0 +1,26 @@
+// HARD interaction: a compact struct whose field type is a C++MG type-EXPRESSION
+// composed record (C = A + B, which concatenates A's then B's fields). The
+// composed type C keeps its own source-order (non-compact) layout, and the outer
+// compact D reorders its own fields treating C by C's alignment (8) and size
+// (24): the field order becomes {inner(C), n, tag}.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+struct A { char a; double b; };
+struct B { char c; int d; };
+using C = A + B;
+
+compact struct D {
+  char tag;
+  C inner;
+  int n;
+};
+D d;
+
+static_assert(sizeof(C) == 24, "composed A+B keeps source order: char,double,char,int");
+static_assert(sizeof(D) == 32, "compact reorders to {inner(24), n(4), tag(1)} -> 32");
+
+// CHECK:      struct D
+// CHECK:      0 |{{.*}}struct C inner
+// CHECK:      24 |{{.*}}int n
+// CHECK:      28 |{{.*}}char tag
diff --git a/clang/test/CXXMG/compact/compact-type-expression-generated-record.cpp b/clang/test/CXXMG/compact/compact-type-expression-generated-record.cpp
new file mode 100644
index 000000000..cf4bbc60d
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-type-expression-generated-record.cpp
@@ -0,0 +1,39 @@
+// C++MG: the `compact` modifier on a type-expression `using` declaration
+// optimizes the *generated* record's field layout, exactly like `compact
+// struct`. A plain (non-compact) type expression keeps source order, proving
+// the modifier -- not composition itself -- is what drives the reorder. This
+// closes the gap where `compact` could only attach to a struct/class/union
+// specifier and never reached a `+`/`-` generated record.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+// expected-no-diagnostics
+
+struct A { char a; double d; };
+struct B { int i; char c; };
+
+// Plain composition: members stay in source order a, d, i, c.
+//   a@0 (char) | pad | d@8 (double) | i@16 (int) | c@20 (char) -> sizeof 24.
+using Plain = A + B;
+Plain plain;
+static_assert(sizeof(Plain) == 24,
+              "non-compact generated record keeps source order");
+
+// Compact composition: the same members are reordered to minimize padding.
+//   d@0 (double) | i@8 (int) | a@12 (char) | c@13 (char) -> sizeof 16.
+compact using Packed = A + B;
+Packed packed;
+static_assert(sizeof(Packed) == 16,
+              "compact generated record is padding-minimized");
+
+// The members carry over unchanged -- only their layout differs.
+static_assert(__is_same(decltype(Packed{}.d), double));
+static_assert(__is_same(decltype(Packed{}.i), int));
+static_assert(__is_same(decltype(Packed{}.a), char));
+static_assert(__is_same(decltype(Packed{}.c), char));
+
+// In source order 'd' would sit at offset 8 and 'i' at 16; seeing them at 0/8
+// proves the high-alignment fields were pulled to the front by `compact`.
+// CHECK:      struct Packed
+// CHECK:      0 |{{.*}}double d
+// CHECK:      8 |{{.*}}int i
diff --git a/clang/test/CXXMG/compact/compact-type-expression-template.cpp b/clang/test/CXXMG/compact/compact-type-expression-template.cpp
new file mode 100644
index 000000000..5b58c79ea
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-type-expression-template.cpp
@@ -0,0 +1,32 @@
+// C++MG: `template <...> compact using Name = A<T> + B;` opts a *templated*
+// type-expression alias into compact layout. The pattern is marked at parse
+// time and each instantiation's generated record is reordered at
+// Sema::ActOnFields -- per instantiation, like a `compact` class template.
+// A non-compact twin keeps source order, proving the modifier drives it.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+// expected-no-diagnostics
+
+template <class T> struct Tag { T t; };
+struct Payload { char a; double b; char c; };
+
+// Members of (Tag<T> + Payload): t(T), a(char), b(double), c(char).
+template <class T> using PlainBoxed = Tag<T> + Payload;
+template <class T> compact using Boxed = Tag<T> + Payload;
+
+// Boxed<int>: source order t(4) a(1) b(8) c(1) -> 24; compact b,t,a,c -> 16.
+PlainBoxed<int> plainI;
+Boxed<int> packedI;
+static_assert(sizeof(PlainBoxed<int>) == 24, "non-compact template type-expr keeps source order");
+static_assert(sizeof(Boxed<int>) == 16, "compact template type-expr reordered per instantiation");
+
+// A second instantiation re-optimizes for its own T.
+PlainBoxed<double> plainD;
+Boxed<double> packedD;
+static_assert(sizeof(PlainBoxed<double>) == 32);
+static_assert(sizeof(Boxed<double>) == 24, "compact re-optimizes for Boxed<double>");
+
+// The compacted instantiation puts the double first.
+// CHECK:      struct Boxed<int>
+// CHECK:      0 |{{.*}}double b
diff --git a/clang/test/CXXMG/compact/compact-union-noop.cpp b/clang/test/CXXMG/compact/compact-union-noop.cpp
new file mode 100644
index 000000000..87c1b79f9
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-union-noop.cpp
@@ -0,0 +1,12 @@
+// `compact` on a union is accepted but is a no-op -- union members overlay at
+// offset 0 -- so the compiler warns that the modifier has no effect.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact union Word { // expected-warning {{'compact' has no effect on a union}}
+  char a;
+  int b;
+  double d;
+};
+
+static_assert(sizeof(Word) == 8, "union size is the largest member, unchanged");
diff --git a/clang/test/CXXMG/compact/compact-using-requires-type-expression.cpp b/clang/test/CXXMG/compact/compact-using-requires-type-expression.cpp
new file mode 100644
index 000000000..907e7e546
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-using-requires-type-expression.cpp
@@ -0,0 +1,20 @@
+// C++MG: `compact` on a using-declaration is only meaningful when the
+// right-hand side is a record-generating type expression (uses `+`/`-`).
+// Applying it to a plain alias has nothing to compact, so it is diagnosed
+// rather than silently ignored.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+struct A { int x; double y; };
+struct B { char c; int z; };
+
+// A plain alias to a builtin: nothing to compact.
+compact using BadInt = int; // expected-error {{'compact' on a using-declaration requires a type expression that generates a record}}
+
+// A plain alias to a single record (no `+`/`-`): not a generated record.
+compact using BadAlias = A; // expected-error {{'compact' on a using-declaration requires a type expression that generates a record}}
+
+// Positive control: a genuine type expression is accepted and compacted.
+compact using Good = A + B;
+Good good;
+static_assert(sizeof(Good) == 24); // {y(8), z(4), x(4), c(1)} packed
