diff --git a/clang/test/CXXMG/compact/compact-conditional-members-template.cpp b/clang/test/CXXMG/compact/compact-conditional-members-template.cpp
new file mode 100644
index 000000000..7026538ce
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-conditional-members-template.cpp
@@ -0,0 +1,35 @@
+// HARD triple interaction: `compact` + a C++MG conditional `if constexpr` member
+// + class-template instantiation. The conditional resolves which fields exist
+// per instantiation, and ONLY THEN does compact reorder by alignment -- so
+// S<true> (which has the double) packs to {big, c, a} = 16, while S<false>
+// (which has the extra char) packs to {c, a, small} = 8. Exercises that the
+// reorderable field set is computed after conditional-member resolution and that
+// the per-instantiation reorder (Sema::ActOnFields) sees the resolved fields.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+template <bool B>
+compact struct S {
+  char a;
+  if constexpr (B) {
+    double big;
+  } else {
+    char small;
+  }
+  int c;
+};
+
+S<true> st;
+S<false> sf;
+
+static_assert(sizeof(S<true>) == 16, "{big(8), c(4), a(1)} padded to 16");
+static_assert(sizeof(S<false>) == 8, "{c(4), a(1), small(1)} padded to 8");
+
+// CHECK:      struct S<true>
+// CHECK-NEXT: double big
+// CHECK-NEXT: int c
+// CHECK-NEXT: char a
+// CHECK:      struct S<false>
+// CHECK-NEXT: int c
+// CHECK-NEXT: char a
+// CHECK-NEXT: char small
diff --git a/clang/test/CXXMG/compact/compact-constexpr-evaluation.cpp b/clang/test/CXXMG/compact/compact-constexpr-evaluation.cpp
new file mode 100644
index 000000000..52cfacc86
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-constexpr-evaluation.cpp
@@ -0,0 +1,23 @@
+// HARD: a compact struct used in constant evaluation. It reorders, yet
+// constexpr construction and by-name member reads still produce the right
+// values -- the constant evaluator follows the reordered decl order
+// consistently, and `.x`/`.n`/`.tag` resolve to the correct members regardless
+// of physical order.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct Pt { char tag; double x; int n; }; // -> {x, n, tag}, 16 bytes
+static_assert(sizeof(Pt) == 16, "");
+
+constexpr Pt make() {
+  Pt p{};
+  p.x = 1.0;
+  p.n = 7;
+  p.tag = 'z';
+  return p;
+}
+
+static_assert(make().x == 1.0, "");
+static_assert(make().n == 7, "");
+static_assert(make().tag == 'z', "");
diff --git a/clang/test/CXXMG/compact/compact-constexpr-lambda-over-greedy-packed.cpp b/clang/test/CXXMG/compact/compact-constexpr-lambda-over-greedy-packed.cpp
new file mode 100644
index 000000000..406bd83df
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-constexpr-lambda-over-greedy-packed.cpp
@@ -0,0 +1,51 @@
+// Correctness (not just size) through a NON-TRIVIALLY reordered layout: P is
+// packed by the greedy/exhaustive optimizer to 16 bytes with field order
+// {hdr, s, a, b, payload} -- different from declaration order. Reordering only
+// changes offsets, never field identity, so constexpr field reads and a lambda
+// that captures the struct by value and reads its members must still evaluate
+// to exactly the assigned values. This exercises the constant evaluator and
+// lambda capture over the optimized layout.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct P {
+  alignas(16) int hdr;
+  double payload;
+  short s;
+  char a;
+  char b;
+};
+
+constexpr P make() {
+  P p{};
+  p.hdr = 10;
+  p.payload = 2.5;
+  p.s = 7;
+  p.a = 'x';
+  p.b = 'y';
+  return p;
+}
+constexpr P gp = make();
+
+static_assert(sizeof(P) == 16, "greedy hole-filling packs P to 16 (decl/descending give 32)");
+static_assert(gp.hdr == 10 && gp.payload == 2.5 && gp.s == 7 && gp.a == 'x' && gp.b == 'y',
+              "every field reads back correctly through the reordered layout");
+
+// A lambda capturing the reordered struct BY VALUE, read in a constexpr context.
+constexpr int viaLambda(P q) {
+  auto f = [q]() constexpr {
+    return q.hdr * 100 + q.s + (q.a - 'x') + (q.b - 'y');
+  };
+  return f();
+}
+static_assert(viaLambda(gp) == 1007, "lambda over reordered members evaluates correctly");
+
+// A lambda capturing BY REFERENCE and mutating through the reordered layout.
+constexpr int mutateViaLambda() {
+  P q = make();
+  auto bump = [&q]() constexpr { q.hdr += 5; q.b = 'z'; };
+  bump();
+  return q.hdr + (q.b - 'y');
+}
+static_assert(mutateViaLambda() == 16, "by-ref lambda mutates the right fields (15 + 1)");
diff --git a/clang/test/CXXMG/compact/compact-deeply-nested-reordered-access.cpp b/clang/test/CXXMG/compact/compact-deeply-nested-reordered-access.cpp
new file mode 100644
index 000000000..978562970
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-deeply-nested-reordered-access.cpp
@@ -0,0 +1,20 @@
+// HARD: four levels of nested compact structs, each independently reordered.
+// Writing through and taking the address of the deepest leaf must compute the
+// offset correctly, composed through every reordered subobject at every level.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct L4 { char pad; int leaf; };
+compact struct L3 { char pad; L4 d; };
+compact struct L2 { char pad; L3 c; };
+compact struct L1 { char pad; L2 b; };
+
+constexpr int deep() {
+  L1 a{};
+  a.b.c.d.leaf = 42;      // offset composes through 4 reordered levels
+  int *p = &a.b.c.d.leaf; // address through the chain
+  return *p;
+}
+
+static_assert(deep() == 42, "deep nested reordered access is offset-correct");
diff --git a/clang/test/CXXMG/compact/compact-do-no-harm-fallback.cpp b/clang/test/CXXMG/compact/compact-do-no-harm-fallback.cpp
new file mode 100644
index 000000000..fd537ef85
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-do-no-harm-fallback.cpp
@@ -0,0 +1,47 @@
+// Do-no-harm guarantee: a descending-alignment sort is NOT optimal when a
+// field's size is smaller than its alignment, so it can produce a layout LARGER
+// than declaration order. For PLAIN compact (no hot/cold), compact simulates
+// both orderings and keeps declaration order whenever its reordering would not
+// shrink the struct -- so `compact` never bloats a struct past what the user
+// wrote. (hot/cold deliberately trade size for locality and are exempt.)
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+// S: `alignas(16) int` (size 4, align 16) would sort to the front and leave a
+// 4-byte hole; the float that fills it in declaration order would be pushed to
+// the tail, growing the struct to 48. Declaration order packs to 32, so compact
+// KEEPS declaration order (f0,f1,f2,f3) rather than bloating.
+compact struct S {
+  alignas(16) int f0;
+  float f1;
+  double f2[2];
+  long double f3;
+};
+S s;
+static_assert(sizeof(S) == 32, "compact must not exceed declaration order (would be 48 reordered)");
+
+// CHECK:      struct S
+// CHECK-NEXT: 0 |{{.*}}int f0
+// CHECK-NEXT: 4 |{{.*}}float f1
+// CHECK-NEXT: 8 |{{.*}}double[2] f2
+// CHECK-NEXT: 24 |{{.*}}long double f3
+// CHECK:      sizeof=32, align=16
+
+// Control G: here reordering genuinely helps (declaration order is 24, sorted is
+// 16), so compact DOES reorder. The fallback is targeted: it only suppresses
+// reordering that would do harm, never beneficial reordering.
+compact struct G {
+  char a;
+  double b;
+  char c;
+  int d;
+};
+G g;
+static_assert(sizeof(G) == 16, "beneficial reorder is still applied");
+
+// CHECK:      struct G
+// CHECK-NEXT: 0 |{{.*}}double b
+// CHECK-NEXT: 8 |{{.*}}int d
+// CHECK-NEXT: 12 |{{.*}}char a
+// CHECK-NEXT: 13 |{{.*}}char c
+// CHECK:      sizeof=16, align=8
