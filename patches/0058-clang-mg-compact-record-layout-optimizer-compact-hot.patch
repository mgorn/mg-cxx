+//===- CXXMGLayout.cpp - C++MG compact record layout ---------------------===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+//
+// This file implements the C++MG `compact` record-layout optimization. The
+// approach mirrors Clang's structure-layout randomization (Randstruct.cpp):
+// the record's `Decl` chain is rewritten via RecordDecl::reorderDecls before
+// the layout builder runs, so no change to the layout builders is required --
+// they simply lay out the already-permuted declaration order. Where randstruct
+// shuffles for security, `compact` sorts by descending alignment to minimize
+// padding.
+//
+//===----------------------------------------------------------------------===//
+
+#include "clang/AST/CXXMGLayout.h"
+#include "clang/AST/ASTContext.h"
+#include "clang/Basic/DiagnosticAST.h"
+#include "clang/AST/Decl.h"
+#include "clang/AST/Attr.h"        // AlignedAttr
+#include "clang/AST/DeclCXX.h"     // CXXRecordDecl, StaticAssertDecl
+#include "clang/AST/DeclTemplate.h" // ClassTemplateSpecializationDecl
+#include "clang/AST/Expr.h"        // IntegerLiteral
+#include "clang/AST/Type.h"
+#include "llvm/ADT/DenseMap.h"
+#include "llvm/ADT/DenseSet.h"
+#include "llvm/ADT/STLExtras.h"
+#include "llvm/ADT/StringMap.h"
+#include "llvm/ADT/StringRef.h"
+#include "llvm/Support/IOSandbox.h"
+#include "llvm/Support/MathExtras.h"
+#include "llvm/Support/MemoryBuffer.h"
+#include "llvm/ADT/SmallVector.h"
+#include <algorithm>
+
+using namespace clang;
+using clang::cxxmg::CXXMGHotness;
+
+namespace {
+
+/// Compute a padding-minimizing, hotness-aware ordering of \p RD's decls into
+/// \p FinalOrdering. Returns false (and leaves the record alone) for any case
+/// this increment does not handle safely.
+bool computeCompactOrdering(
+    const ASTContext &Context, RecordDecl *RD,
+    llvm::function_ref<CXXMGHotness(const FieldDecl *)> GetHotness,
+    llvm::SmallVectorImpl<Decl *> &FinalOrdering) {
+  // Unions overlay all members at offset 0: reordering is a no-op.
+  if (RD->isUnion())
+    return false;
+
+  // Only reorder concrete records; template patterns are reordered per
+  // instantiation (when they are no longer dependent).
+  if (RD->isDependentType())
+    return false;
+
+  // Restrict to simple records: no bases and no vptr. Members of such a record
+  // are laid out starting at offset 0, so a pure field permutation is sound.
+  if (const auto *CXXRD = dyn_cast<CXXRecordDecl>(RD)) {
+    if (CXXRD->getNumBases() != 0 || CXXRD->isPolymorphic())
+      return false;
+  }
+
+  llvm::SmallVector<FieldDecl *, 64> Fields;
+  llvm::SmallVector<Decl *, 8> PostFields;
+  unsigned TotalNumDecls = 0;
+  bool HasIndirectField = false;
+  for (Decl *D : RD->decls()) {
+    ++TotalNumDecls;
+    if (auto *FD = dyn_cast<FieldDecl>(D)) {
+      Fields.push_back(FD);
+    } else if (isa<StaticAssertDecl>(D)) {
+      PostFields.push_back(D);
+    } else if (isa<IndirectFieldDecl>(D)) {
+      // Anonymous struct/union members project IndirectFieldDecls; moving
+      // fields out from under them is unsafe. Bail out entirely.
+      HasIndirectField = true;
+      break;
+    } else {
+      FinalOrdering.push_back(D);
+    }
+  }
+
+  if (HasIndirectField || Fields.size() < 2)
+    return false;
+
+  // Bail on anything whose size/alignment we cannot (or should not) query, or
+  // that has special packing rules deferred to a later increment.
+  for (FieldDecl *FD : Fields) {
+    if (FD->isBitField())
+      return false;
+    QualType T = FD->getType();
+    if (T->isDependentType() || T->isIncompleteType())
+      return false;
+  }
+
+  // A trailing flexible array, or an array of size <= 1 used as one, must stay
+  // last. Exclude it from the reorderable set.
+  FieldDecl *TrailingArray = nullptr;
+  if (RD->hasFlexibleArrayMember()) {
+    TrailingArray = Fields.pop_back_val();
+  } else if (const auto *CA =
+                 dyn_cast<ConstantArrayType>(Fields.back()->getType())) {
+    if (CA->getSize().ule(1))
+      TrailingArray = Fields.pop_back_val();
+  }
+
+  if (Fields.size() < 2) {
+    // Nothing meaningful left to reorder.
+    return false;
+  }
+
+  // A field's EFFECTIVE alignment is the larger of its type's natural alignment
+  // and any explicit `alignas`/__attribute__((aligned)) on the field itself
+  // (FieldDecl::getMaxAlignment(), in bits). Sorting by type alignment alone is
+  // a do-no-harm bug: e.g. `alignas(64) char a` would sort as align-1 and land
+  // last, forcing tens of bytes of padding and making the compact struct LARGER
+  // than source order. Using the effective alignment keeps the heuristic sound.
+  auto EffectiveAlign = [&Context](const FieldDecl *FD) -> uint64_t {
+    uint64_t TypeAlign = Context.getTypeAlignInChars(FD->getType()).getQuantity();
+    unsigned AttrAlignBits = FD->getMaxAlignment(); // 0 when no align attribute
+    uint64_t AttrAlign = AttrAlignBits / Context.getCharWidth();
+    return TypeAlign > AttrAlign ? TypeAlign : AttrAlign;
+  };
+
+  // Within a hotness group, sort by descending alignment, tie-broken by
+  // descending size. The largest-aligned fields go first, funneling inter-field
+  // slack into a single pad. stable_sort keeps declaration order for equal
+  // keys, so the result is deterministic and source-order-stable.
+  auto ByDescendingAlignment = [&Context, &EffectiveAlign](const FieldDecl *A,
+                                                           const FieldDecl *B) {
+    uint64_t AAlign = EffectiveAlign(A);
+    uint64_t BAlign = EffectiveAlign(B);
+    if (AAlign != BAlign)
+      return AAlign > BAlign;
+    uint64_t ASize = Context.getTypeSizeInChars(A->getType()).getQuantity();
+    uint64_t BSize = Context.getTypeSizeInChars(B->getType()).getQuantity();
+    return ASize > BSize;
+  };
+
+  // Partition by hotness: `hot` fields first (toward the first cache line(s)),
+  // then unmarked fields, then `cold` fields (toward the tail). Padding is
+  // minimized within each group; hotness takes priority over padding across
+  // groups, which is the point of the markers.
+  llvm::SmallVector<FieldDecl *, 16> Hot, Middle, Cold;
+  for (FieldDecl *FD : Fields) {
+    switch (GetHotness(FD)) {
+    case CXXMGHotness::Hot:
+      Hot.push_back(FD);
+      break;
+    case CXXMGHotness::Cold:
+      Cold.push_back(FD);
+      break;
+    case CXXMGHotness::None:
+      Middle.push_back(FD);
+      break;
+    }
+  }
+  std::stable_sort(Hot.begin(), Hot.end(), ByDescendingAlignment);
+  std::stable_sort(Middle.begin(), Middle.end(), ByDescendingAlignment);
+  std::stable_sort(Cold.begin(), Cold.end(), ByDescendingAlignment);
+
+  // Simulate the size a given field ordering would produce, mirroring the
+  // record layout for the simple, non-bitfield case compact restricts itself to
+  // (it bails on bitfields, bases, polymorphism and indirect fields). Each
+  // field is placed at the next offset aligned to its EFFECTIVE alignment; the
+  // result is rounded up to the largest field alignment.
+  auto SimulateSize =
+      [&Context, &EffectiveAlign](llvm::ArrayRef<FieldDecl *> Order) -> uint64_t {
+    uint64_t Offset = 0, MaxAlign = 1;
+    for (const FieldDecl *FD : Order) {
+      uint64_t A = EffectiveAlign(FD);
+      if (A == 0)
+        A = 1;
+      uint64_t Sz = Context.getTypeSizeInChars(FD->getType()).getQuantity();
+      Offset = llvm::alignTo(Offset, A);
+      Offset += Sz;
+      if (A > MaxAlign)
+        MaxAlign = A;
+    }
+    return llvm::alignTo(Offset, MaxAlign);
+  };
+
+  // Greedy hole-filling order: repeatedly pick the remaining field that needs
+  // the LEAST padding at the current running offset (tie-broken by larger
+  // alignment, then larger size). This recovers the cases where a pure
+  // descending-alignment sort is suboptimal because a field's size is smaller
+  // than its alignment (e.g. `alignas(16) int`): the small fields that would
+  // fill the resulting holes are chosen exactly when they fit, instead of being
+  // pushed to the tail. O(n^2), negligible for real structs.
+  auto GreedyOrder = [&Context, &EffectiveAlign](
+                         llvm::ArrayRef<FieldDecl *> In) {
+    llvm::SmallVector<FieldDecl *, 64> Rem(In.begin(), In.end());
+    llvm::SmallVector<FieldDecl *, 64> Out;
+    uint64_t Off = 0;
+    while (!Rem.empty()) {
+      unsigned BestI = 0;
+      uint64_t BestPad = ~0ULL, BestAlign = 0, BestSize = 0;
+      for (unsigned I = 0; I < Rem.size(); ++I) {
+        uint64_t A = EffectiveAlign(Rem[I]);
+        if (A == 0)
+          A = 1;
+        uint64_t Sz = Context.getTypeSizeInChars(Rem[I]->getType()).getQuantity();
+        uint64_t Pad = (A - (Off % A)) % A;
+        if (Pad < BestPad ||
+            (Pad == BestPad &&
+             (A > BestAlign || (A == BestAlign && Sz > BestSize)))) {
+          BestPad = Pad;
+          BestAlign = A;
+          BestSize = Sz;
+          BestI = I;
+        }
+      }
+      Off = llvm::alignTo(Off, BestAlign) + BestSize;
+      Out.push_back(Rem[BestI]);
+      Rem.erase(Rem.begin() + BestI);
+    }
+    return Out;
+  };
+
+  // For PLAIN compact (no hot/cold markers), pick the candidate ordering that
+  // packs smallest among {descending-alignment, declaration order, greedy
+  // hole-filling}, PREFERRING descending alignment on ties so the common case
+  // (and existing layouts) stay predictable. Because declaration order is
+  // always a candidate, the result is never larger than what the user wrote --
+  // do-no-harm is a hard guarantee. `hot`/`cold` deliberately trade size for
+  // cache locality, so this packing search only runs when the user wrote
+  // neither marker; within hot/cold groups the descending-alignment sort stands.
+  if (Hot.empty() && Cold.empty()) {
+    auto SimWithTail = [&](llvm::ArrayRef<FieldDecl *> Cand) -> uint64_t {
+      llvm::SmallVector<FieldDecl *, 64> Tmp(Cand.begin(), Cand.end());
+      if (TrailingArray)
+        Tmp.push_back(TrailingArray);
+      return SimulateSize(Tmp);
+    };
+
+    // Start from the descending-alignment order (the predictable default) and
+    // only switch to another candidate when it is STRICTLY smaller, so ties
+    // keep the default and existing layouts stay byte-stable.
+    llvm::SmallVector<FieldDecl *, 64> BestOrder(Middle.begin(), Middle.end());
+    uint64_t BestSize = SimWithTail(BestOrder);
+    auto Consider = [&](llvm::ArrayRef<FieldDecl *> Cand) {
+      if (uint64_t Sz = SimWithTail(Cand); Sz < BestSize) {
+        BestOrder.assign(Cand.begin(), Cand.end());
+        BestSize = Sz;
+      }
+    };
+    Consider(GreedyOrder(Fields)); // greedy hole-filling
+    Consider(Fields);              // declaration order (do-no-harm baseline)
+
+    // Descending-alignment is PROVABLY optimal when every field's size is a
+    // multiple of its effective alignment: alignments are powers of two and
+    // sorted descending, so each field lands already-aligned with zero padding
+    // (minimal size = sum of sizes rounded to the max alignment). That holds for
+    // every standard type, so the exhaustive search below is only needed for the
+    // pathological case where a field's size is NOT a multiple of its alignment
+    // -- e.g. `alignas(16) int` (size 4, align 16) -- which leaves holes a
+    // different order could fill. Gating on that keeps compile time linear in
+    // the common case instead of O(n!) per struct (a file of many 8-field
+    // compact structs was spending seconds in next_permutation).
+    bool NeedsExhaustive = false;
+    for (const FieldDecl *FD : Fields) {
+      uint64_t A = EffectiveAlign(FD);
+      uint64_t Sz = Context.getTypeSizeInChars(FD->getType()).getQuantity();
+      if (A != 0 && Sz % A != 0) {
+        NeedsExhaustive = true;
+        break;
+      }
+    }
+
+    // For small structs the globally minimal layout is cheap to find exactly
+    // (<= 8! = 40320 permutations), so compact is provably optimal up to eight
+    // reorderable fields. This only refines the result when strictly smaller
+    // than the heuristics, so the common case stays on the predictable order.
+    if (NeedsExhaustive && Fields.size() <= 8) {
+      llvm::SmallVector<unsigned, 8> Idx;
+      for (unsigned I = 0, E = Fields.size(); I < E; ++I)
+        Idx.push_back(I);
+      llvm::SmallVector<FieldDecl *, 8> Perm(Fields.size());
+      do {
+        for (unsigned I = 0, E = Idx.size(); I < E; ++I)
+          Perm[I] = Fields[Idx[I]];
+        Consider(Perm);
+      } while (std::next_permutation(Idx.begin(), Idx.end()));
+    }
+
+    Middle.assign(BestOrder.begin(), BestOrder.end());
+  }
+
+  llvm::append_range(FinalOrdering, Hot);
+  llvm::append_range(FinalOrdering, Middle);
+  llvm::append_range(FinalOrdering, Cold);
+  llvm::append_range(FinalOrdering, PostFields);
+  if (TrailingArray)
+    FinalOrdering.push_back(TrailingArray);
+
+  assert(TotalNumDecls == FinalOrdering.size() &&
+         "Decl count changed during C++MG compact layout!");
+  (void)TotalNumDecls;
+  return true;
+}
+
+/// Whether \p T is, or transitively contains BY VALUE, an atomic that should be
+/// isolated onto its own cache line to avoid false sharing: C11 `_Atomic`, a
+/// std::atomic specialization, or std::atomic_flag. Recurses through value
+/// members, base classes, and array elements -- a field whose type embeds an
+/// atomic is itself concurrently written -- but NOT through pointers or
+/// references, since a pointer to an atomic does not make the pointing field
+/// concurrently written. Value-member recursion terminates because a complete
+/// record cannot contain itself by value.
+///
+/// std::atomic_ref is deliberately NOT included: it performs atomic operations
+/// on storage it *refers to*, which lives elsewhere. Isolating the atomic_ref
+/// field's own bytes does not isolate the referenced object, so the alignment
+/// would buy nothing while still inflating the record. The referenced storage
+/// must be isolated where it is actually defined.
+bool typeContainsAtomic(QualType T) {
+  T = T.getCanonicalType();
+  if (T->isAtomicType())
+    return true; // _Atomic(T)
+  if (const ArrayType *AT = T->getAsArrayTypeUnsafe())
+    return typeContainsAtomic(AT->getElementType());
+  const CXXRecordDecl *RD = T->getAsCXXRecordDecl();
+  if (!RD || !RD->isCompleteDefinition())
+    return false;
+  if (const auto *CTSD = dyn_cast<ClassTemplateSpecializationDecl>(RD)) {
+    llvm::StringRef N = CTSD->getSpecializedTemplate()->getName();
+    if (N == "atomic" && CTSD->isInStdNamespace())
+      return true; // do not recurse into the atomic's own storage
+    // NOTE: std::atomic_ref is intentionally excluded -- it isolates external
+    // storage, not its own bytes (see the function comment above).
+  }
+  if (RD->isInStdNamespace() && RD->getIdentifier() &&
+      RD->getName() == "atomic_flag")
+    return true;
+  for (const FieldDecl *F : RD->fields())
+    if (typeContainsAtomic(F->getType()))
+      return true;
+  for (const CXXBaseSpecifier &B : RD->bases())
+    if (typeContainsAtomic(B.getType()))
+      return true;
+  return false;
+}
+
+/// Whether \p FD is an atomic (concurrently-written) field that should be
+/// isolated onto its own cache line to avoid false sharing.
+bool isAtomicField(const FieldDecl *FD) {
+  return typeContainsAtomic(FD->getType());
+}
+
+} // namespace
+
+bool clang::cxxmg::applyCompactLayout(
+    const ASTContext &Context, RecordDecl *RD,
+    llvm::function_ref<CXXMGHotness(const FieldDecl *)> GetHotness) {
+  if (!RD || RD->isInvalidDecl() || !RD->isCompleteDefinition())
+    return false;
+
+  llvm::SmallVector<Decl *, 32> NewOrdering;
+  if (!computeCompactOrdering(Context, RD, GetHotness, NewOrdering))
+    return false;
+
+  RD->reorderDecls(NewOrdering);
+
+  // C++MG: isolate atomic (concurrently-written) fields onto their own cache
+  // line to avoid false sharing. Synthesize a cache-line AlignedAttr on each
+  // atomic field AND on the field immediately after it, so neither shares the
+  // atomic's line. RecordLayoutBuilder honors a field's AlignedAttr via
+  // getMaxAlignment(); reorderDecls left the attributes intact. The cache-line
+  // size is configurable via -fcxxmg-cache-line=N (default 64, correct for
+  // x86-64; e.g. 128 for Apple silicon). A value of 0 disables isolation
+  // entirely (opt-out); a non-power-of-two N is rounded up so the synthesized
+  // alignment is always valid and never under-separates. Do-no-harm: never
+  // lower a field's existing alignment.
+  unsigned LineBytes = Context.getLangOpts().CXXMGCacheLine;
+  if (LineBytes != 0) {
+    if (!llvm::isPowerOf2_32(LineBytes))
+      LineBytes = llvm::PowerOf2Ceil(LineBytes);
+    const unsigned LineBits = LineBytes * Context.getCharWidth();
+    ASTContext &Ctx = const_cast<ASTContext &>(Context);
+    bool PrevAtomic = false;
+    for (FieldDecl *FD : RD->fields()) {
+      bool ThisAtomic = isAtomicField(FD);
+      if ((ThisAtomic || PrevAtomic) && FD->getMaxAlignment() < LineBits) {
+        llvm::APInt Align(32, LineBytes);
+        FD->addAttr(AlignedAttr::CreateImplicit(
+            Ctx, /*IsAlignmentExpr=*/true,
+            IntegerLiteral::Create(
+                Ctx, Align, Ctx.getIntTypeForBitwidth(32, /*Signed=*/0),
+                SourceLocation()),
+            {}, AlignedAttr::GNU_aligned));
+      }
+      PrevAtomic = ThisAtomic;
+    }
+  }
+  return true;
+}
+
+// `compact` template patterns are dependent at parse time, so they cannot be
+// reordered then; instead they are recorded here and each concrete instantiation
+// is reordered at Sema::ActOnFields. The set is keyed by ASTContext* so state
+// from one translation unit/AST never collides with another.
+// Keyed on the CANONICAL decl so the pattern marked at parse time matches what
+// CXXRecordDecl::getTemplateInstantiationPattern() returns (possibly a different
+// redeclaration) at instantiation time.
+static llvm::DenseMap<const ASTContext *, llvm::DenseSet<const Decl *>> &
+getCompactPatternMap() {
+  static llvm::DenseMap<const ASTContext *, llvm::DenseSet<const Decl *>> M;
+  return M;
+}
+
+void clang::cxxmg::markCompactPattern(const ASTContext &Context,
+                                      const RecordDecl *RD) {
+  getCompactPatternMap()[&Context].insert(RD->getCanonicalDecl());
+}
+
+bool clang::cxxmg::isCompactPattern(const ASTContext &Context,
+                                    const RecordDecl *RD) {
+  auto It = getCompactPatternMap().find(&Context);
+  return It != getCompactPatternMap().end() &&
+         It->second.count(RD->getCanonicalDecl());
+}
+
+// Source-level hot/cold markers, keyed by ASTContext* then FieldDecl. Populated
+// at the parser hot/cold site; read at Sema::ActOnFields to apply a `compact`
+// template pattern's markers to each instantiation's (distinct) fields.
+static llvm::DenseMap<const ASTContext *,
+                      llvm::DenseMap<const FieldDecl *, CXXMGHotness>> &
+getFieldHotnessMap() {
+  static llvm::DenseMap<const ASTContext *,
+                        llvm::DenseMap<const FieldDecl *, CXXMGHotness>>
+      M;
+  return M;
+}
+
+void clang::cxxmg::markFieldHotness(const ASTContext &Context,
+                                    const FieldDecl *FD, CXXMGHotness Hotness) {
+  getFieldHotnessMap()[&Context][FD] = Hotness;
+}
+
+CXXMGHotness clang::cxxmg::getFieldHotness(const ASTContext &Context,
+                                           const FieldDecl *FD) {
+  auto It = getFieldHotnessMap().find(&Context);
+  if (It == getFieldHotnessMap().end())
+    return CXXMGHotness::None;
+  auto J = It->second.find(FD);
+  return J == It->second.end() ? CXXMGHotness::None : J->second;
+}
+
+// -fcxxmg-field-profile-use: a field-usage profile loaded once per ASTContext.
+// Maps a record name to (field source index -> hot/cold bucket). The profile is
+// a single global artifact, so a compile-time decision driven by it is a pure
+// function of the profile -- every TU given the same file derives the same
+// layout (the ABI-safety property a usage-driven layout must have).
+namespace {
+// A record's profile entries, keyable either by field name (preferred -- stable
+// and what -Rcxxmg-field-usage prints) or by source-declaration index.
+struct RecordProfile {
+  llvm::StringMap<CXXMGHotness> ByName;
+  llvm::DenseMap<unsigned, CXXMGHotness> ByIndex;
+};
+struct FieldProfile {
+  bool Loaded = false;
+  llvm::StringMap<RecordProfile> Records;
+};
+} // namespace
+
+static llvm::DenseMap<const ASTContext *, FieldProfile> &getFieldProfileMap() {
+  static llvm::DenseMap<const ASTContext *, FieldProfile> M;
+  return M;
+}
+
+// Parse the profile file named by LangOpts into \p P. Each non-empty,
+// non-comment ('#') line is "<record-name> <field-index> <H|C>". Malformed
+// lines are skipped silently -- the profile is advisory, never required.
+static void loadFieldProfile(const ASTContext &Context, FieldProfile &P) {
+  P.Loaded = true;
+  llvm::StringRef Path = Context.getLangOpts().CXXMGFieldProfileFile;
+  if (Path.empty())
+    return;
+  // The profile is an explicit, user-authorized compiler input (named by a
+  // flag), so read it with the IO sandbox bypassed -- the same sanctioned
+  // pattern FileManager uses for its own input reads.
+  llvm::ErrorOr<std::unique_ptr<llvm::MemoryBuffer>> BufOrErr = [&] {
+    auto BypassSandbox = llvm::sys::sandbox::scopedDisable();
+    return llvm::MemoryBuffer::getFile(Path);
+  }();
+  if (!BufOrErr) {
+    // A non-empty path that cannot be read is almost always a typo or a missing
+    // file; warn rather than silently leaving every layout unchanged.
+    Context.getDiagnostics().Report(diag::warn_cxxmg_field_profile_unreadable)
+        << Path;
+    return;
+  }
+  llvm::SmallVector<llvm::StringRef, 64> Lines;
+  (*BufOrErr)->getBuffer().split(Lines, '\n');
+  for (llvm::StringRef Line : Lines) {
+    Line = Line.trim();
+    if (Line.empty() || Line.starts_with("#"))
+      continue;
+    llvm::SmallVector<llvm::StringRef, 3> Tok;
+    Line.split(Tok, ' ', /*MaxSplit=*/-1, /*KeepEmpty=*/false);
+    if (Tok.size() != 3)
+      continue;
+    CXXMGHotness H;
+    if (Tok[2].equals_insensitive("H"))
+      H = CXXMGHotness::Hot;
+    else if (Tok[2].equals_insensitive("C"))
+      H = CXXMGHotness::Cold;
+    else
+      continue;
+    // The field key is either a source index (all digits) or a field name.
+    RecordProfile &RP = P.Records[Tok[0]];
+    unsigned Idx;
+    if (!Tok[1].getAsInteger(10, Idx)) // false == parsed as an integer
+      RP.ByIndex[Idx] = H;
+    else
+      RP.ByName[Tok[1]] = H;
+  }
+}
+
+CXXMGHotness clang::cxxmg::lookupFieldProfile(const ASTContext &Context,
+                                              const FieldDecl *FD) {
+  if (Context.getLangOpts().CXXMGFieldProfileFile.empty())
+    return CXXMGHotness::None;
+  FieldProfile &P = getFieldProfileMap()[&Context];
+  if (!P.Loaded)
+    loadFieldProfile(Context, P);
+  if (P.Records.empty())
+    return CXXMGHotness::None;
+  const RecordDecl *RD = FD->getParent();
+  if (!RD || !RD->getIdentifier())
+    return CXXMGHotness::None;
+  // Match the record by qualified name first (e.g. "net::Pkt"), then fall back
+  // to the simple name ("Pkt"). This lets a profile disambiguate same-named
+  // records in different namespaces, while plain simple-name profiles (and the
+  // simple name printed by -Rcxxmg-field-usage) keep working unchanged.
+  std::string Qualified = RD->getQualifiedNameAsString();
+  auto It = P.Records.find(Qualified);
+  if (It == P.Records.end())
+    It = P.Records.find(RD->getName());
+  if (It == P.Records.end())
+    return CXXMGHotness::None;
+  const RecordProfile &RP = It->second;
+  // Prefer a by-name entry (stable across reorders, and what
+  // -Rcxxmg-field-usage emits).
+  if (const IdentifierInfo *FieldId = FD->getIdentifier()) {
+    auto N = RP.ByName.find(FieldId->getName());
+    if (N != RP.ByName.end())
+      return N->second;
+  }
+  // Otherwise match by source-declaration index. Find it by iterating the field
+  // chain -- we must NOT use FieldDecl::getFieldIndex(), which caches an index
+  // on the FieldDecl; this runs before reorderDecls, so a cached source-order
+  // index would go stale after the reorder and corrupt the computed layout.
+  if (RP.ByIndex.empty())
+    return CXXMGHotness::None;
+  unsigned Idx = 0;
+  for (const FieldDecl *F : RD->fields()) {
+    if (F == FD)
+      break;
+    ++Idx;
+  }
+  auto J = RP.ByIndex.find(Idx);
+  return J == RP.ByIndex.end() ? CXXMGHotness::None : J->second;
+}
