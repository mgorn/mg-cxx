diff --git a/clang/test/CXXMG/compact/compact-bit-cast-warning.cpp b/clang/test/CXXMG/compact/compact-bit-cast-warning.cpp
new file mode 100644
index 000000000..3a296b652
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-bit-cast-warning.cpp
@@ -0,0 +1,22 @@
+// C++MG: __builtin_bit_cast (and std::bit_cast, which lowers to it) of a
+// `compact` record observes its reordered byte layout, exactly like a
+// reinterpret_cast or whole-object memcpy between unrelated types. Warn under
+// -Wcxxmg-compact, in both directions (from and to a compact type).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact struct S { char a; double b; int c; char d; }; // 16 bytes after compact
+struct Raw { double x; double y; };                     // 16 bytes
+struct A { double p; double q; };                       // 16 bytes, non-compact
+
+Raw from_compact(S s) {
+  return __builtin_bit_cast(Raw, s); // expected-warning {{'bit_cast' involving 'compact' type 'S' exposes its reordered byte layout; type 'Raw' interprets the bytes at different field offsets}}
+}
+S to_compact(Raw r) {
+  return __builtin_bit_cast(S, r); // expected-warning {{'bit_cast' involving 'compact' type 'S' exposes its reordered byte layout; type 'Raw' interprets the bytes at different field offsets}}
+}
+
+// Non-compact to non-compact: no warning.
+Raw plain(A a) {
+  return __builtin_bit_cast(Raw, a);
+}
diff --git a/clang/test/CXXMG/compact/compact-cache-line-flag.cpp b/clang/test/CXXMG/compact/compact-cache-line-flag.cpp
new file mode 100644
index 000000000..f65ce7877
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-cache-line-flag.cpp
@@ -0,0 +1,49 @@
+// -fcxxmg-cache-line=N controls the cache-line size used to isolate atomic
+// fields in a compact struct against false sharing. Default is 64 (x86-64);
+// 128 suits Apple silicon; 0 disables isolation entirely (opt-out). The same
+// source is laid out three ways depending on the flag.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s --check-prefix=DEF
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-cache-line=128 -fsyntax-only \
+// RUN:   -fdump-record-layouts %s | FileCheck %s --check-prefix=CL128
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-cache-line=0 -fsyntax-only \
+// RUN:   -fdump-record-layouts %s | FileCheck %s --check-prefix=CL0
+// A non-power-of-two N rounds UP to the next power of two (100 -> 128) WITH a
+// warning, so it never under-separates; the layout is identical to =128.
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-cache-line=100 -fsyntax-only \
+// RUN:   -fdump-record-layouts %s 2>%t.err | FileCheck %s --check-prefix=CL128
+// RUN: FileCheck %s --check-prefix=WARN100 --input-file=%t.err
+// WARN100: '-fcxxmg-cache-line' value 100 is not a power of two; rounding up to 128
+// The flag is forwarded by the driver (not just accepted at -cc1), so the same
+// layout change is observable through the clang-mg++ driver.
+// RUN: clang-mg++ -std=c++20 -fcxxmg-cache-line=128 -fsyntax-only \
+// RUN:   -Xclang -fdump-record-layouts %s | FileCheck %s --check-prefix=CL128
+
+compact struct C {
+  char tag;
+  _Atomic int counter;
+  int n;
+};
+C c;
+
+// Default 64-byte line: counter isolated at 0, n pushed to the next line at 64.
+// DEF:      struct C
+// DEF:      0 |{{.*}}counter
+// DEF:      64 |{{.*}}int n
+// DEF:      68 |{{.*}}char tag
+// DEF:      sizeof=128, align=64
+
+// 128-byte line: n pushed to offset 128, record grows to 256 / align 128.
+// CL128:      struct C
+// CL128:      0 |{{.*}}counter
+// CL128:      128 |{{.*}}int n
+// CL128:      132 |{{.*}}char tag
+// CL128:      sizeof=256, align=128
+
+// Isolation disabled: plain descending-alignment compaction, no padding blowup.
+// CL0:      struct C
+// CL0:      0 |{{.*}}counter
+// CL0:      4 |{{.*}}int n
+// CL0:      8 |{{.*}}char tag
+// CL0:      sizeof=12, align=4
diff --git a/clang/test/CXXMG/compact/compact-cache-line-validation.cpp b/clang/test/CXXMG/compact/compact-cache-line-validation.cpp
new file mode 100644
index 000000000..7373a3b49
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-cache-line-validation.cpp
@@ -0,0 +1,33 @@
+// -fcxxmg-cache-line=N is validated in ParseLangArgs. A value that exceeds the
+// 64 KiB maximum is REJECTED (atomic isolation disabled) rather than silently
+// overflowing the later bytes->bits conversion / power-of-two rounding during
+// layout. A valid power-of-two value (or 0) produces no cache-line diagnostic.
+//
+// Too-large value -> warning on stderr, isolation off, so the atomic is NOT
+// separated and the struct keeps its plain descending-alignment layout.
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-cache-line=99999999 -fsyntax-only \
+// RUN:   -fdump-record-layouts %s 2>%t.err | FileCheck %s --check-prefix=NOISO
+// RUN: FileCheck %s --check-prefix=TOOBIG --input-file=%t.err
+//
+// A valid power-of-two value emits no cache-line diagnostic at all.
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-cache-line=128 -fsyntax-only %s \
+// RUN:   2>&1 | FileCheck %s --check-prefix=QUIET --allow-empty
+
+// TOOBIG: cache-line size exceeds the maximum of 65536 bytes; disabling 'compact' atomic isolation
+
+compact struct C {
+  char tag;
+  _Atomic int counter;
+  int n;
+};
+C c;
+
+// Isolation disabled (the oversized value was rejected) -> plain compaction.
+// NOISO:      struct C
+// NOISO:      0 |{{.*}}counter
+// NOISO:      4 |{{.*}}int n
+// NOISO:      8 |{{.*}}char tag
+// NOISO:      sizeof=12, align=4
+
+// QUIET-NOT: cxxmg-cache-line
+// QUIET-NOT: power of two
diff --git a/clang/test/CXXMG/compact/compact-cast-warning.cpp b/clang/test/CXXMG/compact/compact-cast-warning.cpp
new file mode 100644
index 000000000..61b2aaa79
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-cast-warning.cpp
@@ -0,0 +1,75 @@
+// Safety: reinterpreting a pointer to a `compact` record as a pointer to an
+// UNRELATED record exposes the reordered layout -- the destination type reads
+// fields at source-declaration offsets that no longer hold. Warn at the cast
+// site (-Wcxxmg-compact), covering both reinterpret_cast<B*> and the C-style
+// (B*) form that resolves through the same TryReinterpretCast path. This is the
+// cast escape hatch counterpart to warn_cxxmg_offsetof_compact.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+// A is compact: {a,b,c} reorders to {c,b,a}. Reading it as B (source order)
+// would see b/c at the wrong offsets.
+compact struct A {
+  char a;
+  int b;
+  double c;
+};
+
+struct B {
+  char a;
+  int b;
+  double c;
+};
+
+void f(A *pa) {
+  // reinterpret_cast to an unrelated record type: warns.
+  B *b1 = reinterpret_cast<B *>(pa); // expected-warning {{cast from 'compact' type 'A *' to unrelated type 'B *' exposes the reordered layout}}
+  (void)b1;
+
+  // C-style cast resolving to a reinterpret_cast: warns too.
+  B *b2 = (B *)pa; // expected-warning {{cast from 'compact' type 'A *' to unrelated type 'B *' exposes the reordered layout}}
+  (void)b2;
+
+  // Same-type cast: SrcRD == DestRD, no warning.
+  A *a1 = reinterpret_cast<A *>(pa);
+  (void)a1;
+
+  // Cast to a non-record pointer (char*, void*): no warning -- no destination
+  // record whose offsets could be misread.
+  char *c1 = reinterpret_cast<char *>(pa);
+  (void)c1;
+  void *v1 = reinterpret_cast<void *>(pa);
+  (void)v1;
+}
+
+// A plain (non-compact) struct keeps source order; reinterpreting it is the
+// programmer's normal business -- no compact warning.
+struct PlainSrc {
+  char a;
+  int b;
+  double c;
+};
+
+void g(PlainSrc *ps) {
+  B *b = reinterpret_cast<B *>(ps); // no warning: PlainSrc is not compact
+  (void)b;
+}
+
+// Compact class template: each instantiation is reordered and inherits the
+// compact-pattern mark, so casting away from it warns as well. The
+// specialization must be instantiated (it has a determined, reordered layout)
+// for the cast to be meaningful -- a bare pointer to an un-instantiated
+// specialization has no laid-out fields and correctly does not warn.
+template <class T> compact struct Box {
+  char tag;
+  T payload;
+};
+
+Box<double> g_box; // force instantiation -> Box<double> is reordered here
+
+struct Other { int x; };
+
+void h(Box<double> *pb) {
+  Other *o = reinterpret_cast<Other *>(pb); // expected-warning {{cast from 'compact' type 'Box<double> *' to unrelated type 'Other *' exposes the reordered layout}}
+  (void)o;
+}
diff --git a/clang/test/CXXMG/compact/compact-class-keyword.cpp b/clang/test/CXXMG/compact/compact-class-keyword.cpp
