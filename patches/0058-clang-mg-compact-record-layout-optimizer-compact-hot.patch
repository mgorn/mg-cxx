+//===----------------------------------------------------------------------===//
+// C++MG: advisory `hot` suggestion for compact records (-Rcxxmg-suggest-hot)
+//===----------------------------------------------------------------------===//
+
+namespace {
+/// Counts per-field member references across the TU, weighting uses inside loops
+/// by lexical nesting depth, to suggest which field of a `compact` record is the
+/// hottest. Static lexical heuristic only -- advisory, never drives layout.
+class CXXMGFieldUseCounter : public RecursiveASTVisitor<CXXMGFieldUseCounter> {
+public:
+  llvm::DenseMap<const FieldDecl *, uint64_t> Counts;
+  unsigned Depth = 0;
+
+  bool VisitMemberExpr(MemberExpr *ME) {
+    if (const auto *FD = dyn_cast<FieldDecl>(ME->getMemberDecl()))
+      Counts[FD] += (uint64_t(1) << std::min<unsigned>(Depth, 16u));
+    return true;
+  }
+  bool TraverseForStmt(ForStmt *S) {
+    ++Depth;
+    bool R = RecursiveASTVisitor::TraverseForStmt(S);
+    --Depth;
+    return R;
+  }
+  bool TraverseWhileStmt(WhileStmt *S) {
+    ++Depth;
+    bool R = RecursiveASTVisitor::TraverseWhileStmt(S);
+    --Depth;
+    return R;
+  }
+  bool TraverseDoStmt(DoStmt *S) {
+    ++Depth;
+    bool R = RecursiveASTVisitor::TraverseDoStmt(S);
+    --Depth;
+    return R;
+  }
+  bool TraverseCXXForRangeStmt(CXXForRangeStmt *S) {
+    ++Depth;
+    bool R = RecursiveASTVisitor::TraverseCXXForRangeStmt(S);
+    --Depth;
+    return R;
+  }
+};
+} // namespace
+
+void Parser::applyCXXMGCompactToDecl(Decl *D, SourceLocation Loc) {
+  const ASTContext &Ctx = Actions.getASTContext();
+  if (auto *RD = dyn_cast_or_null<RecordDecl>(D)) {
+    // `compact union` is a no-op overlay; warn and leave the record alone.
+    if (RD->isUnion()) {
+      Diag(Loc, diag::warn_cxxmg_compact_on_union);
+      return;
+    }
+    // Estimate the size of the record laid out in a given field order (each
+    // field aligned to its type alignment, the whole rounded up to the maximum
+    // alignment). Shared by the -Wcxxmg-compact-grows advisory and the
+    // -Rcxxmg-compact-summary yield report; returns nullopt for orders it
+    // cannot size (bitfields, dependent/incomplete types).
+    auto estimate = [&Ctx](llvm::ArrayRef<const FieldDecl *> Order)
+        -> std::optional<uint64_t> {
+      uint64_t Offset = 0, MaxAlign = 1;
+      for (const FieldDecl *FD : Order) {
+        if (FD->isBitField())
+          return std::nullopt;
+        QualType T = FD->getType();
+        if (T->isDependentType() || T->isIncompleteType())
+          return std::nullopt;
+        uint64_t A = Ctx.getTypeAlignInChars(T).getQuantity();
+        // Effective alignment honors a per-field alignas, matching the real
+        // layout and the compact packer; without it the estimate underreports
+        // growth (and the saved-bytes summary) for alignas fields.
+        if (unsigned MA = FD->getMaxAlignment())
+          A = std::max<uint64_t>(A, MA / Ctx.getCharWidth());
+        uint64_t S = Ctx.getTypeSizeInChars(T).getQuantity();
+        Offset = (Offset + A - 1) / A * A; // align up
+        Offset += S;
+        if (A > MaxAlign)
+          MaxAlign = A;
+      }
+      return (Offset + MaxAlign - 1) / MaxAlign * MaxAlign;
+    };
+
+    // Capture the declaration-order size BEFORE reordering, so the byte yield
+    // can be reported afterwards.
+    llvm::SmallVector<const FieldDecl *, 16> SourceOrder(RD->field_begin(),
+                                                         RD->field_end());
+    std::optional<uint64_t> SourceSize = estimate(SourceOrder);
+
+    // Reorder the fields to minimize padding (honoring any hot/cold markers).
+    // Field hotness comes from an explicit `hot`/`cold` marker if present,
+    // otherwise from the -fcxxmg-field-profile-use profile (if any).
+    bool Applied =
+        cxxmg::applyCompactLayout(Ctx, RD, [this, &Ctx](const FieldDecl *FD) {
+          auto It = CXXMGFieldHotness.find(FD);
+          if (It != CXXMGFieldHotness.end())
+            return It->second; // explicit marker wins
+          return cxxmg::lookupFieldProfile(Ctx, FD);
+        });
+
+    llvm::SmallVector<const FieldDecl *, 16> Cur(RD->field_begin(),
+                                                 RD->field_end());
+    std::optional<uint64_t> CompactSize = estimate(Cur);
+
+    // Opt-in advisory (-Wcxxmg-compact-grows): if the applied order is larger
+    // than the pure padding-minimized order, the hot/cold markers traded size
+    // for field placement -- report how much it cost.
+    if (Applied && CompactSize) {
+      // Pure padding-minimized order = sort by EFFECTIVE alignment descending
+      // (honoring alignas, like the compact packer), so the do-no-harm baseline
+      // the grows advisory compares against is the real minimum.
+      auto effAlign = [&Ctx](const FieldDecl *F) -> uint64_t {
+        uint64_t A = Ctx.getTypeAlignInChars(F->getType()).getQuantity();
+        if (unsigned MA = F->getMaxAlignment())
+          A = std::max<uint64_t>(A, MA / Ctx.getCharWidth());
+        return A;
+      };
+      llvm::SmallVector<const FieldDecl *, 16> Min(Cur.begin(), Cur.end());
+      std::stable_sort(Min.begin(), Min.end(),
+                       [&effAlign](const FieldDecl *L, const FieldDecl *R) {
+                         return effAlign(L) > effAlign(R);
+                       });
+      if (std::optional<uint64_t> MinSz = estimate(Min))
+        if (*CompactSize > *MinSz)
+          Diag(Loc, diag::warn_cxxmg_compact_grows)
+              << (unsigned)*CompactSize << (unsigned)*MinSz;
+    }
+
+    // Opt-in advisory (-Rcxxmg-compact-summary): report the byte yield from
+    // padding minimization (declaration-order size -> compact size). Only
+    // fires when reordering actually shrank the record.
+    if (SourceSize && CompactSize && *SourceSize > *CompactSize)
+      Diag(Loc, diag::remark_cxxmg_compact_summary)
+          << RD << (unsigned)*SourceSize << (unsigned)*CompactSize
+          << (unsigned)(*SourceSize - *CompactSize);
+
+    // Record this compact struct so the end-of-TU pass can suggest a `hot`
+    // marker for its most-referenced field (-Rcxxmg-suggest-hot /
+    // -Rcxxmg-field-usage).
+    CXXMGCompactRecords.push_back(RD);
+    // Mark the record (canonical decl) so that if it is a `compact` template
+    // pattern, each instantiation is reordered later at Sema::ActOnFields.
+    // (Harmless for the textual form, which has no instantiation pattern and is
+    // reordered here at the keyword site.)
+    cxxmg::markCompactPattern(Ctx, RD);
+  } else if (auto *CTD = dyn_cast_or_null<ClassTemplateDecl>(D)) {
+    // A `compact` class template: D is the ClassTemplateDecl, not a RecordDecl,
+    // so mark its templated pattern record. Each instantiation is then
+    // reordered at Sema::ActOnFields.
+    cxxmg::markCompactPattern(Ctx, CTD->getTemplatedDecl());
+  }
+}
+
+void Parser::CXXMGEmitFieldUsageRemarks() {
+  if (CXXMGCompactRecords.empty())
+    return;
+  DiagnosticsEngine &Diags = Actions.getDiagnostics();
+  // The TU traversal below is only worth running if at least one of the two
+  // advisory remark groups is enabled: -Rcxxmg-suggest-hot (name the single
+  // hottest field) or -Rcxxmg-field-usage (per-field hot/warm/cold histogram).
+  bool WantHot =
+      !Diags.isIgnored(diag::remark_cxxmg_compact_hot_field, SourceLocation());
+  bool WantUsage =
+      !Diags.isIgnored(diag::remark_cxxmg_field_usage, SourceLocation());
+  if (!WantHot && !WantUsage)
+    return;
+
+  CXXMGFieldUseCounter Counter;
+  Counter.TraverseDecl(Actions.getASTContext().getTranslationUnitDecl());
+
+  for (RecordDecl *RD : CXXMGCompactRecords) {
+    const FieldDecl *Best = nullptr; // most-referenced UNMARKED field
+    uint64_t BestCount = 0;
+    const FieldDecl *OverallBest = nullptr; // most-referenced field (any marker)
+    uint64_t OverallBestCount = 0;
+    for (const FieldDecl *FD : RD->fields()) {
+      auto It = Counter.Counts.find(FD);
+      uint64_t C = (It == Counter.Counts.end()) ? 0 : It->second;
+      if (C > OverallBestCount) {
+        OverallBestCount = C;
+        OverallBest = FD;
+      }
+      // Don't suggest a field that already carries an explicit hot/cold marker
+      // -- the user has already decided its placement, so the hint is noise.
+      auto HotIt = CXXMGFieldHotness.find(FD);
+      if (HotIt != CXXMGFieldHotness.end() &&
+          HotIt->second != cxxmg::CXXMGHotness::None)
+        continue;
+      if (C > BestCount) {
+        BestCount = C;
+        Best = FD;
+      }
+    }
+
+    // -Rcxxmg-suggest-hot: point at the single most-referenced UNMARKED field.
+    if (WantHot && Best && BestCount > 0)
+      Diag(Best->getLocation(), diag::remark_cxxmg_compact_hot_field)
+          << Best << (unsigned)BestCount;
+
+    // -Rcxxmg-suggest-hot: flag a `cold` field that is actually the hottest --
+    // a likely mistake, since `cold` pushes it to the tail away from the front
+    // cache line.
+    if (WantHot && OverallBest && OverallBestCount > 0) {
+      auto HotIt = CXXMGFieldHotness.find(OverallBest);
+      if (HotIt != CXXMGFieldHotness.end() &&
+          HotIt->second == cxxmg::CXXMGHotness::Cold)
+        Diag(OverallBest->getLocation(),
+             diag::remark_cxxmg_cold_field_referenced)
+            << OverallBest << (unsigned)OverallBestCount;
+    }
+
+    // -Rcxxmg-field-usage: emit the full per-field histogram with a suggested
+    // cache-placement bucket. Buckets are relative to this record's hottest
+    // field (a field referenced at least half as often as the hottest is
+    // "hot"; a never-referenced field is "cold"; everything else is "warm").
+    // This is a single-TU lexical heuristic -- strictly advisory, it never
+    // drives layout (which would be ABI-unsafe across translation units).
+    if (WantUsage) {
+      // The reorder is complete and the record is used, so the final layout is
+      // available; report each field's byte offset alongside its usage so a
+      // hot field stranded past the first cache line is visible.
+      const ASTRecordLayout &Layout =
+          Actions.getASTContext().getASTRecordLayout(RD);
+      uint64_t HotThreshold = (BestCount + 1) / 2;
+      unsigned Idx = 0;
+      for (const FieldDecl *FD : RD->fields()) {
+        uint64_t OffsetBytes = Layout.getFieldOffset(Idx) / 8;
+        auto It = Counter.Counts.find(FD);
+        uint64_t C = (It == Counter.Counts.end()) ? 0 : It->second;
+        unsigned Bucket; // matches %select order: 0=cold, 1=warm, 2=hot
+        if (C == 0)
+          Bucket = 0;
+        else if (BestCount > 0 && C >= HotThreshold)
+          Bucket = 2;
+        else
+          Bucket = 1;
+        Diag(FD->getLocation(), diag::remark_cxxmg_field_usage)
+            << FD << RD << (unsigned)OffsetBytes << (unsigned)C << Bucket;
+        ++Idx;
+      }
+    }
+  }
+}
