+// HARD: a compact struct containing an ARRAY of another compact struct. The
+// inner E packs to 16 (each element reordered to {b, a}); the outer C sees the
+// field E[3] as align 8, size 48 and reorders to {elems, n, tag} = 56. Verifies
+// that an array-of-struct field uses its (already-reordered) element's alignment
+// and size when the outer record is packed.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct E { char a; double b; };
+compact struct C { char tag; E elems[3]; int n; };
+C c;
+
+static_assert(sizeof(E) == 16, "double then char, padded to 16");
+static_assert(sizeof(C) == 56, "elems(3*16=48)+int(4)+char, padded to 56");
+
+// CHECK:      struct E
+// CHECK-NEXT: double b
+// CHECK-NEXT: char a
+// CHECK:      struct C
+// CHECK-NEXT: E[3] elems
+// CHECK-NEXT: int n
+// CHECK-NEXT: char tag
diff --git a/clang/test/CXXMG/compact/compact-atomic-isolation-template.cpp b/clang/test/CXXMG/compact/compact-atomic-isolation-template.cpp
new file mode 100644
index 000000000..16a1a37bd
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-atomic-isolation-template.cpp
@@ -0,0 +1,28 @@
+// HARD interaction: atomic false-sharing isolation inside a compact CLASS
+// TEMPLATE. The per-instantiation Sema::ActOnFields hook runs applyCompactLayout,
+// which both permutes the fields by alignment AND stamps the cache-line
+// AlignedAttr on the atomic. So every instantiation places its _Atomic counter
+// alone on cache line 0, with n pushed to line 64 -- combining the template
+// reorder (per-instantiation) with the atomic isolation.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+template <class T> compact struct Box {
+  char tag;
+  _Atomic T counter;
+  int n;
+};
+
+Box<long> bl;
+Box<int> bi;
+
+static_assert(sizeof(Box<long>) == 128, "atomic isolated in the instantiation");
+static_assert(sizeof(Box<int>) == 128, "atomic isolated in the instantiation");
+static_assert(alignof(Box<long>) == 64, "record alignment raised to the line");
+
+// CHECK:      struct Box<long>
+// CHECK:      0 |{{.*}}counter
+// CHECK:      64 |{{.*}}int n
+// CHECK:      struct Box<int>
+// CHECK:      0 |{{.*}}counter
+// CHECK:      64 |{{.*}}int n
diff --git a/clang/test/CXXMG/compact/compact-atomic-isolation.cpp b/clang/test/CXXMG/compact/compact-atomic-isolation.cpp
new file mode 100644
index 000000000..257706854
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-atomic-isolation.cpp
@@ -0,0 +1,43 @@
+// Atomic false-sharing isolation: in a compact struct, each atomic field (and
+// the field immediately after it) is forced onto its own 64-byte cache line, so
+// two concurrently-written atomics can never share a line. Covers both C11
+// _Atomic and std::atomic<>. The isolation grows sizeof to 128 and raises the
+// record alignment to 64 -- the deliberate cost of avoiding false sharing.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+// --- C11 _Atomic: counter is isolated, and n is pushed to the next line ---
+compact struct C {
+  char tag;
+  _Atomic int counter;
+  int n;
+};
+C c;
+static_assert(sizeof(C) == 128, "atomic counter isolated to its own cache line");
+static_assert(alignof(C) == 64, "record alignment raised to the cache line");
+
+// CHECK:      struct C
+// CHECK:      0 |{{.*}}counter
+// CHECK:      64 |{{.*}}int n
+// CHECK:      68 |{{.*}}char tag
+
+// --- std::atomic<> (self-contained fake; no <atomic> header needed) ---
+namespace std {
+template <class T> struct atomic {
+  T v;
+};
+} // namespace std
+
+compact struct D {
+  char a;
+  std::atomic<int> ai;
+  int b;
+};
+D d;
+static_assert(sizeof(D) == 128, "std::atomic isolated to its own cache line");
+static_assert(alignof(D) == 64, "record alignment raised to the cache line");
+
+// CHECK:      struct D
+// CHECK:      0 |{{.*}}ai
+// CHECK:      64 |{{.*}}int b
+// CHECK:      68 |{{.*}}char a
diff --git a/clang/test/CXXMG/compact/compact-atomic-ref-not-isolated.cpp b/clang/test/CXXMG/compact/compact-atomic-ref-not-isolated.cpp
new file mode 100644
index 000000000..06e96a561
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-atomic-ref-not-isolated.cpp
@@ -0,0 +1,34 @@
+// std::atomic_ref is DELIBERATELY excluded from compact's atomic false-sharing
+// isolation. Unlike std::atomic<T>, an atomic_ref<T> performs its atomic
+// operations on storage it *refers to*, which lives elsewhere -- aligning the
+// atomic_ref field's own bytes does NOT isolate the referenced object, so it
+// would only bloat the record for nothing. A compact struct with an atomic_ref
+// field therefore packs normally (alignment NOT raised to a cache line), while a
+// real std::atomic field is still isolated.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+namespace std {
+template <class T> struct atomic { T v; };
+template <class T> struct atomic_ref { T *ptr; }; // refers to external storage
+} // namespace std
+
+// atomic_ref field: NOT isolated -> packs to the minimal layout and keeps its
+// natural alignment. {ref(8)@0, y(4)@8, x(1)@12} -> 16 bytes, align 8.
+compact struct R {
+  char x;
+  std::atomic_ref<int> ref;
+  int y;
+};
+static_assert(sizeof(R) == 16, "atomic_ref is packed, not isolated");
+static_assert(alignof(R) == 8, "alignment must NOT be raised to a cache line");
+
+// Control: a real std::atomic field IS isolated onto its own cache line, which
+// raises the record alignment to the line size.
+compact struct A {
+  char x;
+  std::atomic<int> a;
+  int y;
+};
+static_assert(alignof(A) == 64, "std::atomic is still isolated to its own line");
