diff --git a/clang/test/CXXMG/compact/compact-alignas-field-effective-alignment.cpp b/clang/test/CXXMG/compact/compact-alignas-field-effective-alignment.cpp
new file mode 100644
index 000000000..080da9b0d
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-alignas-field-effective-alignment.cpp
@@ -0,0 +1,45 @@
+// Do-no-harm with field-level `alignas`: a field's place in the descending-
+// alignment sort is decided by its EFFECTIVE alignment -- the larger of its
+// type's natural alignment and any `alignas` on the field -- not the type
+// alignment alone. Otherwise `alignas(64) char` would sort as align-1, land
+// last, and force tens of bytes of padding, making the compact struct LARGER
+// than source order (a regression the whole feature exists to prevent).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+// alignas(64) on a char: must sort FIRST by effective align 64, so the struct
+// is no larger than the source-order layout (also 64). Before the fix this was
+// laid out as {b,c,a} with a@64 -> sizeof 128 (twice as big).
+compact struct T {
+  alignas(64) char a;
+  double b;
+  double c;
+};
+T t;
+static_assert(sizeof(T) == 64, "compact must not bloat past source order");
+
+// CHECK:      struct T
+// CHECK-NEXT: 0 |{{.*}}char a
+// CHECK-NEXT: 8 |{{.*}}double b
+// CHECK-NEXT: 16 |{{.*}}double c
+// CHECK:      sizeof=64, align=64
+
+// alignas(16) int b (align 16, size 4) is placed first, and the greedy packer
+// then fills the 4-byte hole after it with the two chars before laying down the
+// double -- yielding sizeof 16 rather than the 32 a pure descending-alignment
+// sort would give ({b, c, a, d}). Both honor b's effective alignment of 16.
+compact struct S {
+  char a;
+  alignas(16) int b;
+  double c;
+  char d;
+};
+S s;
+static_assert(sizeof(S) == 16, "greedy hole-filling beats descending sort (32)");
+
+// CHECK:      struct S
+// CHECK-NEXT: 0 |{{.*}}int b
+// CHECK-NEXT: 4 |{{.*}}char a
+// CHECK-NEXT: 5 |{{.*}}char d
+// CHECK-NEXT: 8 |{{.*}}double c
+// CHECK:      sizeof=16, align=16
diff --git a/clang/test/CXXMG/compact/compact-all-features-torture.cpp b/clang/test/CXXMG/compact/compact-all-features-torture.cpp
new file mode 100644
index 000000000..ecabb22be
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-all-features-torture.cpp
@@ -0,0 +1,29 @@
+// TORTURE TEST: every compact placement mechanism composing in ONE struct --
+// hot-first, cold-last, atomic false-sharing isolation, and padding-min in the
+// middle, from a deliberately scrambled source order.
+//
+// Source order {tag(cold), value(hot), refs(_Atomic), d}. The result:
+//   value @0   -- hot, pulled to the first cache line
+//   d     @8   -- unmarked middle, padding-minimized by alignment
+//   refs  @64  -- _Atomic, isolated onto its own cache line (no false sharing)
+//   tag   @128 -- cold, pushed last; also a fresh line as the field after refs
+// sizeof grows to 192: the deliberate cost of placement + isolation.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct Mega {
+  cold char tag;
+  hot int value;
+  _Atomic int refs;
+  double d;
+};
+Mega mm;
+
+static_assert(sizeof(Mega) == 192, "hot/cold + atomic isolation all compose");
+static_assert(alignof(Mega) == 64, "record alignment raised to the cache line");
+
+// CHECK:      struct Mega
+// CHECK:      0 |{{.*}}int value
+// CHECK:      8 |{{.*}}double d
+// CHECK:      64 |{{.*}}refs
+// CHECK:      128 |{{.*}}char tag
