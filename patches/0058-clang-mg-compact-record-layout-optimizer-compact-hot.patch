diff --git a/clang/test/CXXMG/compact/compact-field-profile-use.cpp b/clang/test/CXXMG/compact/compact-field-profile-use.cpp
new file mode 100644
index 000000000..b5f450c3a
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-profile-use.cpp
@@ -0,0 +1,31 @@
+// C++MG: -fcxxmg-field-profile-use drives `compact` hot/cold placement from a
+// profile file. Each line is "<record> <field> <H|C>", where <field> is either
+// a source-declaration index or a field name. A field the profile marks 'H' is
+// pulled to the front like an explicit `hot`; without the profile the record is
+// laid out by pure padding minimization. The profile is a single global
+// artifact, so the decision is a deterministic function of the file (ABI-safe
+// across TUs). A missing/unreadable profile is ignored.
+//
+// RUN: echo "Entity 2 H" > %t.idx
+// RUN: echo "Entity score H" > %t.name
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.idx -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=PROFILED
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.name -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=PROFILED
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=DEFAULT
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.missing -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=DEFAULT
+
+compact struct Entity {
+  double a;  // index 0
+  double b;  // index 1
+  int score; // index 2  <- profile marks this hot
+  char tag;  // index 3
+};
+Entity e;
+
+// Without a profile: pure padding minimization -> doubles first, score buried.
+// DEFAULT:      struct Entity
+// DEFAULT:      0 |{{.*}}double a
+// DEFAULT:      16 |{{.*}}int score
+
+// With the profile: 'score' is pulled to the first cache line (offset 0).
+// PROFILED:      struct Entity
+// PROFILED:      0 |{{.*}}int score
diff --git a/clang/test/CXXMG/compact/compact-field-usage-hard-access.cpp b/clang/test/CXXMG/compact/compact-field-usage-hard-access.cpp
new file mode 100644
index 000000000..a246b38ca
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-usage-hard-access.cpp
@@ -0,0 +1,32 @@
+// C++MG: -Rcxxmg-field-usage counts member references across many access
+// shapes -- arrow, dot, array subscript (loop-depth-weighted), lambda-capture
+// body, and BOTH arms of a ternary. KNOWN LIMITATION pinned here: a reference
+// inside a template FUNCTION body is not counted -- in the dependent pattern
+// it is an unresolved member expression, and RecursiveASTVisitor does not
+// descend into template instantiations. This is inherent to the single-TU
+// lexical heuristic (which is advisory only, never drives layout).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -Rcxxmg-field-usage -verify %s
+
+compact struct W {
+  double a; // expected-remark {{compact field 'a' of 'W' at offset 0 has 4 weighted reference(s) this TU; suggested cache placement: hot (pull to first cache line)}}
+  int b;    // expected-remark {{compact field 'b' of 'W' at offset 8 has 2 weighted reference(s) this TU; suggested cache placement: hot (pull to first cache line)}}
+  char c;   // expected-remark {{compact field 'c' of 'W' at offset 12 has 1 weighted reference(s) this TU; suggested cache placement: warm (leave unmarked)}}
+};
+
+// Use of 'a' here is NOT counted: dependent member access in the pattern, and
+// the instantiation below is not traversed.
+template <class T> int tpl(T &w) { return (int)w.a; }
+
+int f(W *pw, W &rw, W *arr) {
+  int s = 0;
+  s += pw->a;                           // arrow -> a (weight 1)
+  s += rw.b;                            // dot -> b (weight 1)
+  for (int i = 0; i < 10; ++i)
+    s += arr[i].a;                      // subscript at depth 1 -> a (weight 2)
+  auto lam = [&] { return (int)rw.c; }; // lambda body -> c (weight 1)
+  s += lam();
+  s += (s > 0 ? rw.a : rw.b);           // ternary -> a (1), b (1)
+  s += tpl(rw);                         // template use of 'a' -> NOT counted
+  return s;
+}
diff --git a/clang/test/CXXMG/compact/compact-field-usage-histogram.cpp b/clang/test/CXXMG/compact/compact-field-usage-histogram.cpp
new file mode 100644
index 000000000..9f264e0b0
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-usage-histogram.cpp
@@ -0,0 +1,28 @@
+// C++MG: -Rcxxmg-field-usage emits a full per-field reference histogram for
+// each compact record, with a suggested hot/warm/cold cache-placement bucket.
+// References are weighted by loop-nesting depth (1 << depth). Buckets are
+// relative to the record's hottest field: >= half the max is "hot", a
+// never-referenced field is "cold", everything else is "warm". This is a
+// single-TU lexical heuristic, strictly advisory -- it never changes layout.
+// Off by default (DefaultIgnore), so a plain compile emits nothing.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -Rcxxmg-field-usage -verify %s
+
+// Compact reorders to {x@0, y@8, id@16, tag@20}; the histogram reports each
+// field's final offset alongside its loop-weighted use count and bucket.
+compact struct Particle {
+  double x; // expected-remark {{compact field 'x' of 'Particle' at offset 0 has 4 weighted reference(s) this TU; suggested cache placement: hot (pull to first cache line)}}
+  int id;   // expected-remark {{compact field 'id' of 'Particle' at offset 16 has 1 weighted reference(s) this TU; suggested cache placement: warm (leave unmarked)}}
+  char tag; // expected-remark {{compact field 'tag' of 'Particle' at offset 20 has 0 weighted reference(s) this TU; suggested cache placement: cold (push to tail)}}
+  double y; // expected-remark {{compact field 'y' of 'Particle' at offset 8 has 2 weighted reference(s) this TU; suggested cache placement: hot (pull to first cache line)}}
+};
+
+void use(Particle &p) {
+  for (int i = 0; i < 10; ++i)
+    for (int j = 0; j < 10; ++j)
+      p.x += 1.0; // 'x' at loop depth 2 -> weight 4 (hottest)
+  for (int i = 0; i < 10; ++i)
+    p.y += 1.0;   // 'y' at loop depth 1 -> weight 2
+  p.id = 5;       // 'id' at depth 0 -> weight 1
+  // 'tag' is never referenced -> weight 0 (cold)
+}
diff --git a/clang/test/CXXMG/compact/compact-field-usage-member-function.cpp b/clang/test/CXXMG/compact/compact-field-usage-member-function.cpp
new file mode 100644
index 000000000..de60bbf44
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-usage-member-function.cpp
@@ -0,0 +1,16 @@
+// C++MG: the field-usage counter counts implicit member access inside a member
+// function (`x` meaning `this->x`), not only `s.x` / `p->x` in free functions.
+// Compact reorders to {y@0, x@8, z@12}; the counter still attributes the loop
+// access to 'x'.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -Rcxxmg-field-usage -verify %s
+
+compact struct S {
+  int x;    // expected-remark {{compact field 'x' of 'S' at offset 8 has 2 weighted reference(s) this TU; suggested cache placement: hot (pull to first cache line)}}
+  double y; // expected-remark {{compact field 'y' of 'S' at offset 0 has 0 weighted reference(s) this TU; suggested cache placement: cold (push to tail)}}
+  char z;   // expected-remark {{compact field 'z' of 'S' at offset 12 has 0 weighted reference(s) this TU; suggested cache placement: cold (push to tail)}}
+  void integrate() {
+    for (int i = 0; i < 100; ++i)
+      x += i; // implicit this->x at loop depth 1 -> weight 2
+  }
+};
diff --git a/clang/test/CXXMG/compact/compact-field-usage-off-by-default.cpp b/clang/test/CXXMG/compact/compact-field-usage-off-by-default.cpp
new file mode 100644
index 000000000..be0c26ddc
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-usage-off-by-default.cpp
@@ -0,0 +1,18 @@
+// The per-field usage histogram is OPT-IN: without -Rcxxmg-field-usage the
+// compiler stays silent even though fields are referenced. (DefaultIgnore.)
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct S {
+  int a;
+  double b;
+  char c;
+};
+
+int use(S &s) {
+  int t = 0;
+  for (int i = 0; i < 4; ++i)
+    t += (int)s.b; // referenced in a loop, but still silent without the flag
+  return t + s.a;
+}
diff --git a/clang/test/CXXMG/compact/compact-function-local-class.cpp b/clang/test/CXXMG/compact/compact-function-local-class.cpp
new file mode 100644
index 000000000..2861b1464
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-function-local-class.cpp
@@ -0,0 +1,43 @@
+// WEIRD scenario: a `compact` struct declared at BLOCK SCOPE (a function-local
+// class). The block-scope statement parser must recognize `compact` as the
+// start of a declaration statement (via the C++ tentative parse), not an
+// expression -- otherwise it errors with "expected expression". The local class
+// is reordered like any compact struct: {a, b, c} -> {b, c, a}.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+int use() {
+  compact struct L {
+    char a;
+    double b;
+    int c;
+  };
+  L x{};
+  x.a = 1;
+  x.b = 2.5;
+  x.c = 3;
+  static_assert(sizeof(L) == 16, "local compact struct reorders to {b,c,a}");
+  return x.a + x.c;
+}
+
+// A local compact struct nested inside a lambda body, for good measure.
+auto lam = [] {
+  compact struct M {
+    char tag;
+    double val;
+    int n;
+  };
+  M m{};
+  m.val = 1.0;
+  static_assert(sizeof(M) == 16, "compact struct local to a lambda body reorders too");
+  return (int)sizeof(M);
+};
+
+// CHECK:      struct L
+// CHECK-NEXT: 0 |{{.*}}double b
+// CHECK-NEXT: 8 |{{.*}}int c
+// CHECK-NEXT: 12 |{{.*}}char a
+// CHECK:      struct M
+// CHECK-NEXT: 0 |{{.*}}double val
+// CHECK-NEXT: 8 |{{.*}}int n
+// CHECK-NEXT: 12 |{{.*}}char tag
diff --git a/clang/test/CXXMG/compact/compact-greedy-hole-filling.cpp b/clang/test/CXXMG/compact/compact-greedy-hole-filling.cpp
new file mode 100644
index 000000000..5285e5da1
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-greedy-hole-filling.cpp
@@ -0,0 +1,28 @@
+// Greedy hole-filling: when a field's size is smaller than its alignment, a
+// pure descending-alignment sort leaves a hole. compact instead searches among
+// {descending-alignment, declaration order, greedy hole-filling} and picks the
+// smallest, so the small fields land in the hole. Here `alignas(16) int hdr`
+// ends at offset 4; the greedy order then drops `short s` + two chars into
+// offsets 4..8 before the double, packing P to 16 bytes -- half the 32 that
+// both declaration order AND a descending-alignment sort ({hdr, payload, s, a,
+// b}) would produce.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct P {
+  alignas(16) int hdr;
+  double payload;
+  short s;
+  char a;
+  char b;
+};
+P p;
+static_assert(sizeof(P) == 16, "greedy fills the post-hdr hole (vs 32 unpacked)");
+
+// CHECK:      struct P
+// CHECK-NEXT: 0 |{{.*}}int hdr
+// CHECK-NEXT: 4 |{{.*}}short s
+// CHECK-NEXT: 6 |{{.*}}char a
+// CHECK-NEXT: 7 |{{.*}}char b
+// CHECK-NEXT: 8 |{{.*}}double payload
+// CHECK:      sizeof=16, align=16
diff --git a/clang/test/CXXMG/compact/compact-grows-alignas.cpp b/clang/test/CXXMG/compact/compact-grows-alignas.cpp
new file mode 100644
index 000000000..6ab157de6
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-grows-alignas.cpp
@@ -0,0 +1,22 @@
+// C++MG: the -Wcxxmg-compact-grows size estimate honors per-field alignas. A
+// `hot` char pulled in front of an alignas(16) field wastes padding (48 bytes
+// vs the 32-byte padding-minimized order). Before the fix the estimate used
+// type alignment (ignoring alignas) and missed this growth.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -Wcxxmg-compact-grows -fsyntax-only -verify %s
+
+compact struct S { // expected-warning {{'hot'/'cold' markers make this 'compact' record 48 bytes, larger than the 32-byte padding-minimized layout}}
+  hot char a;
+  alignas(16) int over;
+  double b;
+  int c;
+};
+S s;
+
+// A compact struct with no alignas and no growth must NOT warn.
+compact struct Plain {
+  hot double d;
+  int i;
+  char c;
+};
+Plain p;
diff --git a/clang/test/CXXMG/compact/compact-grows-warning.cpp b/clang/test/CXXMG/compact/compact-grows-warning.cpp
new file mode 100644
index 000000000..748720d2d
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-grows-warning.cpp
@@ -0,0 +1,25 @@
+// -Wcxxmg-compact-grows (opt-in, off by default) warns when `hot`/`cold` markers
+// make a compact record larger than its padding-minimized layout would be -- i.e.
+// when the markers trade size for field placement. This directly surfaces the
+// "markers can cost size" tradeoff to the user.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -Wcxxmg-compact-grows -fsyntax-only -verify %s
+
+// Forcing {a,b} hot keeps them first => {a,b,d,i} = 24 bytes, whereas the
+// padding-minimized order {d,i,a,b} is 16 bytes: the markers cost 8 bytes.
+compact struct HotFirst { // expected-warning {{markers make this 'compact' record 24 bytes, larger than the 16-byte padding-minimized layout}}
+  hot char a;
+  hot char b;
+  double d;
+  int i;
+};
+static_assert(sizeof(HotFirst) == 24, "");
+
+// Here the hot field is already the highest-aligned, so the applied order equals
+// the padding-minimized order: no size cost, no warning.
+compact struct NoCost {
+  hot double d;
+  int i;
+  char c;
+};
+static_assert(sizeof(NoCost) == 16, "");
diff --git a/clang/test/CXXMG/compact/compact-hot-field-asm.cpp b/clang/test/CXXMG/compact/compact-hot-field-asm.cpp
new file mode 100644
index 000000000..edd9965cc
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-field-asm.cpp
@@ -0,0 +1,23 @@
+// END-TO-END (-S assembly): the compact reorder reaches MACHINE CODE, not just
+// the AST. `position` is declared LAST but marked `hot`, so it is reordered to
+// offset 0 -- and the emitted load uses a zero displacement `(%rcx)`, while `id`
+// (offset 8) uses `8(%rcx)`. This proves codegen consumes the reordered layout
+// and that no later pass re-permutes it. (Windows x64 ABI: first arg in %rcx.)
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -triple x86_64-pc-windows-msvc -O2 -S -o - %s | FileCheck %s
+
+compact struct E {
+  cold char name[8];
+  int id;
+  hot double position;
+};
+
+extern "C" double load_pos(E *e) { return e->position; }
+extern "C" int load_id(E *e) { return e->id; }
+
+// position reordered to offset 0 -> load from (%rcx) with no displacement:
+// CHECK-LABEL: load_pos:
+// CHECK:       movsd (%rcx), %xmm0
+// id at offset 8 -> load from 8(%rcx):
+// CHECK-LABEL: load_id:
+// CHECK:       movl 8(%rcx), %eax
diff --git a/clang/test/CXXMG/compact/compact-hot-first-cold-last.cpp b/clang/test/CXXMG/compact/compact-hot-first-cold-last.cpp
new file mode 100644
index 000000000..245924e1b
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-first-cold-last.cpp
@@ -0,0 +1,19 @@
+// `hot` fields are placed first (toward the first cache line(s)) and `cold`
+// fields last, regardless of source order.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s
+
+compact struct Entity {
+  cold char name[8];  // declared first, but cold => goes last
+  int id;             // unmarked => middle
+  hot double position; // declared last, but hot => goes first
+};
+
+static_assert(sizeof(Entity) == 24, "position(8)+id(4)+name(8) padded to 24");
+
+// CHECK:      *** Dumping AST Record Layout
+// CHECK:      0 | struct Entity
+// CHECK-NEXT: 0 |   double position
+// CHECK-NEXT: 8 |   int id
+// CHECK-NEXT: 12 |   char[8] name
diff --git a/clang/test/CXXMG/compact/compact-hot-group-padding-min.cpp b/clang/test/CXXMG/compact/compact-hot-group-padding-min.cpp
new file mode 100644
index 000000000..1d1e2388f
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-group-padding-min.cpp
@@ -0,0 +1,21 @@
+// Within the `hot` group, fields are still padding-minimized (stable sort by
+// descending alignment), so `hot double` precedes `hot char` even though the
+// char was declared first.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s
+
+compact struct S {
+  hot char h1;
+  hot double h2;
+  int m;
+};
+
+// hot group {h1,h2} padding-min => {h2, h1}; then middle m.
+// h2@0, h1@8, pad to 12, m@12 => 16.
+static_assert(sizeof(S) == 16, "h2(8)+h1(1)+pad+m(4) => 16");
+
+// CHECK:      0 | struct S
+// CHECK-NEXT: 0 |   double h2
+// CHECK-NEXT: 8 |   char h1
+// CHECK-NEXT: 12 |   int m
diff --git a/clang/test/CXXMG/compact/compact-hot-priority-over-padding.cpp b/clang/test/CXXMG/compact/compact-hot-priority-over-padding.cpp
new file mode 100644
index 000000000..1d8f54aac
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-priority-over-padding.cpp
@@ -0,0 +1,29 @@
+// `hot` placement takes priority over padding minimization: marking fields hot
+// can make the struct larger than the pure padding-minimized order, because the
+// hot fields are forced to the front. This is the intended tradeoff.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct HotFirst {
+  hot char a;
+  hot char b;
+  double d;
+  int i;
+};
+
+// hot {a,b} first (cost: padding before d), then middle {d,i}:
+// a@0, b@1, pad to 8, d@8, i@16 => 24.
+static_assert(sizeof(HotFirst) == 24, "hot-first costs padding");
+
+// Same members with no markers pack tightly: {d, i, a, b} => 16.
+compact struct NoMarkers {
+  char a;
+  char b;
+  double d;
+  int i;
+};
+static_assert(sizeof(NoMarkers) == 16, "padding-min packs to 16");
+
+static_assert(sizeof(HotFirst) > sizeof(NoMarkers),
+              "hotness overrides padding minimization");
diff --git a/clang/test/CXXMG/compact/compact-implements-interaction.cpp b/clang/test/CXXMG/compact/compact-implements-interaction.cpp
new file mode 100644
index 000000000..cf4e87f2a
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-implements-interaction.cpp
@@ -0,0 +1,63 @@
+// C++MG: `compact` field reordering is layout-only and structurally invisible.
+// A `compact` struct still satisfies a `trait` via `implements` after its
+// fields are reordered, because trait matching is by member name+type, not by
+// declaration order. This pins the orthogonality of the two features (compact
+// shrinks the layout; implements/trait sees the same members) so a future
+// change cannot silently break it.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+trait HasIdAndWeight {
+  int id;
+  double weight;
+};
+
+// Source order: tag(1), id(4), weight(8), flag(1).
+// Compact reorders to weight(8), id(4), tag(1), flag(1) -> sizeof 16.
+compact struct Widget {
+  char tag;
+  int id;
+  double weight;
+  char flag;
+};
+
+// A non-compact twin with identical members keeps source-order layout.
+struct WidgetPlain {
+  char tag;
+  int id;
+  double weight;
+  char flag;
+};
+
+// Reordering shrinks Widget but does not change which members it has.
+static_assert(sizeof(Widget) == 16, "compact reorders Widget to minimize padding");
+static_assert(sizeof(WidgetPlain) == 24, "non-compact twin keeps source order");
+
+// Trait satisfaction is order-independent: both implement the trait, and the
+// reordered `compact` struct is not penalized for having moved its fields.
+static_assert(Widget implements HasIdAndWeight);
+static_assert(WidgetPlain implements HasIdAndWeight);
+
+// The members survive the reorder with their original names and types.
+static_assert(__is_same(decltype(Widget{}.id), int));
+static_assert(__is_same(decltype(Widget{}.weight), double));
+
+// A compact struct missing a required member does not implement the trait
+// (reordering cannot conjure a member that was never declared).
+compact struct Partial {
+  int id;
+  char pad;
+  short extra;
+};
+static_assert(!(Partial implements HasIdAndWeight));
+
+// A compact struct can also be used as a member of another compact struct
+// while still satisfying the trait on its own.
+compact struct Holder {
+  char lead;
+  Widget w;
+  int trailer;
+};
+static_assert(Widget implements HasIdAndWeight);
+static_assert(sizeof(Holder) >= sizeof(Widget));
diff --git a/clang/test/CXXMG/compact/compact-init-designated-reorder-warning.cpp b/clang/test/CXXMG/compact/compact-init-designated-reorder-warning.cpp
new file mode 100644
index 000000000..bf88c4f65
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-init-designated-reorder-warning.cpp
@@ -0,0 +1,17 @@
+// Because `compact` rewrites the field DECLARATION order (here {a,b} becomes
+// {b,a} after sorting by descending alignment), designated initializers written
+// in SOURCE order are now "out of declaration order", so C++ trips
+// -Wreorder-init-list. This pins the CURRENT behavior; it is a known rough edge
+// of the decl-chain-reorder approach and is expected to change once semantic
+// declaration order is decoupled from physical layout order.
+// See research/08-reorder-safety-and-do-no-harm.md.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact struct P {
+  char a;   // align 1
+  double b; // align 8  -> reordered declaration order becomes {b, a}
+};
+
+// Source-order designators .a then .b are out of the reordered decl order {b,a}.
+P p = {.a = 1, .b = 2.0}; // expected-warning {{will be initialized after field 'b'}} expected-note {{previous initialization for field 'a' is here}}
diff --git a/clang/test/CXXMG/compact/compact-init-positional-rejected.cpp b/clang/test/CXXMG/compact/compact-init-positional-rejected.cpp
new file mode 100644
index 000000000..8c593b513
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-init-positional-rejected.cpp
@@ -0,0 +1,20 @@
+// A `compact` struct physically reorders its field declaration order, so
+// positional (non-designated) aggregate initialization is REJECTED: the braced
+// values bind to members in declaration order, which `compact` has changed, so
+// allowing it would silently misinitialize fields. Rejecting it is the correct,
+// safe behavior (it mirrors -frandstruct). Use designated initializers instead.
+//
+// `compact` reuses randstruct's IsRandomized machinery internally (reorderDecls
+// sets the bit), but the diagnostic names `compact` specifically rather than
+// "randomized", so the message matches what the user actually wrote.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact struct P {
+  char a;
+  int b;
+  double c;
+};
+
+// Positional init is rejected (would otherwise bind to the reordered order).
+P p = {1, 2, 3.0}; // expected-error {{a compact struct can only be initialized with a designated initializer}}
diff --git a/clang/test/CXXMG/compact/compact-init-statement-scopes.cpp b/clang/test/CXXMG/compact/compact-init-statement-scopes.cpp
new file mode 100644
index 000000000..9cd418e73
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-init-statement-scopes.cpp
@@ -0,0 +1,23 @@
+// WEIRD scenarios: a `compact` struct defined inline in a C++17 if-init and a
+// for-init statement. These reach the tentative declaration-vs-expression
+// disambiguation through distinct parse paths from a plain function-local
+// declaration, so they separately exercise the kw_compact fix. Both reorder
+// like any compact struct.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+int f(int k) {
+  // if-init-statement: X is defined and reordered ({a,b,c} -> {b,c,a}).
+  if (compact struct X { char a; double b; int c; } v{}; k > 0) {
+    static_assert(sizeof(X) == 16, "if-init compact reorders");
+    (void)v;
+    return v.c;
+  }
+  // for-init-statement: Y is defined and reordered ({a,b} -> {b,a}).
+  for (compact struct Y { char a; double b; } y{}; k < 0; ++k) {
+    static_assert(sizeof(Y) == 16, "for-init compact reorders");
+    return (int)y.b;
+  }
+  return 0;
+}
diff --git a/clang/test/CXXMG/compact/compact-init-value-and-zero-ok.cpp b/clang/test/CXXMG/compact/compact-init-value-and-zero-ok.cpp
new file mode 100644
index 000000000..bb84bda98
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-init-value-and-zero-ok.cpp
@@ -0,0 +1,15 @@
+// Even though `compact` reorders fields, value-initialization `{}` and a single
+// zero initializer `{0}` do not depend on field order, so they remain allowed
+// (this matches the carve-out for randomized structs in C99 6.7.8p19).
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct P {
+  char a;
+  int b;
+  double c;
+};
+
+P e = {};  // value-initialization: no field-order dependence
+P z = {0}; // single zero initializer is explicitly allowed
diff --git a/clang/test/CXXMG/compact/compact-keywords-inert-without-cxxmg.cpp b/clang/test/CXXMG/compact/compact-keywords-inert-without-cxxmg.cpp
new file mode 100644
index 000000000..3a133f5df
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-keywords-inert-without-cxxmg.cpp
@@ -0,0 +1,20 @@
+// Outside C++MG mode (-fno-cxxmg), `compact`, `hot`, and `cold` must remain
+// ordinary identifiers so that existing C++ code keeps compiling.
+//
+// RUN: %clang_cc1 -x c++ -std=c++20 -fno-cxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+int compact = 1;
+int hot = 2;
+int cold = 3;
+
+struct WithMembers {
+  int compact;
+  int hot;
+  int cold;
+};
+
+int use(WithMembers w) {
+  int compact_local = compact + hot + cold;
+  return compact_local + w.compact + w.hot + w.cold;
+}
diff --git a/clang/test/CXXMG/compact/compact-keywords-reserved-with-cxxmg.cpp b/clang/test/CXXMG/compact/compact-keywords-reserved-with-cxxmg.cpp
new file mode 100644
index 000000000..fa99b42ea
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-keywords-reserved-with-cxxmg.cpp
@@ -0,0 +1,10 @@
