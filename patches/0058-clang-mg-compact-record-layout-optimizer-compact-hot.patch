+// C++MG: -Rcxxmg-compact-summary reports the byte yield of padding
+// minimization for each compact record (declaration-order size -> compact
+// size). It only fires when reordering actually shrank the record; an
+// already-optimal record stays silent. Advisory, off by default.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -Rcxxmg-compact-summary -verify %s
+
+// Source order: material_id(1) pad velocity(8) flags(4) mass(8 @24) team(1)
+// -> 40 bytes; compact packs the two doubles first -> 24 bytes (saves 16).
+compact struct Particle { // expected-remark {{'compact' reordered 'Particle' from 40 to 24 bytes (saved 16 of padding)}}
+  char material_id;
+  double velocity;
+  int flags;
+  double mass;
+  char team;
+};
+Particle p;
+
+// Already in descending-alignment order: no padding to recover, so no remark.
+compact struct Tight {
+  double d;
+  int i;
+  char c;
+};
+Tight t;
