diff --git a/clang/test/CXXMG/compact/compact-field-profile-qualified-name.cpp b/clang/test/CXXMG/compact/compact-field-profile-qualified-name.cpp
new file mode 100644
index 000000000..589de92fa
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-profile-qualified-name.cpp
@@ -0,0 +1,26 @@
+// C++MG: -fcxxmg-field-profile-use matches a record by qualified name first
+// (e.g. "net::Pkt"), then falls back to the simple name ("Pkt"). A qualified
+// key disambiguates same-named structs in different namespaces; a simple-name
+// key still matches all of them (backward compatible, and what
+// -Rcxxmg-field-usage emits).
+//
+// RUN: echo "net::Pkt seq H" > %t.q
+// RUN: echo "Pkt seq H" > %t.s
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.q -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=QUAL
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.s -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=SIMPLE
+
+namespace net { compact struct Pkt { char tag; double ts; int seq; }; net::Pkt a; }
+namespace disk { compact struct Pkt { char tag; double ts; int seq; }; disk::Pkt b; }
+
+// The qualified key targets only net::Pkt (seq -> offset 0); disk::Pkt keeps
+// its padding-minimized order (seq at offset 8).
+// QUAL:      struct net::Pkt
+// QUAL:      0 |{{.*}}int seq
+// QUAL:      struct disk::Pkt
+// QUAL:      8 |{{.*}}int seq
+
+// The simple-name key matches both records.
+// SIMPLE:      struct net::Pkt
+// SIMPLE:      0 |{{.*}}int seq
+// SIMPLE:      struct disk::Pkt
+// SIMPLE:      0 |{{.*}}int seq
diff --git a/clang/test/CXXMG/compact/compact-field-profile-template.cpp b/clang/test/CXXMG/compact/compact-field-profile-template.cpp
new file mode 100644
index 000000000..96cc05f99
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-profile-template.cpp
@@ -0,0 +1,25 @@
+// C++MG: -fcxxmg-field-profile-use also drives `compact` template
+// instantiations. The profile keys on the PATTERN's (record name, field), so a
+// single entry covers every instantiation. The reorder happens per
+// instantiation at Sema::ActOnFields, consulting the profile for the mapped
+// pattern field.
+//
+// RUN: echo "Box small H" > %t.prof
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.prof -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=PROFILED
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s --check-prefix=DEFAULT
+
+template <class T> compact struct Box {
+  double big;
+  T small;
+  int mid;
+};
+Box<char> b;
+
+// Without a profile: padding-min -> big(8), mid(4), small(1) -> big at offset 0.
+// DEFAULT:      struct Box<char>
+// DEFAULT:      0 |{{.*}}double big
+
+// With the profile, the pattern field 'small' is hot -> pulled to offset 0 in
+// the instantiation.
+// PROFILED:      struct Box<char>
+// PROFILED:      0 |{{.*}}char small
