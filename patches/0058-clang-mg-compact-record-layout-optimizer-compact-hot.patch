--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-profile-edge-cases.cpp
@@ -0,0 +1,23 @@
+// C++MG: -fcxxmg-field-profile-use edge cases.
+//  - an explicit `hot`/`cold` marker overrides the profile;
+//  - a 'C' bucket pushes a field to the tail;
+//  - comment ('#'), wrong-token-count, and bad-bucket lines are ignored
+//    without error.
+//
+// RUN: printf '# a comment\nWidget a C\nWidget c C\nWidget b\njunk junk junk\n' > %t.prof
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.prof -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.prof -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct Widget {
+  hot int a; // explicitly hot: stays at offset 0 even though the profile says C
+  double b;
+  int c;     // profile marks this C (cold) -> pushed to the tail
+  char d;
+};
+Widget w;
+
+// 'a' wins as hot (explicit beats profile); 'c' is cold, last among the data.
+// CHECK:      struct Widget
+// CHECK:      0 |{{.*}}int a
+// CHECK:      20 |{{.*}}int c
