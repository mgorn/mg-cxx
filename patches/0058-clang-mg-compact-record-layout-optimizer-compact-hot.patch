diff --git a/clang/test/CXXMG/compact/compact-lambda-over-isolated-atomic.cpp b/clang/test/CXXMG/compact/compact-lambda-over-isolated-atomic.cpp
new file mode 100644
index 000000000..d86bf1829
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-lambda-over-isolated-atomic.cpp
@@ -0,0 +1,27 @@
+// HARD (combined lambda + atomic isolation + constexpr): a constexpr lambda
+// captures by reference and mutates a compact struct whose atomic field is
+// isolated onto its own 64-byte cache line. The lambda reads/writes a member at
+// the reordered offset and constant evaluation produces the right value --
+// proving the isolated layout is consistent across capture, member access, and
+// constexpr evaluation.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct S {
+  char tag;
+  _Atomic int a; // isolated onto its own cache line
+  int b;
+};
+
+constexpr int run() {
+  S s{};
+  auto inc = [&s](int d) {
+    s.b += d;
+    return s.b;
+  };
+  inc(3);
+  return inc(4);
+}
+
+static_assert(run() == 7, "lambda mutates the reordered/isolated struct");
diff --git a/clang/test/CXXMG/compact/compact-lambda-over-reordered-members.cpp b/clang/test/CXXMG/compact/compact-lambda-over-reordered-members.cpp
new file mode 100644
index 000000000..7d5168af3
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-lambda-over-reordered-members.cpp
@@ -0,0 +1,21 @@
+// HARD: a lambda captures a compact (hot/cold-reordered) struct by reference and
+// touches several of its reordered members inside a constexpr evaluation. Member
+// access by name must resolve to the correct field regardless of physical order,
+// and the closure must observe one consistent layout.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct V3 { hot double x; cold char tag; double y; double z; };
+
+constexpr double sum() {
+  V3 v{};
+  v.x = 1;
+  v.y = 2;
+  v.z = 3;
+  v.tag = 'a';
+  auto f = [&] { return v.x + v.y + v.z; }; // touches reordered members
+  return f();
+}
+
+static_assert(sum() == 6.0, "lambda reads the right reordered fields");
diff --git a/clang/test/CXXMG/compact/compact-memcpy-warning.cpp b/clang/test/CXXMG/compact/compact-memcpy-warning.cpp
new file mode 100644
index 000000000..9ada78e96
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-memcpy-warning.cpp
@@ -0,0 +1,65 @@
+// Safety: memcpy/memmove between a `compact` record and an UNRELATED record
+// type copies the field-reordered bytes, which the other type reinterprets at
+// its own (different) offsets. memcpy launders both pointers through `void *`,
+// so warn_cxxmg_cast_from_compact cannot see it -- this is a distinct, otherwise
+// silent escape hatch. Warn at the call (-Wcxxmg-compact). Same-type copies and
+// copies to/from a non-record buffer are intentionally NOT flagged.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+// A is compact: {a,b,c} reorders to {c,b,a}. B keeps source order.
+compact struct A {
+  char a;
+  int b;
+  double c;
+};
+
+struct B {
+  char a;
+  int b;
+  double c;
+};
+
+void f(A *pa, A *pa2, B *pb) {
+  // compact source -> unrelated dest: warns.
+  __builtin_memcpy(pb, pa, sizeof(A)); // expected-warning {{between 'compact' type 'A' and unrelated type 'B' copies the reordered byte layout}}
+
+  // compact dest <- unrelated source: warns too (mismatch is symmetric).
+  __builtin_memcpy(pa, pb, sizeof(A)); // expected-warning {{between 'compact' type 'A' and unrelated type 'B' copies the reordered byte layout}}
+
+  // memmove behaves the same.
+  __builtin_memmove(pb, pa, sizeof(A)); // expected-warning {{between 'compact' type 'A' and unrelated type 'B' copies the reordered byte layout}}
+
+  // Same compact type on both sides: faithful byte copy, no warning.
+  __builtin_memcpy(pa, pa2, sizeof(A));
+
+  // To/from a raw byte buffer (serialization idiom): no record on one side,
+  // no warning.
+  char buf[sizeof(A)];
+  __builtin_memcpy(buf, pa, sizeof(A));
+  __builtin_memcpy(pa, buf, sizeof(A));
+}
+
+// Two non-compact records: ordinary programmer business, no compact warning.
+struct PlainSrc {
+  char a;
+  int b;
+  double c;
+};
+void g(PlainSrc *ps, B *pb) {
+  __builtin_memcpy(pb, ps, sizeof(B)); // no warning: neither side is compact
+}
+
+// Compact class template: an instantiated specialization is reordered and
+// inherits the compact-pattern mark, so memcpy to an unrelated type warns.
+template <class T> compact struct Box {
+  char tag;
+  T payload;
+};
+Box<double> g_box; // force instantiation -> Box<double> reordered
+
+struct Other { int x; double y; };
+
+void h(Box<double> *pbox, Other *po) {
+  __builtin_memcpy(po, pbox, sizeof(Box<double>)); // expected-warning {{between 'compact' type 'Box<double>' and unrelated type 'Other' copies the reordered byte layout}}
+}
diff --git a/clang/test/CXXMG/compact/compact-mixed-int-widths-pointer.cpp b/clang/test/CXXMG/compact/compact-mixed-int-widths-pointer.cpp
new file mode 100644
index 000000000..4385f743d
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-mixed-int-widths-pointer.cpp
@@ -0,0 +1,27 @@
+// HARD: compact packing across all integer widths plus pointer and bool. Prior
+// tests used only char/int/double; this exercises pointer (align 8), long long
+// (align 8), int (4), short (2), bool/char (1). Reorder is by descending
+// alignment, tie-broken by descending size then source order, giving
+// {void*, long long, int, short, bool, char}.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct M {
+  bool b;
+  void *p;
+  short s;
+  char c;
+  long long ll;
+  int i;
+};
+M m;
+
+static_assert(sizeof(M) == 24, "ptr(8)+ll(8)+int(4)+short(2)+bool(1)+char(1) => 24");
+
+// CHECK:      struct M
+// CHECK-NEXT: void * p
+// CHECK-NEXT: long long ll
+// CHECK-NEXT: int i
+// CHECK-NEXT: short s
+// CHECK-NEXT: _Bool b
+// CHECK-NEXT: char c
diff --git a/clang/test/CXXMG/compact/compact-named-union-member.cpp b/clang/test/CXXMG/compact/compact-named-union-member.cpp
new file mode 100644
index 000000000..7f3299063
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-named-union-member.cpp
@@ -0,0 +1,20 @@
+// C++MG: a compact struct with a NAMED union member reorders the union as an
+// opaque field -- it is not an anonymous/indirect member, so compact does not
+// bail. (Contrast compact-bail-anonymous-member, where an anonymous union bails
+// the whole record, and compact-union-noop, where a compact union is a no-op.)
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct S {
+  char tag;
+  union U { int i; double d; } u;
+  int n;
+};
+S s;
+
+// u (align 8) sorts to the front, then n (4), then tag (1) -> 16 bytes.
+// CHECK:      struct S
+// CHECK:      0 |{{.*}}union S::U u
+// CHECK:      8 |{{.*}}int n
+// CHECK:      12 |{{.*}}char tag
+// CHECK:      {{.*}}sizeof=16
diff --git a/clang/test/CXXMG/compact/compact-nested-compact-atomic-composition.cpp b/clang/test/CXXMG/compact/compact-nested-compact-atomic-composition.cpp
new file mode 100644
index 000000000..61c769efe
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-nested-compact-atomic-composition.cpp
@@ -0,0 +1,25 @@
+// Hard/weird scenario: a compact struct whose field is ITSELF a compact struct
+// that contains an atomic. The inner atomic isolation (Inner -> 128B/align64)
+// composes through the outer compact reorder: because Inner now has alignment
+// 64, the outer compact sort places it FIRST (offset 0), funneling the small
+// `char a` into the tail. The result (192) is smaller than the non-compact
+// outer layout (256), where `a` forces the 64-aligned Inner to offset 64. So
+// nesting an isolated atomic still satisfies do-no-harm at the outer level.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct Inner { char x; _Atomic int ctr; int y; };
+compact struct Outer { char a; Inner in; double d; };
+Outer o;
+
+// Inner is isolated to its own cache line: ctr@0, y pushed to 64, sizeof 128.
+static_assert(sizeof(Inner) == 128, "inner atomic isolated");
+// Outer compact sorts the align-64 Inner first, then the double, then the char.
+static_assert(sizeof(Outer) == 192, "outer reorder keeps it tight (vs 256 unsorted)");
+static_assert(alignof(Outer) == 64, "outer inherits the cache-line alignment");
+
+// CHECK:      struct Outer
+// CHECK-NEXT: 0 |{{.*}}struct Inner in
+// CHECK:      128 |{{.*}}double d
+// CHECK-NEXT: 136 |{{.*}}char a
+// CHECK:      sizeof=192, align=64
diff --git a/clang/test/CXXMG/compact/compact-nested-in-compact.cpp b/clang/test/CXXMG/compact/compact-nested-in-compact.cpp
new file mode 100644
index 000000000..004763c48
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-nested-in-compact.cpp
@@ -0,0 +1,22 @@
+// HARD: a compact struct nested as a field of another compact struct. Each
+// reorders independently, and the outer must place the inner field using the
+// inner's ALREADY-reordered size (16) and alignment (8) -- inner-before-outer
+// completion, no stale size.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct Inner { char c; double d; };           // -> {d, c}, 16 bytes
+compact struct Outer { char a; Inner inner; long l; }; // -> {inner, l, a}, 24 bytes
+
+static_assert(sizeof(Inner) == 16, "inner packs char after double");
+static_assert(sizeof(Outer) == 24, "inner(16)+long(8)+char, padded to 24");
+
+// Inner reorders to {d, c}:
+// CHECK:      struct Inner
+// CHECK-NEXT: double d
+// CHECK-NEXT: char c
+// Outer reorders to {inner, l, a}; the nested inner is itself reordered:
+// CHECK:      struct Outer
+// CHECK-NEXT: struct Inner inner
+// CHECK:      long l
+// CHECK-NEXT: char a
diff --git a/clang/test/CXXMG/compact/compact-nsdmi-and-unnamed-member.cpp b/clang/test/CXXMG/compact/compact-nsdmi-and-unnamed-member.cpp
new file mode 100644
index 000000000..597a137f5
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-nsdmi-and-unnamed-member.cpp
@@ -0,0 +1,38 @@
+// Default member initializers (NSDMI) bind to their FIELDS, not to positions, so
+// reordering a compact struct preserves them: each field keeps its initializer.
+// Also covers a compact struct with no type name used as a member type, which
+// reorders like any other. Both are realistic patterns that must keep working.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+// {a,b,c} reorders to {b,c,a}, but the NSDMIs travel with their fields.
+compact struct N {
+  char a = 'A';
+  double b = 2.5;
+  int c = 42;
+};
+constexpr N n{}; // value-init uses the NSDMIs
+static_assert(n.a == 'A' && n.b == 2.5 && n.c == 42,
+              "each default member initializer binds to its own field after reorder");
+static_assert(sizeof(N) == 16, "reordered to {b,c,a}");
+
+// A nested compact struct whose NSDMI references an earlier member still works
+// (initialization order follows declaration order, independent of layout order).
+compact struct M {
+  int base = 100;
+  double scaled = 1.5;
+  char tag = 't';
+};
+constexpr M m{};
+static_assert(m.base == 100 && m.scaled == 1.5 && m.tag == 't', "");
+
+// A compact struct with no type name, used as a member's type, reorders too.
+struct Outer {
+  compact struct {
+    int x;
+    double y;
+    char z;
+  } inner;
+};
+static_assert(sizeof(Outer) == 16, "unnamed compact member reorders to {y,x,z}");
diff --git a/clang/test/CXXMG/compact/compact-offsetof-on-greedy-layout.cpp b/clang/test/CXXMG/compact/compact-offsetof-on-greedy-layout.cpp
new file mode 100644
index 000000000..9b78f1e2d
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-offsetof-on-greedy-layout.cpp
@@ -0,0 +1,23 @@
+// The offsetof escape-hatch warning composes with the greedy/exhaustive packer:
+// __builtin_offsetof on a compact struct returns the OPTIMIZED offset (not the
+// source-declaration offset) and still warns at every use site, since the field
+// offset differs from declaration order. P is packed to {hdr, s, a, b, payload}
+// at offsets 0,4,6,7,8 -- none of which match declaration order except hdr.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact struct P {
+  alignas(16) int hdr;
+  double payload;
+  short s;
+  char a;
+  char b;
+};
+
+// Offsets reflect the packed layout (hdr@0, s@4, a@6, b@7, payload@8), and each
+// offsetof on the compact type warns that it sees the reordered layout.
+static_assert(__builtin_offsetof(P, hdr) == 0, "");     // expected-warning {{'offsetof' on 'compact' type 'P' uses the reordered layout}}
+static_assert(__builtin_offsetof(P, s) == 4, "");       // expected-warning {{'offsetof' on 'compact' type 'P' uses the reordered layout}}
+static_assert(__builtin_offsetof(P, a) == 6, "");       // expected-warning {{'offsetof' on 'compact' type 'P' uses the reordered layout}}
+static_assert(__builtin_offsetof(P, b) == 7, "");       // expected-warning {{'offsetof' on 'compact' type 'P' uses the reordered layout}}
+static_assert(__builtin_offsetof(P, payload) == 8, ""); // expected-warning {{'offsetof' on 'compact' type 'P' uses the reordered layout}}
diff --git a/clang/test/CXXMG/compact/compact-offsetof-warning.cpp b/clang/test/CXXMG/compact/compact-offsetof-warning.cpp
new file mode 100644
index 000000000..40320410b
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-offsetof-warning.cpp
@@ -0,0 +1,25 @@
+// Safety: `offsetof` on a `compact` struct returns the REORDERED offset, which
+// differs from the source declaration order -- a layout-escape hazard. Warn at
+// the offsetof use site (-Wcxxmg-compact). Here compact reorders {a,b,c} to
+// {c,b,a}, so c moves from source-order offset 8 to 0.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact struct S {
+  char a;
+  int b;
+  double c;
+};
+
+// c is the first field after the compact reorder, so its offset is 0 (it would
+// be 8 in source order) -- offsetof observes the reordered layout.
+static_assert(__builtin_offsetof(S, c) == 0, ""); // expected-warning {{'offsetof' on 'compact' type 'S' uses the reordered layout}}
+static_assert(__builtin_offsetof(S, a) == 12, ""); // expected-warning {{'offsetof' on 'compact' type 'S' uses the reordered layout}}
+
+// A non-compact struct with the same members is NOT warned (source-order layout).
+struct Plain {
+  char a;
+  int b;
+  double c;
+};
+static_assert(__builtin_offsetof(Plain, c) == 8, "");
diff --git a/clang/test/CXXMG/compact/compact-optimal-small-struct.cpp b/clang/test/CXXMG/compact/compact-optimal-small-struct.cpp
new file mode 100644
index 000000000..ebc0e7e03
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-optimal-small-struct.cpp
@@ -0,0 +1,28 @@
+// For a PLAIN compact struct with up to 8 reorderable fields, compact searches
+// all field permutations and produces the provably MINIMAL layout -- which can
+// beat every cheap heuristic (descending alignment, declaration order, greedy
+// hole-filling). Q below packs to 32 bytes via a non-obvious interleaving that
+// greedy alone misses (greedy gives 48): the two alignas(16) fields and the
+// plain ints are interleaved so the 16-byte slots are fully used.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct Q {
+  int f0;
+  int f1[2];
+  int f2[2];
+  alignas(16) int f3;
+  alignas(16) char f4;
+};
+Q q;
+static_assert(sizeof(Q) == 32, "exhaustive search finds the minimal layout (greedy gives 48)");
+
+// The optimal order packs all 24 bytes of data into two 16-byte slots: an
+// alignas(16) field opens each slot, plain ints fill the remainder.
+// CHECK:      struct Q
+// CHECK-NEXT: 0 |{{.*}}int f3
+// CHECK-NEXT: 4 |{{.*}}int f0
+// CHECK-NEXT: 8 |{{.*}}int[2] f1
+// CHECK-NEXT: 16 |{{.*}}char f4
+// CHECK-NEXT: 20 |{{.*}}int[2] f2
+// CHECK:      sizeof=32, align=16
diff --git a/clang/test/CXXMG/compact/compact-packer-fast-path.cpp b/clang/test/CXXMG/compact/compact-packer-fast-path.cpp
new file mode 100644
index 000000000..2f1e583a3
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-packer-fast-path.cpp
@@ -0,0 +1,27 @@
+// C++MG: when every field's size is a multiple of its effective alignment (all
+// standard types), descending-alignment packing is provably optimal -- each
+// field lands with zero padding -- so the O(n!) exhaustive search is skipped.
+// This pins that the fast path still produces the minimal layout, and that an
+// alignas field (size not a multiple of alignment) still gets the optimal
+// layout via the exhaustive path.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+// All sizes are multiples of their alignments -> zero internal padding.
+// 1+8+4+2+1+8+4+4 = 32, max align 8 -> 32 bytes (fast path, no exhaustive search).
+compact struct Std {
+  char a; double b; int c; short d; char e; double f; int g; long h;
+};
+static_assert(sizeof(Std) == 32, "descending-alignment is optimal here");
+
+// alignas makes a field's size (4) not a multiple of its alignment (16), so the
+// exhaustive search runs and still finds the minimal layout: 'over'(4)@0,
+// 'a'(1) in the hole at @4, 'b'(8)@8 -> everything fits in one 16-byte block,
+// which descending-alignment alone would not discover.
+compact struct WithAlignas {
+  char a;
+  alignas(16) int over;
+  double b;
+};
+static_assert(sizeof(WithAlignas) == 16, "exhaustive path finds the optimal 16");
diff --git a/clang/test/CXXMG/compact/compact-padding-minimization.cpp b/clang/test/CXXMG/compact/compact-padding-minimization.cpp
new file mode 100644
index 000000000..045085ea2
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-padding-minimization.cpp
@@ -0,0 +1,27 @@
+// A `compact` struct reorders its fields (stable sort by descending alignment)
+// to minimize padding, so it is no larger than -- and here strictly smaller
+// than -- the same struct declared without `compact`.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct Packed {
+  char a;
+  int b;
+  char c;
+  double d;
+};
+
+// Same members, no `compact`: declaration-order layout keeps the padding.
+struct Plain {
+  char a;
+  int b;
+  char c;
+  double d;
+};
+
+// Reordered to {d, b, a, c}: 8 + 4 + 1 + 1 = 14, padded to the 8-byte
+// alignment of `double` => 16. Plain stays in source order => 24.
+static_assert(sizeof(Packed) == 16, "compact should pack to 16 bytes");
+static_assert(sizeof(Plain) == 24, "plain layout keeps source-order padding");
+static_assert(sizeof(Packed) < sizeof(Plain), "compact must shrink the struct");
diff --git a/clang/test/CXXMG/compact/compact-requires-record.cpp b/clang/test/CXXMG/compact/compact-requires-record.cpp
new file mode 100644
index 000000000..7423a1ca0
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-requires-record.cpp
@@ -0,0 +1,11 @@
+// `compact` is only valid immediately before a struct/class/union specifier.
+// Other uses are diagnosed, and the parser recovers by dropping the keyword.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact int x; // expected-error {{'compact' must be followed by 'struct', 'class', or 'union'}}
+
+compact enum E { A, B }; // expected-error {{'compact' must be followed by 'struct', 'class', or 'union'}}
+
+// Recovery: after dropping 'compact', the rest parses normally.
+static_assert(sizeof(x) == sizeof(int), "");
diff --git a/clang/test/CXXMG/compact/compact-size-tiebreak.cpp b/clang/test/CXXMG/compact/compact-size-tiebreak.cpp
new file mode 100644
index 000000000..c49d56cab
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-size-tiebreak.cpp
@@ -0,0 +1,22 @@
+// HARD: the compact comparator sorts by DESCENDING ALIGNMENT, then DESCENDING
+// SIZE as a tie-break (then source order). Here char[4] (big) and char (small)
+// share alignment 1 but differ in size, so big must precede small. The full
+// order by alignment is {int(4), short(2), char[4](1,sz4), char(1,sz1)}.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct S {
+  char small;
+  char big[4];
+  short s;
+  int x;
+};
+S v;
+
+static_assert(sizeof(S) == 12, "int(4)+short(2)+char[4]+char, padded to 12");
+
+// CHECK:      struct S
+// CHECK-NEXT: int x
+// CHECK-NEXT: short s
+// CHECK-NEXT: char[4] big
+// CHECK-NEXT: char small
diff --git a/clang/test/CXXMG/compact/compact-structured-binding-warning.cpp b/clang/test/CXXMG/compact/compact-structured-binding-warning.cpp
new file mode 100644
index 000000000..72f16836c
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-structured-binding-warning.cpp
@@ -0,0 +1,32 @@
+// C++MG: a structured binding of a `compact` record binds its members in the
+// optimized (reordered) layout order, not source declaration order. Warn under
+// -Wcxxmg-compact (default-on) so positional binding code is not surprised.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+compact struct S { char first; double second; int third; };
+
+void f(S s) {
+  auto [a, b, c] = s; // expected-warning {{structured binding of 'compact' type 'S' binds members in the reordered layout order, not source declaration order}}
+  (void)a;
+  (void)b;
+  (void)c;
+}
+
+// A non-compact struct decomposes in source order -- no warning.
+struct Plain { char x; double y; int z; };
+void g(Plain p) {
+  auto [a, b, c] = p; // no warning
+  (void)a;
+  (void)b;
+  (void)c;
+}
+
+// The warning can be silenced with -Wno-cxxmg-compact (it is in that group);
+// here we just confirm a single-field compact record does not warn (nothing to
+// reorder).
+compact struct One { int only; };
+void h(One o) {
+  auto [a] = o; // no warning: single field, no reordering
+  (void)a;
+}
diff --git a/clang/test/CXXMG/compact/compact-suggest-hot-cold-contradiction.cpp b/clang/test/CXXMG/compact/compact-suggest-hot-cold-contradiction.cpp
new file mode 100644
index 000000000..8a10b9021
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-suggest-hot-cold-contradiction.cpp
@@ -0,0 +1,30 @@
+// C++MG: -Rcxxmg-suggest-hot flags a field that is marked `cold` yet is the
+// most-referenced member -- a likely mistake, since `cold` pushes the field to
+// the tail, away from the first cache line.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -Rcxxmg-suggest-hot -verify %s
+
+compact struct S {
+  cold int x; // expected-remark {{field 'x' is marked 'cold' but is the most-referenced member (4 uses); this pushes a hot field to the tail and likely hurts cache locality}}
+  double y;
+  char z;
+};
+int use(S *s, int n) {
+  int t = 0;
+  for (int i = 0; i < n; ++i)
+    for (int j = 0; j < n; ++j)
+      t += s[i].x; // x referenced at loop depth 2 -> weight 4
+  return t;
+}
+
+// A correctly-cold field (not referenced) does not warn.
+compact struct Ok {
+  cold char rare;
+  hot double hotf;
+  int mid;
+};
+int use2(Ok *s, int n) {
+  int t = 0;
+  for (int i = 0; i < n; ++i) t += (int)s[i].hotf; // hotf used, rare not
+  return t;
+}
diff --git a/clang/test/CXXMG/compact/compact-suggest-hot-loop-weighted.cpp b/clang/test/CXXMG/compact/compact-suggest-hot-loop-weighted.cpp
new file mode 100644
index 000000000..92871438d
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-suggest-hot-loop-weighted.cpp
@@ -0,0 +1,21 @@
+// HARD: loop weighting. A field touched once inside a doubly-nested loop
+// outweighs a field touched three times at top level, because uses are weighted
+// by lexical loop-nesting depth (weight = 1 << depth). The suggestion must name
+// the loop-hot field, not the raw-most-frequent one.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -Rcxxmg-suggest-hot -fsyntax-only -verify %s
+
+compact struct S {
+  int outer;
+  double loophot; // expected-remark {{field 'loophot' is the most-referenced member (4 uses); consider marking it 'hot'}}
+  char c;
+};
+
+void use(S &s, int n) {
+  s.outer = 1; // depth 0 -> weight 1
+  s.outer = 2; // depth 0 -> weight 1
+  s.outer = 3; // depth 0 -> weight 1   (total 3)
+  for (int i = 0; i < n; ++i)
+    for (int j = 0; j < n; ++j)
+      s.loophot += 1.0; // depth 2 -> weight 1 << 2 = 4
+}
diff --git a/clang/test/CXXMG/compact/compact-suggest-hot-off-by-default.cpp b/clang/test/CXXMG/compact/compact-suggest-hot-off-by-default.cpp
new file mode 100644
index 000000000..7a281e7a9
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-suggest-hot-off-by-default.cpp
@@ -0,0 +1,13 @@
+// The usage-analysis suggestion is OPT-IN: without -Rcxxmg-suggest-hot the
+// compiler stays silent even though fields are referenced. (DefaultIgnore.)
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct S {
+  int a;
+  double b;
+  char c;
+};
+
+int use(S &s) { return (int)(s.b + s.b + s.b) + s.a; }
diff --git a/clang/test/CXXMG/compact/compact-suggest-hot-remark.cpp b/clang/test/CXXMG/compact/compact-suggest-hot-remark.cpp
new file mode 100644
index 000000000..caa15119b
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-suggest-hot-remark.cpp
@@ -0,0 +1,19 @@
+// -Rcxxmg-suggest-hot (opt-in, off by default) counts how often each field of a
+// compact struct is referenced across the translation unit and emits a remark
+// naming the most-referenced field, suggesting it be marked `hot`. Advisory
+// ONLY -- it does not change layout.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -Rcxxmg-suggest-hot -fsyntax-only -verify %s
+
+compact struct S {
+  int a;
+  double b; // expected-remark {{field 'b' is the most-referenced member (3 uses); consider marking it 'hot'}}
+  char c;
+};
+
+int use(S &s) {
+  s.b = 1.0;  // b: 1
+  s.b += s.b; // b: 2, 3
+  s.a = 2;    // a: 1
+  return s.c; // c: 1
+}
diff --git a/clang/test/CXXMG/compact/compact-suggest-hot-skips-marked.cpp b/clang/test/CXXMG/compact/compact-suggest-hot-skips-marked.cpp
new file mode 100644
index 000000000..c132a1621
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-suggest-hot-skips-marked.cpp
@@ -0,0 +1,27 @@
+// C++MG: -Rcxxmg-suggest-hot does not suggest a field that already carries an
+// explicit `hot`/`cold` marker -- the user already decided its placement, so
+// the hint would be noise. It suggests the most-referenced UNMARKED field.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -Rcxxmg-suggest-hot -verify %s
+
+compact struct Marked { hot int x; double y; char z; };
+int um(Marked *s, int n) {
+  int t = 0;
+  for (int i = 0; i < n; ++i)
+    for (int j = 0; j < n; ++j)
+      t += s[i].x; // most-referenced, but already hot -> no suggestion
+  return t;
+}
+
+compact struct Unmarked {
+  int a; // expected-remark {{field 'a' is the most-referenced member (4 uses); consider marking it 'hot'}}
+  double b;
+  char c;
+};
+int uu(Unmarked *s, int n) {
+  int t = 0;
+  for (int i = 0; i < n; ++i)
+    for (int j = 0; j < n; ++j)
+      t += s[i].a; // most-referenced and unmarked -> suggested
+  return t;
+}
