diff --git a/clang/test/CXXMG/compact/compact-field-profile-atomic.cpp b/clang/test/CXXMG/compact/compact-field-profile-atomic.cpp
new file mode 100644
index 000000000..f39600b88
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-field-profile-atomic.cpp
@@ -0,0 +1,20 @@
+// C++MG: profile-driven hot placement composes with atomic false-sharing
+// isolation. With "C b H", the profiled field 'b' is pulled to offset 0, while
+// the atomic 'counter' still gets its own 64-byte cache line and the following
+// field is pushed past it.
+//
+// RUN: printf 'C b H\n' > %t.prof
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fcxxmg-field-profile-use=%t.prof -fsyntax-only -fdump-record-layouts %s | FileCheck %s
+
+compact struct C {
+  char a;
+  _Atomic int counter; // isolated onto its own cache line
+  int b;               // profiled hot -> pulled to the front
+  double d;
+};
+C c;
+
+// CHECK:      struct C
+// CHECK:      0 |{{.*}}int b
+// CHECK:      64 |{{.*}}_Atomic(int) counter
+// CHECK:      {{.*}}sizeof=192, align=64
diff --git a/clang/test/CXXMG/compact/compact-field-profile-edge-cases.cpp b/clang/test/CXXMG/compact/compact-field-profile-edge-cases.cpp
new file mode 100644
