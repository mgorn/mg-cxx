+bool TemplateDeclInstantiator::InstantiateCXXMGConditionalMemberDecl(
+    CXXMGConditionalMemberDecl *D, SmallVectorImpl<Decl *> &Instantiated) {
+  SmallVector<CXXMGConditionalMemberArm, 4> DependentArms;
+  SmallVector<ArrayRef<Decl *>, 4> DependentArmDecls;
+
+  auto PreserveDependentArm = [&](const CXXMGConditionalMemberArm &Arm,
+                                  Expr *Condition, unsigned ArmIndex) {
+    DependentArms.push_back(CXXMGConditionalMemberArm(
+        Condition, 0, 0, Arm.StartAS, Arm.Range, Arm.IsElseArm));
+    DependentArmDecls.push_back(D->getArmDecls(ArmIndex));
+  };
+
+  for (unsigned I = 0, N = D->getNumArms(); I != N; ++I) {
+    const CXXMGConditionalMemberArm &Arm = D->getArm(I);
+    Expr *Condition = Arm.Condition;
+    bool Selected = Arm.isElseArm();
+
+    if (Arm.hasCondition()) {
+      EnterExpressionEvaluationContext Eval(
+          SemaRef, Sema::ExpressionEvaluationContext::ConstantEvaluated);
+      ExprResult SubstCond = SemaRef.SubstExpr(Arm.Condition, TemplateArgs);
+      if (SubstCond.isInvalid())
+        return true;
+
+      ExprResult CheckedCond =
+          SemaRef.CheckCXXBooleanCondition(SubstCond.get(),
+                                           /*IsConstexpr=*/true);
+      if (CheckedCond.isInvalid())
+        return true;
+
+      Condition = CheckedCond.get();
+      if (Condition->isValueDependent()) {
+        PreserveDependentArm(Arm, Condition, I);
+        for (unsigned J = I + 1; J != N; ++J) {
+          const CXXMGConditionalMemberArm &LaterArm = D->getArm(J);
+          Expr *LaterCondition = LaterArm.Condition;
+          if (LaterArm.hasCondition()) {
+            ExprResult LaterSubst =
+                SemaRef.SubstExpr(LaterArm.Condition, TemplateArgs);
+            if (LaterSubst.isInvalid())
+              return true;
+            ExprResult LaterChecked =
+                SemaRef.CheckCXXBooleanCondition(LaterSubst.get(),
+                                                 /*IsConstexpr=*/true);
+            if (LaterChecked.isInvalid())
+              return true;
+            LaterCondition = LaterChecked.get();
+          }
+          PreserveDependentArm(LaterArm, LaterCondition, J);
+        }
+
+        auto *NewD = CXXMGConditionalMemberDecl::Create(
+            SemaRef.Context, Owner, D->getIfLoc(), DependentArms,
+            DependentArmDecls);
+        Instantiated.push_back(NewD);
+        return false;
+      }
+
+      bool ConditionValue = false;
+      if (!Condition->EvaluateAsBooleanCondition(ConditionValue,
+                                                 SemaRef.Context)) {
+        SemaRef.Diag(Condition->getExprLoc(),
+                     diag::err_constexpr_if_condition_expression_is_not_constant);
+        return true;
+      }
+
+      Selected = ConditionValue;
+    }
+
+    if (!Selected)
+      continue;
+
+    for (Decl *PatternDecl : D->getArmDecls(I)) {
+      Decl *NewArmMember = Visit(PatternDecl);
+      if (!NewArmMember)
+        return true;
+      Instantiated.push_back(NewArmMember);
+    }
+    return false;
+  }
+
+  return false;
+}
