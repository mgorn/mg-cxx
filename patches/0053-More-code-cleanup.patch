+ExpectedDecl
+ASTNodeImporter::VisitTraitRequirementDecl(TraitRequirementDecl *D) {
+  DeclContext *DC, *LexicalDC;
+  DeclarationName Name;
+  SourceLocation Loc;
+  NamedDecl *ToND;
+  if (Error Err = ImportDeclParts(D, DC, LexicalDC, Name, ToND, Loc))
+    return std::move(Err);
+  if (ToND)
+    return ToND;
+
+  ExpectedSLoc KeywordLocOrErr = import(D->getKeywordLoc());
+  if (!KeywordLocOrErr)
+    return KeywordLocOrErr.takeError();
+
+  auto FunctionTypeInfoOrErr = import(D->getFunctionTypeInfo());
+  if (!FunctionTypeInfoOrErr)
+    return FunctionTypeInfoOrErr.takeError();
+
+  auto *ToD = TraitRequirementDecl::Create(
+      Importer.getToContext(), DC, *KeywordLocOrErr, Loc,
+      Name.getAsIdentifierInfo(), D->getRequirementKind(),
+      *FunctionTypeInfoOrErr);
+  Importer.MapImported(D, ToD);
+  ToD->setLexicalDeclContext(LexicalDC);
+  LexicalDC->addDeclInternal(ToD);
+  return ToD;
+}
