+class TraitRequirementDecl final : public NamedDecl {
+public:
+  enum RequirementKind : uint8_t {
+    AssociatedTypeAny,
+    StaticFunctionAnyReturn
+  };
+
+private:
+  RequirementKind ReqKind;
+  TypeSourceInfo *FunctionTypeInfo;
+  SourceLocation KeywordLoc;
+
+  TraitRequirementDecl(DeclContext *DC, SourceLocation KeywordLoc,
+                       SourceLocation NameLoc, IdentifierInfo *Name,
+                       RequirementKind Kind,
+                       TypeSourceInfo *FunctionTypeInfo)
+      : NamedDecl(TraitRequirement, DC, NameLoc, Name), ReqKind(Kind),
+        FunctionTypeInfo(FunctionTypeInfo), KeywordLoc(KeywordLoc) {}
+
+public:
+  friend class ASTDeclReader;
+
+  static TraitRequirementDecl *Create(ASTContext &C, DeclContext *DC,
+                                      SourceLocation KeywordLoc,
+                                      SourceLocation NameLoc,
+                                      IdentifierInfo *Name,
+                                      RequirementKind Kind,
+                                      TypeSourceInfo *FunctionTypeInfo);
+  static TraitRequirementDecl *CreateDeserialized(ASTContext &C,
+                                                  GlobalDeclID ID);
+
+  RequirementKind getRequirementKind() const { return ReqKind; }
+  bool isAssociatedTypeAny() const { return ReqKind == AssociatedTypeAny; }
+  bool isStaticFunctionAnyReturn() const {
+    return ReqKind == StaticFunctionAnyReturn;
+  }
+  TypeSourceInfo *getFunctionTypeInfo() const { return FunctionTypeInfo; }
+  SourceLocation getKeywordLoc() const { return KeywordLoc; }
+
+  static bool classof(const Decl *D) { return classofKind(D->getKind()); }
+  static bool classofKind(Kind K) { return K == TraitRequirement; }
+};
