diff --git a/clang/lib/Lex/UrlInclude.cpp b/clang/lib/Lex/UrlInclude.cpp
new file mode 100644
index 000000000000..0131e3b03eda
--- /dev/null
+++ b/clang/lib/Lex/UrlInclude.cpp
@@ -0,0 +1,363 @@
+//===--- UrlInclude.cpp - C++MG URL Include Support ----------------------===//
+//
+// C++MG licensing notice pending. This file intentionally uses the LLVM
+// source-file banner style, but the final license for mg-cxx patch-owned
+// sources has not been selected yet.
+//
+//===----------------------------------------------------------------------===//
+//
+// This file implements cache, download, locking, and diagnostic support for
+// the C++MG #urlinclude directive.
+//
+//===----------------------------------------------------------------------===//
+
+#include "UrlInclude.h"
+#include "clang/Basic/CharInfo.h"
+#include "clang/Lex/LexDiagnostic.h"
+#include "clang/Lex/Preprocessor.h"
+#include "clang/Lex/PreprocessorOptions.h"
+#include "llvm/ADT/ArrayRef.h"
+#include "llvm/ADT/STLExtras.h"
+#include "llvm/ADT/ScopeExit.h"
+#include "llvm/ADT/StringExtras.h"
+#include "llvm/Support/Error.h"
+#include "llvm/Support/ErrorHandling.h"
+#include "llvm/Support/FileSystem.h"
+#include "llvm/Support/IOSandbox.h"
+#include "llvm/Support/LockFileManager.h"
+#include "llvm/Support/Path.h"
+#include "llvm/Support/Process.h"
+#include "llvm/Support/Program.h"
+#include "llvm/Support/SHA256.h"
+#include <algorithm>
+#include <chrono>
+#include <optional>
+#include <string>
+#include <system_error>
+
+using namespace clang;
+
+namespace {
+
+std::string getUrlIncludeHash(StringRef URL) {
+  auto Digest = llvm::SHA256::hash(llvm::arrayRefFromStringRef(URL));
+  return llvm::toHex(Digest, /*LowerCase=*/true);
+}
+
+std::string sanitizeUrlIncludeBasename(StringRef URL) {
+  StringRef WithoutFragment = URL.split('#').first;
+  StringRef WithoutQuery = WithoutFragment.split('?').first;
+  StringRef Base = llvm::sys::path::filename(WithoutQuery,
+                                             llvm::sys::path::Style::posix);
+  std::string Result;
+  for (char C : Base.take_front(80)) {
+    if (llvm::isAlnum(C) || C == '.' || C == '_' || C == '-')
+      Result.push_back(C);
+    else
+      Result.push_back('_');
+  }
+  if (Result.empty())
+    Result = "urlinclude.hpp";
+  return Result;
+}
+
+std::string redactUrlIncludeForDiagnostics(StringRef URL) {
+  StringRef Scheme = URL.take_until([](char C) { return C == ':'; });
+  StringRef Rest = URL.drop_front(Scheme.size());
+  if (!Rest.consume_front("://"))
+    return "<redacted-url>";
+
+  StringRef Authority = Rest.take_until([](char C) {
+    return C == '/' || C == '?' || C == '#';
+  });
+  StringRef PathAndSuffix = Rest.drop_front(Authority.size());
+  StringRef Host = Authority;
+  if (size_t At = Authority.rfind('@'); At != StringRef::npos)
+    Host = Authority.drop_front(At + 1);
+
+  StringRef Path = PathAndSuffix.take_until([](char C) {
+    return C == '?' || C == '#';
+  });
+  StringRef QueryAndFragment = PathAndSuffix.drop_front(Path.size());
+  StringRef Base = llvm::sys::path::filename(Path,
+                                             llvm::sys::path::Style::posix);
+
+  std::string Result;
+  Result += Scheme;
+  Result += "://";
+  Result += Host;
+  if (!Base.empty()) {
+    Result += "/.../";
+    Result += Base;
+  }
+
+  if (QueryAndFragment.contains('?'))
+    Result += "?[redacted]";
+  if (QueryAndFragment.contains('#'))
+    Result += "#[redacted]";
+  return Result;
+}
+
+bool hasUrlIncludeRawWhitespaceOrControl(StringRef URL) {
+  return llvm::any_of(URL, [](char C) {
+    unsigned char UC = static_cast<unsigned char>(C);
+    return UC <= 0x20 || UC == 0x7f;
+  });
+}
+
+bool validateUrlInclude(Preprocessor &PP, StringRef URL, SourceLocation Loc) {
+  if (hasUrlIncludeRawWhitespaceOrControl(URL)) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_invalid_url)
+        << "raw whitespace or control character";
+    return false;
+  }
+
+  StringRef Scheme = URL.split(':').first;
+  if (Scheme.empty() || Scheme == URL) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_expected_url);
+    return false;
+  }
+  if (Scheme != "https" && Scheme != "http") {
+    PP.Diag(Loc, diag::err_pp_urlinclude_unsupported_scheme);
+    return false;
+  }
+  if (Scheme == "http" && !PP.getPreprocessorOpts().UrlIncludeAllowHTTP) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_http_requires_flag);
+    return false;
+  }
+  StringRef Rest = URL.drop_front(Scheme.size() + 1);
+  if (!Rest.consume_front("//")) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_expected_url);
+    return false;
+  }
+  StringRef Host = Rest.take_until([](char C) {
+    return C == '/' || C == '?' || C == '#';
+  });
+  if (Host.empty()) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_invalid_url) << "empty host";
+    return false;
+  }
+  return true;
+}
+
+bool computeUrlIncludeCachePath(Preprocessor &PP, StringRef URL,
+                                SourceLocation Loc,
+                                UrlIncludeResult &Result) {
+  Result.SearchPath = PP.getPreprocessorOpts().UrlIncludeCacheDir;
+  if (std::error_code EC = llvm::sys::fs::make_absolute(Result.SearchPath)) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_cache_write_failed)
+        << Result.SearchPath;
+    return false;
+  }
+
+  std::string Hash = getUrlIncludeHash(URL);
+  std::string Base = Hash + "-" + sanitizeUrlIncludeBasename(URL);
+  Result.RelativePath = Base;
+  Result.CachePath = Result.SearchPath;
+  llvm::sys::path::append(Result.CachePath, Base);
+  return true;
+}
+
+bool shouldShowUrlIncludeProgress(Preprocessor &PP) {
+  switch (PP.getPreprocessorOpts().UrlIncludeProgress) {
+  case UrlIncludeProgressMode::Always:
+    return true;
+  case UrlIncludeProgressMode::Never:
+    return false;
+  case UrlIncludeProgressMode::Auto:
+    return llvm::sys::Process::StandardErrIsDisplayed();
+  }
+  llvm_unreachable("invalid #urlinclude progress mode");
+}
+
+bool findUrlIncludeDownloader(Preprocessor &PP, std::string &Program,
+                              std::string &Kind) {
+  StringRef Tool = PP.getPreprocessorOpts().UrlIncludeTool;
+  auto FindByName = [](StringRef Name) -> std::optional<std::string> {
+    if (llvm::ErrorOr<std::string> P = llvm::sys::findProgramByName(Name))
+      return *P;
+    return std::nullopt;
+  };
+
+  if (Tool != "auto") {
+    Kind = Tool.str();
+    if (llvm::sys::path::has_parent_path(Tool)) {
+      Program = Tool.str();
+      return true;
+    }
+    if (auto Found = FindByName(Tool)) {
+      Program = *Found;
+      return true;
+    }
+    return false;
+  }
+
+  if (auto Curl = FindByName("curl")) {
+    Program = *Curl;
+    Kind = "curl";
+    return true;
+  }
+  if (auto Wget = FindByName("wget")) {
+    Program = *Wget;
+    Kind = "wget";
+    return true;
+  }
+  return false;
+}
+
+int executeUrlIncludeDownloader(StringRef Program, ArrayRef<StringRef> Args,
+                                unsigned Timeout) {
+  // Launching the configured downloader is the only operation here that may
+  // need to escape LLVM's process sandbox. URL validation, cache checks,
+  // locking, and file writes remain in the normal sandboxed execution path.
+  auto DisableSandbox = llvm::sys::sandbox::scopedDisable();
+  return llvm::sys::ExecuteAndWait(Program, Args, std::nullopt, {}, Timeout, 0);
+}
+
+bool runUrlIncludeDownloader(Preprocessor &PP, StringRef URL,
+                             SourceLocation Loc, StringRef OutputPath,
+                             std::string &Downloader) {
+  std::string Program;
+  if (!findUrlIncludeDownloader(PP, Program, Downloader)) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_no_downloader);
+    return false;
+  }
+
+  bool ShowProgress = shouldShowUrlIncludeProgress(PP);
+  unsigned Timeout = PP.getPreprocessorOpts().UrlIncludeTimeout;
+  SmallVector<StringRef, 16> Args;
+  Args.push_back(Program);
+
+  if (Downloader == "curl" || llvm::sys::path::filename(Program) == "curl") {
+    Args.append({"--disable", "-L", "--fail", "--show-error",
+                 "--connect-timeout", "10", "--max-time"});
+    std::string TimeoutStr = std::to_string(Timeout);
+    Args.push_back(TimeoutStr);
+    if (ShowProgress)
+      Args.push_back("--progress-bar");
+    else
+      Args.append({"--silent", "--show-error"});
+    if (PP.getPreprocessorOpts().UrlIncludeAllowHTTP)
+      Args.append({"--proto", "=http,https", "--proto-redir", "=http,https"});
+    else
+      Args.append({"--proto", "=https", "--proto-redir", "=https"});
+    Args.append({"-o", OutputPath, "--", URL});
+    int Code = executeUrlIncludeDownloader(Program, Args, Timeout);
+    if (Code != 0) {
+      PP.Diag(Loc, diag::err_pp_urlinclude_download_failed)
+          << redactUrlIncludeForDiagnostics(URL) << Downloader;
+      return false;
+    }
+    return true;
+  }
+
+  if (Downloader == "wget" || llvm::sys::path::filename(Program) == "wget") {
+    std::string TimeoutArg = "--timeout=" + std::to_string(Timeout);
+    Args.append({"-O", OutputPath, TimeoutArg, "--tries=1"});
+    if (ShowProgress)
+      Args.push_back("--progress=bar:force:noscroll");
+    else
+      Args.push_back("--no-verbose");
+    Args.append({"--", URL});
+    int Code = executeUrlIncludeDownloader(Program, Args, Timeout);
+    if (Code != 0) {
+      PP.Diag(Loc, diag::err_pp_urlinclude_download_failed)
+          << redactUrlIncludeForDiagnostics(URL) << Downloader;
+      return false;
+    }
+    return true;
+  }
+
+  for (const std::string &Arg : PP.getPreprocessorOpts().UrlIncludeToolArgs)
+    Args.push_back(Arg);
+  Args.append({"-o", OutputPath, URL});
+  int Code = executeUrlIncludeDownloader(Program, Args, Timeout);
+  if (Code != 0) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_download_failed)
+        << redactUrlIncludeForDiagnostics(URL) << Downloader;
+    return false;
+  }
+  return true;
+}
+
+} // namespace
+
+bool clang::ensureUrlIncludeCached(Preprocessor &PP, StringRef URL,
+                                   SourceLocation Loc,
+                                   UrlIncludeResult &Result) {
+  if (!validateUrlInclude(PP, URL, Loc))
+    return false;
+  if (!computeUrlIncludeCachePath(PP, URL, Loc, Result))
+    return false;
+
+  const PreprocessorOptions &Opts = PP.getPreprocessorOpts();
+  if (!Opts.UrlIncludeRefresh &&
+      llvm::sys::fs::exists(Twine(Result.CachePath))) {
+    Result.CacheHit = true;
+    return true;
+  }
+
+  if (Opts.UrlIncludeOffline) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_offline_cache_miss)
+        << redactUrlIncludeForDiagnostics(URL);
+    return false;
+  }
+
+  if (std::error_code EC = llvm::sys::fs::create_directories(Result.SearchPath)) {
+    PP.Diag(Loc, diag::err_pp_urlinclude_cache_write_failed)
+        << Result.SearchPath;
+    return false;
+  }
+
+  for (;;) {
+    llvm::LockFileManager Lock(Result.CachePath);
+    auto Locked = Lock.tryLock();
+    if (!Locked) {
+      consumeError(Locked.takeError());
+      PP.Diag(Loc, diag::err_pp_urlinclude_lock_timeout) << Result.CachePath;
+      return false;
+    }
+
+    if (!*Locked) {
+      if (Lock.waitForUnlockFor(std::chrono::seconds(
+              std::max(60u, Opts.UrlIncludeTimeout))) ==
+          llvm::WaitForUnlockResult::Timeout) {
+        PP.Diag(Loc, diag::err_pp_urlinclude_lock_timeout) << Result.CachePath;
+        return false;
+      }
+      continue;
+    }
+
+    if (!Opts.UrlIncludeRefresh &&
+        llvm::sys::fs::exists(Twine(Result.CachePath))) {
+      Result.CacheHit = true;
+      return true;
+    }
+
+    SmallString<256> TmpModel = Result.SearchPath;
+    llvm::sys::path::append(TmpModel, "urlinclude-%%%%%%%%.tmp");
+    SmallString<256> TmpPath;
+    if (std::error_code EC =
+            llvm::sys::fs::createUniqueFile(TmpModel, TmpPath)) {
+      PP.Diag(Loc, diag::err_pp_urlinclude_cache_write_failed) << TmpModel;
+      return false;
+    }
+    llvm::scope_exit Cleanup([&] { llvm::sys::fs::remove(Twine(TmpPath)); });
+
+    if (!runUrlIncludeDownloader(PP, URL, Loc, TmpPath, Result.Downloader))
+      return false;
+    if (!llvm::sys::fs::exists(Twine(TmpPath))) {
+      PP.Diag(Loc, diag::err_pp_urlinclude_cache_file_missing) << TmpPath;
+      return false;
+    }
+
+    if (std::error_code EC =
+            llvm::sys::fs::rename(Twine(TmpPath), Twine(Result.CachePath))) {
+      PP.Diag(Loc, diag::err_pp_urlinclude_cache_write_failed)
+          << Result.CachePath;
+      return false;
+    }
+    Cleanup.release();
+    return true;
+  }
+}
