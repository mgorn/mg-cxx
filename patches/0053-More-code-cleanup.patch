diff --git a/clang/lib/Sema/SemaExprCXXMG.cpp b/clang/lib/Sema/SemaExprCXXMG.cpp
new file mode 100644
index 000000000000..4508b6642ea2
--- /dev/null
+++ b/clang/lib/Sema/SemaExprCXXMG.cpp
@@ -0,0 +1,140 @@
+//===--- SemaExprCXXMG.cpp - C++MG Expression Semantics ------------------===//
+//
+// C++MG licensing notice pending. This file intentionally uses the LLVM
+// source-file banner style, but the final license for mg-cxx patch-owned
+// sources has not been selected yet.
+//
+//===----------------------------------------------------------------------===//
+//
+// This file implements semantic analysis helpers for C++MG expressions.
+//
+//===----------------------------------------------------------------------===//
+
+#include "SemaCXXMG.h"
+#include "clang/AST/DeclCXX.h"
+#include "clang/AST/DeclCXXMG.h"
+#include "clang/AST/ExprCXX.h"
+#include "clang/Sema/Sema.h"
+#include "llvm/Support/Casting.h"
+
+using namespace clang;
+
+static bool cxxmgIsExpressionUsableConditionalMemberPatternDecl(
+    const NamedDecl *ND) {
+  if (!ND || ND->isInvalidDecl())
+    return false;
+
+  if (isa<ValueDecl>(ND))
+    return true;
+
+  if (const auto *Shadow = dyn_cast<UsingShadowDecl>(ND))
+    return cxxmgIsExpressionUsableConditionalMemberPatternDecl(
+        Shadow->getTargetDecl());
+
+  if (isa<UnresolvedUsingValueDecl>(ND))
+    return true;
+
+  return false;
+}
+
+static bool cxxmgConditionalMemberPatternDeclMatchesName(
+    const Decl *D, DeclarationName Name) {
+  if (!D)
+    return false;
+
+  if (const auto *ND = dyn_cast<NamedDecl>(D)) {
+    if (ND->getDeclName() == Name &&
+        cxxmgIsExpressionUsableConditionalMemberPatternDecl(ND))
+      return true;
+  }
+
+  if (const auto *BUD = dyn_cast<BaseUsingDecl>(D)) {
+    for (const UsingShadowDecl *Shadow : BUD->shadows()) {
+      if (Shadow->getDeclName() == Name &&
+          cxxmgIsExpressionUsableConditionalMemberPatternDecl(Shadow))
+        return true;
+    }
+  }
+
+  return false;
+}
+
+static constexpr unsigned CXXMGInvalidConditionalMemberArmIndex = ~0u;
+
+static unsigned getFirstPossiblySelectedCXXMGConditionalMemberArm(
+    Sema &S, const CXXMGConditionalMemberDecl *CMD) {
+  unsigned Index = 0;
+
+  for (const CXXMGConditionalMemberArm &Arm : CMD->arms()) {
+    if (!Arm.hasCondition())
+      return CXXMGInvalidConditionalMemberArmIndex;
+
+    if (Arm.Condition->isValueDependent())
+      return Index;
+
+    bool ConditionValue = false;
+    if (!Arm.Condition->EvaluateAsBooleanCondition(ConditionValue, S.Context))
+      return CXXMGInvalidConditionalMemberArmIndex;
+
+    if (ConditionValue)
+      return CXXMGInvalidConditionalMemberArmIndex;
+
+    ++Index;
+  }
+
+  return CXXMGInvalidConditionalMemberArmIndex;
+}
+
+static bool recordHasCXXMGConditionalMemberExpressionCandidate(
+    Sema &S, const CXXRecordDecl *RD, DeclarationName Name) {
+  if (!RD || !RD->hasDefinition())
+    return false;
+
+  if (!RD->isDependentContext())
+    return false;
+
+  for (const Decl *D : RD->decls()) {
+    const auto *CMD = dyn_cast<CXXMGConditionalMemberDecl>(D);
+    if (!CMD)
+      continue;
+
+    unsigned FirstPossibleArm =
+        getFirstPossiblySelectedCXXMGConditionalMemberArm(S, CMD);
+    if (FirstPossibleArm == CXXMGInvalidConditionalMemberArmIndex)
+      continue;
+
+    for (unsigned I = FirstPossibleArm, N = CMD->getNumArms(); I != N; ++I) {
+      for (const Decl *PatternDecl : CMD->getArmDecls(I)) {
+        if (cxxmgConditionalMemberPatternDeclMatchesName(PatternDecl, Name))
+          return true;
+      }
+    }
+  }
+
+  return false;
+}
+
+Expr *clang::recoverFromCXXMGConditionalMemberLookup(
+    Sema &S, ASTContext &Context, DeclarationNameInfo &NameInfo,
+    SourceLocation TemplateKWLoc,
+    const TemplateArgumentListInfo *TemplateArgs) {
+  QualType ThisType = S.getCurrentThisType();
+
+  if (ThisType.isNull() || !ThisType->isPointerType())
+    return nullptr;
+
+  const CXXRecordDecl *RD = ThisType->getPointeeType()->getAsCXXRecordDecl();
+  if (!RD)
+    return nullptr;
+
+  if (!recordHasCXXMGConditionalMemberExpressionCandidate(
+          S, RD, NameInfo.getName()))
+    return nullptr;
+
+  return CXXDependentScopeMemberExpr::Create(
+      Context,
+      /*This=*/nullptr, ThisType,
+      /*IsArrow=*/true,
+      /*Op=*/SourceLocation(), NestedNameSpecifierLoc(), TemplateKWLoc,
+      /*FirstQualifierFoundInScope=*/nullptr, NameInfo, TemplateArgs);
+}
