diff --git a/clang/test/CXXMG/regression/reverted-type-trait-keyword.cpp b/clang/test/CXXMG/regression/reverted-type-trait-keyword.cpp
new file mode 100644
index 000000000..b8714f3d6
--- /dev/null
+++ b/clang/test/CXXMG/regression/reverted-type-trait-keyword.cpp
@@ -0,0 +1,32 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+namespace std {
+template <class T> struct __make_unsigned;
+// expected-warning@-1 {{keyword '__make_unsigned' will be made available as an identifier for the remainder of the translation unit}}
+
+template <class T> struct __make_unsigned {
+  using type = T;
+};
+}
+
+trait generator {
+  void generate() const;
+};
+
+template <class T> struct dependent_type {
+  using type = T;
+};
+
+template <class T> void dependent_type_construction() {
+  (void)typename dependent_type<T>::type{};
+  (void)typename dependent_type<T>::type();
+}
+
+template <class T> struct numeric_traits_like {
+  static const bool __is_signed = (T)(-1) < 0;
+  // expected-warning@-1 {{keyword '__is_signed' will be made available as an identifier for the remainder of the translation unit}}
+  static const int __digits = 32 - __is_signed;
+  static const T __min = __is_signed ? -1 : (T)0;
+};
+
+template <class T> const bool numeric_traits_like<T>::__is_signed;
