         return false;
+      if (K == tok::l_paren) {
+        if (!AllowParens)
+          return false;
+        ++ParenDepth;
+        continue;
       }
-      ++I;
-    } while (Depth != 0);
+      if (K == tok::r_paren) {
+        if (ParenDepth == 0)
+          return false;
+        --ParenDepth;
+        if (AllowParens && ParenDepth == 0)
+          return false;
+        continue;
+      }
+    }
+    if (K == tok::less) {
+      ++AngleDepth;
+    } else if (K == tok::greater) {
+      if (AngleDepth == 0)
+        return false;
+      --AngleDepth;
+    }
