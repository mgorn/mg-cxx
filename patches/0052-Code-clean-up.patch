diff --git a/clang/lib/AST/ExprCXXMG.cpp b/clang/lib/AST/ExprCXXMG.cpp
new file mode 100644
index 000000000..a6cd9c0de
--- /dev/null
+++ b/clang/lib/AST/ExprCXXMG.cpp
@@ -0,0 +1,91 @@
+//===--- ExprCXXMG.cpp - C++MG Expression AST Nodes ----------------------===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+//
+// This file implements the C++MG Expr subclasses.
+//
+//===----------------------------------------------------------------------===//
+
+#include "clang/AST/ExprCXXMG.h"
+#include "clang/AST/ASTContext.h"
+#include "clang/AST/CXXMGTypeExpr.h"
+#include "clang/AST/Type.h"
+
+using namespace clang;
+
+static ExprDependence
+computeCXXMGTypeCheckExprDependence(CXXMGTypeExprNode *ExprNode) {
+  ExprDependence D = ExprDependence::None;
+
+  if (!ExprNode)
+    return D;
+
+  if (ExprNode->containsUnexpandedParameterPack())
+    D |= ExprDependence::UnexpandedPack;
+
+  if (ExprNode->isDependent() || ExprNode->isInstantiationDependent())
+    D |= ExprDependence::ValueInstantiation;
+
+  return D;
+}
+
+CXXMGTypeCheckExpr *CXXMGTypeCheckExpr::Create(ASTContext &Ctx,
+                                               CXXMGTypeExprNode *ExprNode) {
+  return new (Ctx)
+      CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode,
+                         computeCXXMGTypeCheckExprDependence(ExprNode));
+}
+
+CXXMGTypeCheckExpr *
+CXXMGTypeCheckExpr::CreateResolved(ASTContext &Ctx,
+                                   CXXMGTypeExprNode *ExprNode, bool Value) {
+  return new (Ctx)
+      CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode, ExprDependence::None,
+                         /*HasKnownValue=*/true, Value);
+}
+
+CXXMGTypeCheckExpr *CXXMGTypeCheckExpr::CreateEmpty(ASTContext &Ctx) {
+  return new (Ctx) CXXMGTypeCheckExpr(EmptyShell());
+}
+
+static ExprDependence
+computeCXXMGImplementsExprDependence(TypeSourceInfo *CandidateTSI,
+                                      TypeSourceInfo *RequirementTSI) {
+  ExprDependence D = ExprDependence::None;
+
+  auto AddTypeDependence = [&](TypeSourceInfo *TSI) {
+    if (!TSI)
+      return;
+    QualType T = TSI->getType();
+    if (T.isNull())
+      return;
+    if (T->isDependentType())
+      D |= ExprDependence::Type | ExprDependence::Value;
+    if (T->isInstantiationDependentType())
+      D |= ExprDependence::Instantiation | ExprDependence::Value;
+    if (T->containsUnexpandedParameterPack())
+      D |= ExprDependence::UnexpandedPack;
+  };
+
+  AddTypeDependence(CandidateTSI);
+  AddTypeDependence(RequirementTSI);
+  return D;
+}
+
+CXXMGImplementsExpr *
+CXXMGImplementsExpr::Create(ASTContext &Ctx, TypeSourceInfo *CandidateTSI,
+                            TypeSourceInfo *RequirementTSI,
+                            SourceLocation OpLoc, SourceLocation OpEndLoc,
+                            SourceRange Range) {
+  return new (Ctx) CXXMGImplementsExpr(
+      Ctx.BoolTy, CandidateTSI, RequirementTSI, OpLoc, OpEndLoc, Range,
+      computeCXXMGImplementsExprDependence(CandidateTSI, RequirementTSI));
+}
+
+CXXMGImplementsExpr *CXXMGImplementsExpr::CreateEmpty(ASTContext &Ctx) {
+  return new (Ctx) CXXMGImplementsExpr(EmptyShell());
+}
