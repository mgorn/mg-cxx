index 000000000..245924e1b
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-first-cold-last.cpp
@@ -0,0 +1,19 @@
+// `hot` fields are placed first (toward the first cache line(s)) and `cold`
+// fields last, regardless of source order.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s
+
+compact struct Entity {
+  cold char name[8];  // declared first, but cold => goes last
+  int id;             // unmarked => middle
+  hot double position; // declared last, but hot => goes first
+};
+
+static_assert(sizeof(Entity) == 24, "position(8)+id(4)+name(8) padded to 24");
+
+// CHECK:      *** Dumping AST Record Layout
+// CHECK:      0 | struct Entity
+// CHECK-NEXT: 0 |   double position
+// CHECK-NEXT: 8 |   int id
+// CHECK-NEXT: 12 |   char[8] name
diff --git a/clang/test/CXXMG/compact/compact-hot-group-padding-min.cpp b/clang/test/CXXMG/compact/compact-hot-group-padding-min.cpp
new file mode 100644
index 000000000..1d1e2388f
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-group-padding-min.cpp
@@ -0,0 +1,21 @@
+// Within the `hot` group, fields are still padding-minimized (stable sort by
+// descending alignment), so `hot double` precedes `hot char` even though the
+// char was declared first.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s
+
+compact struct S {
+  hot char h1;
+  hot double h2;
+  int m;
+};
+
+// hot group {h1,h2} padding-min => {h2, h1}; then middle m.
+// h2@0, h1@8, pad to 12, m@12 => 16.
+static_assert(sizeof(S) == 16, "h2(8)+h1(1)+pad+m(4) => 16");
+
+// CHECK:      0 | struct S
+// CHECK-NEXT: 0 |   double h2
+// CHECK-NEXT: 8 |   char h1
+// CHECK-NEXT: 12 |   int m
diff --git a/clang/test/CXXMG/compact/compact-hot-priority-over-padding.cpp b/clang/test/CXXMG/compact/compact-hot-priority-over-padding.cpp
new file mode 100644
index 000000000..1d8f54aac
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-hot-priority-over-padding.cpp
@@ -0,0 +1,29 @@
+// `hot` placement takes priority over padding minimization: marking fields hot
+// can make the struct larger than the pure padding-minimized order, because the
+// hot fields are forced to the front. This is the intended tradeoff.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+compact struct HotFirst {
+  hot char a;
+  hot char b;
+  double d;
+  int i;
+};
+
+// hot {a,b} first (cost: padding before d), then middle {d,i}:
+// a@0, b@1, pad to 8, d@8, i@16 => 24.
+static_assert(sizeof(HotFirst) == 24, "hot-first costs padding");
+
+// Same members with no markers pack tightly: {d, i, a, b} => 16.
+compact struct NoMarkers {
+  char a;
+  char b;
+  double d;
+  int i;
+};
+static_assert(sizeof(NoMarkers) == 16, "padding-min packs to 16");
+
+static_assert(sizeof(HotFirst) > sizeof(NoMarkers),
+              "hotness overrides padding minimization");
