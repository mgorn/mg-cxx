          "ParseCXXClassMemberDeclaration should only be called in C++ mode");
   if (Tok.is(tok::at)) {
diff --git a/clang/test/CXXMG/compact/compact-cold-pushed-to-tail.cpp b/clang/test/CXXMG/compact/compact-cold-pushed-to-tail.cpp
new file mode 100644
index 000000000..85e944df5
--- /dev/null
+++ b/clang/test/CXXMG/compact/compact-cold-pushed-to-tail.cpp
@@ -0,0 +1,20 @@
+// A `cold` field is pushed to the tail while the unmarked fields ahead of it
+// are padding-minimized.
+//
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -fdump-record-layouts %s \
+// RUN:   | FileCheck %s
+
+compact struct Log {
+  cold char debug[16];
+  int level;
+  double timestamp;
+};
+
+// middle {level, timestamp} padding-min => {timestamp, level}; cold debug last.
+// timestamp@0, level@8, debug@12 (size 16) => 28, padded to 32.
+static_assert(sizeof(Log) == 32, "timestamp(8)+level(4)+debug(16) padded to 32");
+
+// CHECK:      0 | struct Log
+// CHECK-NEXT: 0 |   double timestamp
+// CHECK-NEXT: 8 |   int level
+// CHECK-NEXT: 12 |   char[16] debug
diff --git a/clang/test/CXXMG/compact/compact-hot-first-cold-last.cpp b/clang/test/CXXMG/compact/compact-hot-first-cold-last.cpp
