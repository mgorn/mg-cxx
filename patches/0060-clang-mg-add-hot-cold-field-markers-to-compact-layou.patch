diff --git a/clang/lib/Parse/ParseDeclCXX.cpp b/clang/lib/Parse/ParseDeclCXX.cpp
index d76592b04..10d60f0e2 100644
--- a/clang/lib/Parse/ParseDeclCXX.cpp
+++ b/clang/lib/Parse/ParseDeclCXX.cpp
@@ -2715,6 +2715,29 @@ void Parser::MaybeParseAndDiagnoseDeclSpecAfterCXX11VirtSpecifierSeq(
 Parser::DeclGroupPtrTy Parser::ParseCXXClassMemberDeclaration(
     AccessSpecifier AS, ParsedAttributes &AccessAttrs,
     ParsedTemplateInfo &TemplateInfo, ParsingDeclRAIIObject *TemplateDiags) {
+  // C++MG: consume an optional leading `hot` / `cold` field marker, parse the
+  // member normally, then record the placement hint for any field it produces.
+  cxxmg::CXXMGHotness Hotness = cxxmg::CXXMGHotness::None;
+  if (getLangOpts().CPlusPlusMG && Tok.isOneOf(tok::kw_hot, tok::kw_cold)) {
+    Hotness = Tok.is(tok::kw_hot) ? cxxmg::CXXMGHotness::Hot
+                                  : cxxmg::CXXMGHotness::Cold;
+    ConsumeToken();
+  }
+
+  DeclGroupPtrTy DG = ParseCXXClassMemberDeclarationImpl(
+      AS, AccessAttrs, TemplateInfo, TemplateDiags);
+
+  if (Hotness != cxxmg::CXXMGHotness::None && DG) {
+    for (Decl *D : DG.get())
+      if (auto *FD = dyn_cast<FieldDecl>(D))
+        CXXMGFieldHotness[FD] = Hotness;
+  }
+  return DG;
+}
+
