diff --git a/clang/lib/Parse/ParseCXXMGTypeExpr.cpp b/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
index 24be122c587a..3f54838b5b34 100644
--- a/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
+++ b/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
@@ -17,6 +17,31 @@ static bool isCXXMGTypeExprPrimaryFollowOperator(Parser &P) {
           P.GetLookAheadToken(2).is(tok::greater));
 }
 
+static bool isCXXMGTypePredicateOperator(Parser &P) {
+  return P.getCurToken().is(tok::kw_implements) ||
+         (P.getCurToken().is(tok::less) && P.NextToken().is(tok::greater));
+}
+
+static bool mayStartCXXMGTypePredicateExpression(Parser &P) {
+  for (unsigned I = 0; I != 32; ++I) {
+    const Token &Tok = P.GetLookAheadToken(I);
+    if (Tok.is(tok::kw_implements))
+      return true;
+    if (Tok.is(tok::less) && P.GetLookAheadToken(I + 1).is(tok::greater)) {
+      tok::TokenKind After = P.GetLookAheadToken(I + 2).getKind();
+      return After == tok::identifier || After == tok::coloncolon ||
+             After == tok::annot_typename || After == tok::kw_typename ||
+             After == tok::kw_decltype || After == tok::kw_struct ||
+             After == tok::kw_class || After == tok::kw_trait ||
+             After == tok::l_paren;
+    }
+    if (Tok.isOneOf(tok::semi, tok::comma, tok::r_paren, tok::r_square,
+                    tok::eof))
+      return false;
+  }
+  return false;
+}
+
 bool Parser::isCXXMGTypeCompositionOperator(tok::TokenKind K) const {
   return K == tok::plus || K == tok::minus;
 }
@@ -188,5 +213,82 @@ ExprResult Parser::TryParseCXXMGTypePredicateExpression() {
   if (!getLangOpts().CPlusPlusMG)
     return ExprEmpty();
 
-  return ExprEmpty();
+  if (!mayStartCXXMGTypePredicateExpression(*this))
+    return ExprEmpty();
+
+  if (Tok.is(tok::l_paren)) {
+    TentativeParsingAction TPA(*this);
+    ConsumeParen();
+    ExprResult Inner = TryParseCXXMGTypePredicateExpression();
+    if (!Inner.isUsable() || Tok.isNot(tok::r_paren)) {
+      TPA.Revert();
+      return ExprEmpty();
+    }
+    ConsumeParen();
+    TPA.Commit();
+    return Inner;
+  }
+
+  TentativeParsingAction TPA(*this);
+  ParsedCXXMGTypeExpr LHS;
+  if (!ParseCXXMGTypeExprPrimary(LHS, /*AllowTypeNameFallback=*/false)) {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+  if (!ParseCXXMGTypeExprRHS(LHS, prec::Unknown,
+                             /*AllowTypeNameFallback=*/false)) {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+
+  if (!isCXXMGTypePredicateOperator(*this)) {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+
+  SourceLocation OpLoc;
+  SourceLocation OpEndLoc;
+  bool UsesAngleSyntax = false;
+  if (Tok.is(tok::kw_implements)) {
+    OpLoc = ConsumeToken();
+    OpEndLoc = OpLoc;
+  } else {
+    OpLoc = ConsumeToken();
+    OpEndLoc = ConsumeToken();
+    UsesAngleSyntax = true;
+  }
+
+  if (Tok.isOneOf(tok::semi, tok::comma, tok::r_paren, tok::eof)) {
+    TPA.Commit();
+    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
+    return ExprError();
+  }
+
+  ParsedCXXMGTypeExpr RHS;
+  if (!ParseCXXMGTypeExprPrimary(RHS, /*AllowTypeNameFallback=*/true)) {
+    TPA.Commit();
+    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
+    return ExprError();
+  }
+  if (!ParseCXXMGTypeExprRHS(RHS, prec::Unknown,
+                             /*AllowTypeNameFallback=*/true)) {
+    TPA.Commit();
+    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
+    return ExprError();
+  }
+
+  auto Node = std::make_unique<ParsedCXXMGTypeExpr>();
+  Node->K = ParsedCXXMGTypeExpr::Binary;
+  Node->Op = ParsedCXXMGTypeExprOpcode::Implements;
+  Node->OpLoc = OpLoc;
+  Node->OpEndLoc = OpEndLoc;
+  Node->UsesAngleImplements = UsesAngleSyntax;
+  Node->BeginLoc = LHS.BeginLoc;
+  Node->EndLoc = RHS.EndLoc;
+  Node->SawTypeExprOperator = true;
+  Node->LHS = std::make_unique<ParsedCXXMGTypeExpr>(std::move(LHS));
+  Node->RHS = std::make_unique<ParsedCXXMGTypeExpr>(std::move(RHS));
+
+  TPA.Commit();
+  return Actions.ActOnCXXMGTypePredicateExpression(getCurScope(), *Node);
 }
