From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mike <michaelgorney4@gmail.com>
Date: Thu, 18 Jun 2026 17:58:26 -0400
Subject: [PATCH] clang-mg: Improve semantic recovery for conditional member
 access
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Implements robust semantic recovery for conditional member access (C++ MG).[4D[K
MG).
A new function, `recoverFromCXXMGConditionalMemberAccess`, is added to [K
Sema to handle
the logic for member access expressions.
This recovery path is now hooked into `SemaExprMember.cpp`, ensuring correc[6D[K
correct
handling of conditional member lookups during member reference expression c[1D[K
construction.

diff --git a/clang/lib/Sema/SemaCXXMG.h b/clang/lib/Sema/SemaCXXMG.h
index debb805c2d26..cf299e466c36 100644
--- a/clang/lib/Sema/SemaCXXMG.h
+++ b/clang/lib/Sema/SemaCXXMG.h
@@ -18,15 +18,25 @@
 namespace clang {
 
 class ASTContext;
+class CXXScopeSpec;
 class Expr;
+class NamedDecl;
 class Sema;
 struct DeclarationNameInfo;
 class TemplateArgumentListInfo;
+class QualType;
 
 Expr *recoverFromCXXMGConditionalMemberLookup(
-    Sema &S, ASTContext &Context, DeclarationNameInfo &NameInfo,
+    Sema &S, ASTContext &Context, const DeclarationNameInfo &NameInfo,
     SourceLocation TemplateKWLoc, const TemplateArgumentListInfo *TemplateArgs);
 
+Expr *recoverFromCXXMGConditionalMemberAccess(
+    Sema &S, ASTContext &Context, Expr *BaseExpr, QualType BaseExprType,
+    bool IsArrow, SourceLocation OpLoc, const CXXScopeSpec &SS,
+    SourceLocation TemplateKWLoc, NamedDecl *FirstQualifierInScope,
+    const DeclarationNameInfo &NameInfo,
+    const TemplateArgumentListInfo *TemplateArgs);
+
 } // namespace clang
 
 #endif // LLVM_CLANG_LIB_SEMA_SEMACXXMG_H
diff --git a/clang/lib/Sema/SemaExprCXXMG.cpp b/clang/lib/Sema/SemaExprCXXMG.cpp
index 4508b6642ea2..35ae69dbd85d 100644
--- a/clang/lib/Sema/SemaExprCXXMG.cpp
+++ b/clang/lib/Sema/SemaExprCXXMG.cpp
@@ -115,7 +115,7 @@ static bool recordHasCXXMGConditionalMemberExpressionCandidate(
 }
 
 Expr *clang::recoverFromCXXMGConditionalMemberLookup(
-    Sema &S, ASTContext &Context, DeclarationNameInfo &NameInfo,
+    Sema &S, ASTContext &Context, const DeclarationNameInfo &NameInfo,
     SourceLocation TemplateKWLoc,
     const TemplateArgumentListInfo *TemplateArgs) {
   QualType ThisType = S.getCurrentThisType();
@@ -138,3 +138,33 @@ Expr *clang::recoverFromCXXMGConditionalMemberLookup(
       /*Op=*/SourceLocation(), NestedNameSpecifierLoc(), TemplateKWLoc,
       /*FirstQualifierFoundInScope=*/nullptr, NameInfo, TemplateArgs);
 }
+
+Expr *clang::recoverFromCXXMGConditionalMemberAccess(
+    Sema &S, ASTContext &Context, Expr *BaseExpr, QualType BaseExprType,
+    bool IsArrow, SourceLocation OpLoc, const CXXScopeSpec &SS,
+    SourceLocation TemplateKWLoc, NamedDecl *FirstQualifierInScope,
+    const DeclarationNameInfo &NameInfo,
+    const TemplateArgumentListInfo *TemplateArgs) {
+  if (!BaseExpr || SS.isSet())
+    return nullptr;
+
+  QualType RecordType = BaseExprType;
+  if (IsArrow) {
+    if (!RecordType->isPointerType())
+      return nullptr;
+    RecordType = RecordType->castAs<PointerType>()->getPointeeType();
+  }
+
+  const CXXRecordDecl *RD = RecordType->getAsCXXRecordDecl();
+  if (!RD)
+    return nullptr;
+
+  if (!recordHasCXXMGConditionalMemberExpressionCandidate(
+          S, RD, NameInfo.getName()))
+    return nullptr;
+
+  return CXXDependentScopeMemberExpr::Create(
+      Context, BaseExpr, BaseExprType, IsArrow, OpLoc,
+      SS.getWithLocInContext(Context), TemplateKWLoc, FirstQualifierInScope,
+      NameInfo, TemplateArgs);
+}
