diff --git a/clang/test/CXXMG/conditional-members/conditional-member-dependent-this.cpp b/clang/test/CXXMG/conditional-members/conditional-member-dependent-this.cpp
new file mode 100644
index 000000000000..c40eebb23c12
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-dependent-this.cpp
@@ -0,0 +1,58 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+template <auto V>
+struct MemberTemplateUse {
+  static constexpr bool has_value = V != 0;
+
+  if constexpr (has_value) {
+    int x = 0;
+  }
+
+  template <class T>
+  void f(T) {
+    if constexpr (has_value) {
+      this->x = 1;
+    }
+  }
+};
+
+template struct MemberTemplateUse<1>;
+template struct MemberTemplateUse<0>;
+
+template <auto V>
+struct NonTemplateUse {
+  static constexpr bool has_value = V != 0;
+
+  if constexpr (has_value) {
+    int x = 0;
+  }
+
+  void f() {
+    if constexpr (has_value) {
+      this->x = 1;
+    }
+  }
+};
+
+template struct NonTemplateUse<1>;
+template struct NonTemplateUse<0>;
+
+template <auto V>
+struct UnqualifiedUse {
+  static constexpr bool has_value = V != 0;
+
+  if constexpr (has_value) {
+    int x = 0;
+  }
+
+  template <class T>
+  void f(T) {
+    if constexpr (has_value) {
+      x = 1;
+    }
+  }
+};
+
+template struct UnqualifiedUse<1>;
+template struct UnqualifiedUse<0>;
diff --git a/clang/test/CXXMG/conditional-members/conditional-member-realistic-guard.cpp b/clang/test/CXXMG/conditional-members/conditional-member-realistic-guard.cpp
new file mode 100644
index 000000000000..5f00384c0265
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-realistic-guard.cpp
@@ -0,0 +1,32 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+struct impl {
+  void on(int &) {}
+};
+
+template <class I, class E>
+concept has_on_for = requires(I i, E &e) {
+  i->on(e);
+};
+
+template <impl *Implementation>
+struct control {
+  static constexpr bool has_implementation = Implementation != nullptr;
+
+  if constexpr (has_implementation) {
+    impl *m_implementation = Implementation;
+  }
+
+  template <typename event_t>
+  void trigger(event_t &event) {
+    if constexpr (has_implementation && has_on_for<impl *, event_t>) {
+      this->m_implementation->on(event);
+    }
+  }
+};
+
+impl global_impl;
+
+template struct control<&global_impl>;
+template struct control<nullptr>;
diff --git a/clang/test/CXXMG/conditional-members/conditional-member-this-negative.cpp b/clang/test/CXXMG/conditional-members/conditional-member-this-negative.cpp
new file mode 100644
index 000000000000..f2eb0133acbe
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-this-negative.cpp
@@ -0,0 +1,31 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+template <auto V>
+struct Unguarded {
+  static constexpr bool has_value = V != 0;
+
+  if constexpr (has_value) {
+    int x = 0;
+  }
+
+  void f() {
+    this->x = 1; // expected-error {{no member named 'x'}}
+  }
+};
+
+template struct Unguarded<0>; // expected-note {{in instantiation of member function}}
+
+template <bool A, bool B>
+struct MismatchedGuard {
+  if constexpr (A) {
+    int x = 0;
+  }
+
+  void f() {
+    if constexpr (B) {
+      this->x = 1; // expected-error {{no member named 'x'}}
+    }
+  }
+};
+
+template struct MismatchedGuard<false, true>; // expected-note {{in instantiation of member function}}
