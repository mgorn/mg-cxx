 #include "clang/AST/DeclObjCCommon.h"
 #include "clang/AST/Expr.h"
 #include "clang/AST/ExprCXX.h"
+#include "clang/AST/ExprCXXMG.h"
 #include "clang/AST/Mangle.h"
 #include "clang/AST/OpenACCClause.h"
 #include "clang/AST/OpenMPClause.h"
@@ -1331,6 +1334,30 @@ bool CursorVisitor::VisitConceptDecl(ConceptDecl *D) {
   return false;
 }
 
+bool CursorVisitor::VisitTraitRequirementDecl(TraitRequirementDecl *D) {
+  if (TypeSourceInfo *TSI = D->getFunctionTypeInfo())
+    return Visit(TSI->getTypeLoc());
+  return false;
+}
+
+bool CursorVisitor::VisitCXXMGConditionalMemberDecl(
+    CXXMGConditionalMemberDecl *D) {
+  for (const CXXMGConditionalMemberArm &Arm : D->arms()) {
+    if (Arm.Condition &&
+        Visit(MakeCXCursor(Arm.Condition, StmtParent, TU, RegionOfInterest)))
+      return true;
+
+    for (Decl *SubD : Arm.Decls) {
+      if (!SubD)
+        continue;
+      if (Visit(MakeCXCursor(SubD, TU, RegionOfInterest)))
+        return true;
+    }
+  }
+
+  return false;
+}
+
 bool CursorVisitor::VisitTypeConstraint(const TypeConstraint &TC) {
   if (TC.getNestedNameSpecifierLoc()) {
     if (VisitNestedNameSpecifierLoc(TC.getNestedNameSpecifierLoc()))
@@ -1864,6 +1891,25 @@ bool CursorVisitor::VisitPackIndexingTypeLoc(PackIndexingTypeLoc TL) {
   return Visit(MakeCXCursor(TL.getIndexExpr(), StmtParent, TU));
 }
 
+bool CursorVisitor::VisitCXXMGTypeExprNode(CXXMGTypeExprNode *Node) {
+  if (!Node)
+    return false;
+
+  if (Node->isOperand()) {
+    if (TypeSourceInfo *TSI = Node->getOperandTypeSourceInfo())
+      return Visit(TSI->getTypeLoc());
+    return false;
+  }
+
+  if (VisitCXXMGTypeExprNode(Node->getLHS()))
+    return true;
+  return VisitCXXMGTypeExprNode(Node->getRHS());
+}
+
+bool CursorVisitor::VisitCXXMGTypeExprTypeLoc(CXXMGTypeExprTypeLoc TL) {
+  return VisitCXXMGTypeExprNode(TL.getTypePtr()->getTypeExprNode());
+}
+
 bool CursorVisitor::VisitInjectedClassNameTypeLoc(InjectedClassNameTypeLoc TL) {
   return Visit(MakeCursorTypeRef(TL.getDecl(), TL.getNameLoc(), TU));
 }
@@ -2123,6 +2169,8 @@ public:
   void VisitSwitchStmt(const SwitchStmt *S);
   void VisitWhileStmt(const WhileStmt *W);
   void VisitTypeTraitExpr(const TypeTraitExpr *E);
+  void VisitCXXMGImplementsExpr(const CXXMGImplementsExpr *E);
+  void VisitCXXMGTypeCheckExpr(const CXXMGTypeCheckExpr *E);
   void VisitArrayTypeTraitExpr(const ArrayTypeTraitExpr *E);
   void VisitExpressionTraitExpr(const ExpressionTraitExpr *E);
   void VisitUnresolvedMemberExpr(const UnresolvedMemberExpr *U);
@@ -2252,6 +2300,7 @@ private:
   void AddStmt(const Stmt *S);
   void AddDecl(const Decl *D, bool isFirst = true);
   void AddTypeLoc(TypeSourceInfo *TI);
+  void AddCXXMGTypeExprNode(const CXXMGTypeExprNode *Node);
   void EnqueueChildren(const Stmt *S);
   void EnqueueChildren(const OpenACCClause *S);
   void EnqueueChildren(const OMPClause *S);
@@ -2291,6 +2340,18 @@ void EnqueueVisitor::AddTypeLoc(TypeSourceInfo *TI) {
   if (TI)
     WL.push_back(TypeLocVisit(TI->getTypeLoc(), Parent));
 }
+void EnqueueVisitor::AddCXXMGTypeExprNode(const CXXMGTypeExprNode *Node) {
+  if (!Node)
+    return;
+
+  if (Node->isOperand()) {
+    AddTypeLoc(Node->getOperandTypeSourceInfo());
+    return;
+  }
+
+  AddCXXMGTypeExprNode(Node->getRHS());
+  AddCXXMGTypeExprNode(Node->getLHS());
+}
 void EnqueueVisitor::EnqueueChildren(const Stmt *S) {
   unsigned size = WL.size();
   for (const Stmt *SubStmt : S->children()) {
@@ -3255,6 +3316,15 @@ void EnqueueVisitor::VisitTypeTraitExpr(const TypeTraitExpr *E) {
     AddTypeLoc(E->getArg(I - 1));
 }
 
+void EnqueueVisitor::VisitCXXMGImplementsExpr(const CXXMGImplementsExpr *E) {
+  AddTypeLoc(E->getRequirementTypeSourceInfo());
+  AddTypeLoc(E->getCandidateTypeSourceInfo());
+}
+
+void EnqueueVisitor::VisitCXXMGTypeCheckExpr(const CXXMGTypeCheckExpr *E) {
+  AddCXXMGTypeExprNode(E->getTypeExprNode());
+}
+
 void EnqueueVisitor::VisitArrayTypeTraitExpr(const ArrayTypeTraitExpr *E) {
   AddTypeLoc(E->getQueriedTypeSourceInfo());
 }
