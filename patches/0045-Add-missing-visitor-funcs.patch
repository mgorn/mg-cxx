   case Decl::CXXDestructor:
   case Decl::CXXMethod:
   case Decl::CXXRecord:
+  case Decl::TraitRequirement:
+  case Decl::CXXMGConditionalMember:
   case Decl::ClassTemplate:
   case Decl::ClassTemplatePartialSpecialization:
   case Decl::ClassTemplateSpecialization:
